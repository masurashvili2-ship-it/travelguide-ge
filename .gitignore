.env
.env.production

# Real accounts — do not commit (copy data/users.json.example → data/users.json locally).
# On App Platform: set SEED_ADMIN_EMAIL + SEED_ADMIN_PASSWORD env vars (RUN_TIME scope) so
# the admin is auto-created on first request after each redeploy when users.json is absent.
data/users.json
# Email settings contain SMTP password — never commit
data/email-settings.json
# Contact form messages — user data, never commit
data/messages.json
