# Copy to .env locally. On DigitalOcean, set these in App → Settings → App-Level Environment Variables.

# Required in production (min 16 chars; use 32+ random bytes)
SESSION_SECRET=

# App Platform sets PORT automatically. For local prod preview:
# PORT=4321
# HOST=0.0.0.0

# Optional: shared upload storage for multi-instance / persistent files (must contain subdirs tours, what-to-do)
# UPLOAD_ROOT=/mnt/your_volume/uploads
#
# Optional: override one kind only (full directory path)
# TOUR_UPLOAD_DIR=
# WTD_UPLOAD_DIR=
