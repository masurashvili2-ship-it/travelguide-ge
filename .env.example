# Copy to .env locally. On DigitalOcean, set these in App → Settings → App-Level Environment Variables.

# Required in production (min 16 chars; use 32+ random bytes)
SESSION_SECRET=

# App Platform sets PORT automatically. For local prod preview:
# PORT=4321
# HOST=0.0.0.0

# Production persistence (Coolify / Docker / DO): mount a volume and point DATA_DIR at it.
# The volume MOUNT PATH in Coolify must equal DATA_DIR exactly, or redeploys use ephemeral /app/data.
# All JSON stores (users, tours, packages, bookings, …) live under DATA_DIR at runtime.
#
# Example (use the same path Coolify shows for the volume mount):
# DATA_DIR=/data/coolify/applications/<your-app-uuid>
# UPLOAD_ROOT=/data/coolify/applications/<your-app-uuid>/uploads
#
# UPLOAD_ROOT is optional if you only have one volume: uploads default to ${DATA_DIR}/uploads.
# Subdirs used at runtime: tours, what-to-do, regions, guides, packages.
#
# Optional: override one kind only (full directory path)
# TOUR_UPLOAD_DIR=
# WTD_UPLOAD_DIR=

# Google sign-in (OAuth 2.0). Create credentials in Google Cloud Console → APIs → Credentials.
# Authorized redirect URI: https://YOUR_DOMAIN/api/auth/google/callback (and http://localhost:4321/... for local dev)
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=

# ── Email (SMTP) ─────────────────────────────────────────────────────────────
# Used for: contact-form emails and admin notifications on new submissions.
#
# Gmail quick-start:
#   1. Google Account → Security → 2-Step Verification  (must be ON)
#   2. Google Account → Security → App passwords → create one for "Mail"
#   3. Paste the 16-char App Password below (no spaces)
#
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your@gmail.com
SMTP_PASS=your-16-char-app-password
# Optional: display name + address in From header
# SMTP_FROM=Travel Guide Georgia <your@gmail.com>
# Optional: override where site notifications are delivered (defaults to SMTP_USER)
# ADMIN_NOTIFY_EMAIL=your@gmail.com

# ── PayPal ────────────────────────────────────────────────────────────────────
# Optional: configure PayPal in Admin → Payment Settings instead.
# These env vars are NOT required; PayPal credentials are stored in payment-settings.json.
# PAYPAL_MODE=sandbox          # "sandbox" or "live"
# PAYPAL_CLIENT_ID=            # From developer.paypal.com
# PAYPAL_CLIENT_SECRET=
