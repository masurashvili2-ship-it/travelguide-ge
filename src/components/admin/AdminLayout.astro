---
import '@fontsource-variable/dm-sans';
import 'easymde/dist/easymde.min.css';
import '../../styles/admin-layout.css';
import { getRelativeLocaleUrl } from 'astro:i18n';
import type { Locale } from '../../lib/strings';
import { countUnread } from '../../lib/messages-db';

type AdminNavId =
	| 'dashboard'
	| 'submissions'
	| 'reviews'
	| 'tours-all'
	| 'tours-new'
	| 'tours-edit'
	| 'wtd-all'
	| 'wtd-new'
	| 'wtd-edit'
	| 'regions-all'
	| 'regions-new'
	| 'regions-edit'
	| 'pages-all'
	| 'pages-new'
	| 'pages-edit'
	| 'footer'
	| 'email-settings'
	| 'messages'
	| 'data-backup';

interface Props {
	locale: Locale;
	/** &lt;title&gt; */
	title: string;
	headline: string;
	subtitle?: string;
	activeNav: AdminNavId;
	userEmail: string;
}

const { locale, title, headline, subtitle, activeNav, userEmail } = Astro.props;

const urlAdmin = getRelativeLocaleUrl(locale, 'admin');
const urlSubmissions = getRelativeLocaleUrl(locale, 'admin/submissions');
const urlReviews = getRelativeLocaleUrl(locale, 'admin/reviews');
const urlToursList = getRelativeLocaleUrl(locale, 'admin/tours');
const urlNewTour = getRelativeLocaleUrl(locale, 'admin/tours/new');
const urlWtdList = getRelativeLocaleUrl(locale, 'admin/what-to-do');
const urlNewWtd = getRelativeLocaleUrl(locale, 'admin/what-to-do/new');
const urlRegionsList = getRelativeLocaleUrl(locale, 'admin/regions');
const urlNewRegion = getRelativeLocaleUrl(locale, 'admin/regions/new');
const urlPages = getRelativeLocaleUrl(locale, 'admin/pages');
const urlNewPage = getRelativeLocaleUrl(locale, 'admin/pages/new');
const urlFooter = getRelativeLocaleUrl(locale, 'admin/footer');
const urlEmailSettings = getRelativeLocaleUrl(locale, 'admin/email-settings');
const urlMessages = getRelativeLocaleUrl(locale, 'admin/messages');
const urlDataBackup = getRelativeLocaleUrl(locale, 'admin/backup');
const urlSiteHome = getRelativeLocaleUrl(locale, '/');

const dash = activeNav === 'dashboard';
const submissionsNav = activeNav === 'submissions';
const reviewsNav = activeNav === 'reviews';
const pagesAll = activeNav === 'pages-all' || activeNav === 'pages-edit';
const pagesNew = activeNav === 'pages-new';
const footerActive = activeNav === 'footer';
const emailSettingsActive = activeNav === 'email-settings';
const messagesActive = activeNav === 'messages';
const unreadCount = countUnread();
const toursBrowse = activeNav === 'tours-all' || activeNav === 'tours-edit';
const toursNewOnly = activeNav === 'tours-new';
const wtdBrowse = activeNav === 'wtd-all' || activeNav === 'wtd-edit';
const wtdNewOnly = activeNav === 'wtd-new';
const regionsBrowse = activeNav === 'regions-all' || activeNav === 'regions-edit';
const regionsNewOnly = activeNav === 'regions-new';
const usersBrowse = activeNav === 'dashboard';
const dataBackupNav = activeNav === 'data-backup';

function sideClass(active: boolean) {
	return ['admin-side__a', active && 'is-active'].filter(Boolean) as string[];
}
---

<!doctype html>
<html lang={locale} class="admin-app">
	<head>
		<meta charset="utf-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<meta name="robots" content="noindex, nofollow" />
		<title>{title}</title>
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
	</head>
	<body>
		<header class="admin-top">
			<div class="admin-top__inner">
				<div class="admin-top__row">
					<a class="admin-top__brand" href={urlSiteHome} lang="en" translate="no">TRAVELGEORGIA.GE</a>
					<div class="admin-top__tools">
						<span class="muted admin-top__email" title={userEmail}>{userEmail}</span>
						<form method="post" action="/api/auth/logout" class="admin-top__logout-form">
							<button type="submit" class="admin-top__logout">Log out</button>
						</form>
					</div>
				</div>
			</div>
		</header>

		<div class="admin-frame">
			<aside class="admin-side" aria-label="Admin menu">
				<nav class="admin-side__nav">
					<ul class="admin-side__list">
						<li>
							<a class:list={sideClass(dash)} href={urlAdmin}>Dashboard</a>
						</li>
						<li>
							<a class:list={sideClass(dataBackupNav)} href={urlDataBackup}>Backup & import</a>
						</li>
						<li>
							<a class:list={sideClass(submissionsNav)} href={urlSubmissions}>Approvals</a>
						</li>
						<li>
							<a class:list={sideClass(reviewsNav)} href={urlReviews}>Reviews</a>
						</li>
					</ul>

					<p class="admin-side__label">Pages</p>
					<ul class="admin-side__list">
						<li>
							<a class:list={sideClass(pagesAll)} href={urlPages}>All pages</a>
						</li>
						<li>
							<a class:list={sideClass(pagesNew)} href={urlNewPage}>New page</a>
						</li>
					</ul>

					<p class="admin-side__label">Site footer</p>
					<ul class="admin-side__list">
						<li>
							<a class:list={sideClass(footerActive)} href={urlFooter}>Edit footer</a>
						</li>
					</ul>

					<p class="admin-side__label">Email</p>
					<ul class="admin-side__list">
						<li>
							<a class:list={sideClass(messagesActive)} href={urlMessages}>
								Inbox
								{unreadCount > 0 && <span class="admin-nav-badge">{unreadCount}</span>}
							</a>
						</li>
						<li>
							<a class:list={sideClass(emailSettingsActive)} href={urlEmailSettings}>Email settings</a>
						</li>
					</ul>

					<p class="admin-side__label">Tours</p>
					<ul class="admin-side__list">
						<li>
							<a class:list={sideClass(toursBrowse)} href={urlToursList}>All tours</a>
						</li>
						<li>
							<a class:list={sideClass(toursNewOnly)} href={urlNewTour}>New tour</a>
						</li>
					</ul>

					<p class="admin-side__label">What to do</p>
					<ul class="admin-side__list">
						<li>
							<a class:list={sideClass(wtdBrowse)} href={urlWtdList}>All entries</a>
						</li>
						<li>
							<a class:list={sideClass(wtdNewOnly)} href={urlNewWtd}>New entry</a>
						</li>
					</ul>

					<p class="admin-side__label">Regions</p>
					<ul class="admin-side__list">
						<li>
							<a class:list={sideClass(regionsBrowse)} href={urlRegionsList}>All places</a>
						</li>
						<li>
							<a class:list={sideClass(regionsNewOnly)} href={urlNewRegion}>New place</a>
						</li>
					</ul>

					<p class="admin-side__label">Users</p>
					<ul class="admin-side__list">
						<li>
							<a class:list={sideClass(usersBrowse)} href={`${urlAdmin}#section-users`}>All users</a>
						</li>
					</ul>
				</nav>
				<div class="admin-side__foot">
					<a class="admin-side__site" href={urlSiteHome}>View public site</a>
				</div>
			</aside>

			<main class="admin-main">
				<div class="admin-main__inner">
					<header class="admin-page-head">
						<h1>{headline}</h1>
						{subtitle ? <p class="muted">{subtitle}</p> : null}
					</header>
					<slot />
				</div>
			</main>
		</div>
	</body>
</html>

<script>
import EasyMDE from 'easymde';

document.addEventListener('DOMContentLoaded', () => {
	document.querySelectorAll<HTMLTextAreaElement>('textarea.body-md').forEach((ta) => {
		new EasyMDE({
			element: ta,
			spellChecker: false,
			autosave: { enabled: false },
			status: false,
			minHeight: '320px',
			toolbar: [
				'bold', 'italic', '|',
				'heading-2', 'heading-3', '|',
				'quote', 'unordered-list', 'ordered-list', '|',
				'link', '|',
				'preview', 'side-by-side', 'fullscreen',
			],
		});
	});
});
</script>

<style>
	/* ── EasyMDE overrides to match admin design ── */
	.EasyMDEContainer {
		display: block;
	}
	.EasyMDEContainer .CodeMirror {
		font-family: ui-monospace, Consolas, monospace;
		font-size: 0.875rem;
		line-height: 1.6;
		border: 1px solid var(--border, #d0d5dd);
		border-top: none;
		border-radius: 0 0 6px 6px;
		color: var(--text, #101828);
		background: #fff;
		padding: 0.5rem;
	}
	.EasyMDEContainer .editor-toolbar {
		border: 1px solid var(--border, #d0d5dd);
		border-bottom: none;
		border-radius: 6px 6px 0 0;
		background: #f9fafb;
		opacity: 1;
	}
	.EasyMDEContainer .editor-toolbar button {
		color: #344054;
	}
	.EasyMDEContainer .editor-toolbar button:hover,
	.EasyMDEContainer .editor-toolbar button.active {
		background: #e5e7eb;
		border-color: #d0d5dd;
	}
	.EasyMDEContainer .editor-toolbar i.separator {
		border-color: #d0d5dd;
	}
	.EasyMDEContainer .editor-preview,
	.EasyMDEContainer .editor-preview-side {
		background: #fff;
		font-family: inherit;
		font-size: 0.9rem;
		line-height: 1.7;
		padding: 1rem 1.25rem;
	}
	.EasyMDEContainer .editor-preview h2,
	.EasyMDEContainer .editor-preview-side h2 {
		font-size: 1.15rem;
		margin: 1.25rem 0 0.5rem;
	}
	.EasyMDEContainer .editor-preview h3,
	.EasyMDEContainer .editor-preview-side h3 {
		font-size: 1rem;
		margin: 1rem 0 0.4rem;
	}
	.EasyMDEContainer .editor-preview ul,
	.EasyMDEContainer .editor-preview-side ul {
		padding-left: 1.4rem;
	}
	/* hide the original textarea (EasyMDE does this but add belt+suspenders) */
	.EasyMDEContainer ~ textarea {
		display: none;
	}
</style>
