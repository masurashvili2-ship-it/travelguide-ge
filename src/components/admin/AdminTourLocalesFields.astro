---
import type { TourPost } from '../../lib/tours-db';
import type { Locale } from '../../lib/strings';
import { localeNames } from '../../lib/strings';
import {
	CONTACT_SOCIAL_LABELS,
	CONTACT_SOCIAL_LINK_KEYS,
	type ContactSocialLinkKey,
} from '../../lib/contact-social-links';

interface Props {
	post?: TourPost | null;
	/** “What to do” only: Markdown for the public page right-hand contact box */
	showContactSidebar?: boolean;
}

const { post, showContactSidebar = false } = Astro.props;
const locales: Locale[] = ['en', 'ka', 'ru'];

function field(loc: Locale, key: 'title' | 'duration' | 'excerpt' | 'price' | 'body'): string {
	const b = post?.i18n[loc];
	if (!b) return '';
	const v = b[key];
	return v == null ? '' : String(v);
}

function seo(loc: Locale, key: 'seo_title' | 'seo_description'): string {
	const b = post?.i18n[loc];
	if (!b) return '';
	const v = b[key];
	return v == null ? '' : String(v);
}

function contactSidebar(loc: Locale): string {
	const b = post?.i18n[loc];
	if (!b) return '';
	return b.contact_sidebar ?? '';
}

function socialLink(loc: Locale, key: ContactSocialLinkKey): string {
	const b = post?.i18n[loc];
	if (!b?.social_links) return '';
	const v = b.social_links[key];
	return v == null ? '' : String(v);
}
---

{
	locales.map((loc) => (
		<fieldset class="locale-block">
			<legend>{localeNames[loc]} ({loc})</legend>
			<p class="muted" style="margin:0 0 0.75rem">
				Leave title, duration, and excerpt all empty to omit this language from the site.
			</p>
			<div class="row">
				<label>
					<span>Title</span>
					<input type="text" name={`${loc}_title`} value={field(loc, 'title')} />
				</label>
			</div>
			<div class="row">
				<label>
					<span>Duration</span>
					<input type="text" name={`${loc}_duration`} value={field(loc, 'duration')} />
				</label>
			</div>
			<div class="row">
				<label>
					<span>Price (optional)</span>
					<input type="text" name={`${loc}_price`} value={field(loc, 'price')} />
				</label>
			</div>
			<div class="row">
				<label>
					<span>Excerpt</span>
					<input type="text" name={`${loc}_excerpt`} value={field(loc, 'excerpt')} />
				</label>
			</div>
			<div class="row">
				<label>
					<span>SEO title (optional)</span>
					<input type="text" name={`${loc}_seo_title`} value={seo(loc, 'seo_title')} />
				</label>
			</div>
			<div class="row">
				<label>
					<span>SEO description (optional)</span>
					<input type="text" name={`${loc}_seo_description`} value={seo(loc, 'seo_description')} />
				</label>
			</div>
			<div class="row">
				<label>
					<span>Body (Markdown)</span>
					<textarea name={`${loc}_body`} class="body-md">
						{field(loc, 'body')}
					</textarea>
				</label>
			</div>
			{showContactSidebar ? (
				<>
					<div class="row">
						<label>
							<span>Contact sidebar (Markdown)</span>
							<p class="muted" style="margin:0 0 0.35rem">
								Shown under <strong>Contact &amp; hours</strong> on the public “What to do” page for this
								language. Use for hours, address, booking copy, etc. Optional social URLs below are listed
								first; this field can add free-form notes.
							</p>
							<textarea name={`${loc}_contact_sidebar`} class="body-md contact-sidebar-md">
								{contactSidebar(loc)}
							</textarea>
						</label>
					</div>
					<div class="row contact-social-grid-wrap">
						<span class="contact-social-grid-wrap__label">Social &amp; contact links (optional)</span>
						<p class="muted" style="margin:0 0 0.5rem">
							Full URLs are best (e.g. <code>https://instagram.com/yourpage</code>). For WhatsApp, a phone
							number (digits) or a <code>wa.me</code> link; for Telegram, <code>@username</code> or a{' '}
							<code>t.me</code> link.
						</p>
						<div class="contact-social-grid">
							{CONTACT_SOCIAL_LINK_KEYS.map((key) => (
								<label class="contact-social-grid__item">
									<span>{CONTACT_SOCIAL_LABELS[key]}</span>
									<input
										type="text"
										name={`${loc}_social_${key}`}
										value={socialLink(loc, key)}
										autocomplete="off"
									/>
								</label>
							))}
						</div>
					</div>
				</>
			) : null}
		</fieldset>
	))
}

<style>
	.body-md {
		min-height: 160px;
		font-family: ui-monospace, monospace;
		font-size: 0.88rem;
	}
	.contact-sidebar-md {
		min-height: 120px;
	}
	.contact-social-grid-wrap__label {
		display: block;
		font-weight: 600;
		margin-bottom: 0.25rem;
	}
	.contact-social-grid {
		display: grid;
		gap: 0.65rem 1rem;
		grid-template-columns: repeat(auto-fill, minmax(200px, 1fr));
	}
	.contact-social-grid__item {
		display: flex;
		flex-direction: column;
		gap: 0.2rem;
		font-size: 0.88rem;
	}
	.contact-social-grid__item input {
		width: 100%;
	}
</style>
