---
import { getRelativeLocaleUrl } from 'astro:i18n';
import { marked } from 'marked';
import {
	getFooterBlurbMarkdown,
	getFooterNavForLocale,
	getFooterBrandLine,
	getFooterAboutMarkdown,
	getFooterExploreHeading,
	getFooterCompanyHeading,
	getFooterExploreNavForLocale,
	getFooterCompanyNavForLocale,
	type FooterNavEntry,
} from '../lib/footer-db';
import type { Locale } from '../lib/strings';
import { ui } from '../lib/strings';

interface Props {
	locale: Locale;
}

const { locale } = Astro.props;
const t = ui[locale];
const footerNav = getFooterNavForLocale(locale);
const blurbMd = getFooterBlurbMarkdown(locale);
const blurbParsed = blurbMd ? marked.parse(blurbMd, { async: false }) : '';
const footerBlurbHtml = typeof blurbParsed === 'string' ? blurbParsed : '';
const footerHasExtras = footerNav.length > 0 || footerBlurbHtml.trim().length > 0;
const year = new Date().getFullYear();
const home = getRelativeLocaleUrl(locale, '/');
const policyHref = getRelativeLocaleUrl(locale, 'policy');

const brandLine = getFooterBrandLine(locale) ?? 'TRAVELGEORGIA.GE';
const exploreHeading = getFooterExploreHeading(locale) ?? t.footerColExplore;
const companyHeading = getFooterCompanyHeading(locale) ?? t.footerColCompany;
const exploreNav = getFooterExploreNavForLocale(locale);
const companyNav = getFooterCompanyNavForLocale(locale);

const aboutMd = getFooterAboutMarkdown(locale);
const aboutParsed = aboutMd ? marked.parse(aboutMd, { async: false }) : '';
const aboutHtml = typeof aboutParsed === 'string' ? aboutParsed : '';
const aboutIsCustom = aboutMd.trim().length > 0;

function footerNavHref(e: FooterNavEntry): string {
	if (e.kind === 'external') return e.url;
	if (e.path === '') return home;
	return getRelativeLocaleUrl(locale, e.path);
}
---

<footer class="site-footer">
	<div class="site-footer__grid">
		<div class="site-footer__brand">
			<a class="site-footer__brand-link" href={home}>
				<img
					class="site-footer__logo"
					src="/logo.svg"
					width="40"
					height="40"
					alt=""
					decoding="async"
					loading="lazy"
				/>
				<span class="site-footer__brand-text" lang="en" translate="no">{brandLine}</span>
			</a>
			{
				aboutIsCustom ? (
					<div class="site-footer__about site-footer__about--md prose" set:html={aboutHtml} />
				) : (
					<p class="site-footer__about">{t.footerAboutText}</p>
				)
			}
		</div>

		<nav class="site-footer__col" aria-labelledby="footer-explore-h">
			<h2 id="footer-explore-h" class="site-footer__h">{exploreHeading}</h2>
			<ul class="site-footer__list">
				{exploreNav.map((e) => (
					<li>
						<a href={footerNavHref(e)} {...(e.kind === 'external' ? { target: '_blank', rel: 'noopener noreferrer' } : {})}>
							{e.title}
						</a>
					</li>
				))}
			</ul>
		</nav>

		<nav class="site-footer__col" aria-labelledby="footer-company-h">
			<h2 id="footer-company-h" class="site-footer__h">{companyHeading}</h2>
			<ul class="site-footer__list">
				{companyNav.map((e) => (
					<li>
						<a href={footerNavHref(e)} {...(e.kind === 'external' ? { target: '_blank', rel: 'noopener noreferrer' } : {})}>
							{e.title}
						</a>
					</li>
				))}
			</ul>
		</nav>
	</div>

	{
		footerHasExtras ? (
			<div class="site-footer__cms">
				{footerNav.length > 0 ? (
					<nav class="site-footer__cms-nav" aria-label={t.footerSitePages}>
						{footerNav.map((e) => {
							const href = e.kind === 'internal' ? getRelativeLocaleUrl(locale, e.path) : e.url;
							const external = e.kind === 'external';
							return (
								<a
									href={href}
									target={external ? '_blank' : undefined}
									rel={external ? 'noopener noreferrer' : undefined}
								>
									{e.title}
								</a>
							);
						})}
					</nav>
				) : null}
				{footerBlurbHtml.trim() ? (
					<div class="site-footer__blurb prose" set:html={footerBlurbHtml} />
				) : null}
			</div>
		) : null
	}

	<div class="site-footer__bottom">
		<p class="site-footer__meta">© {year} {t.siteTitle}</p>
		<p class="site-footer__legal">
			<a href={policyHref}>{t.footerPolicy}</a>
		</p>
	</div>
</footer>
