---
import { getRelativeLocaleUrl } from 'astro:i18n';
import { marked } from 'marked';
import { getFooterBlurbMarkdown, getFooterNavForLocale } from '../lib/footer-db';
import type { Locale } from '../lib/strings';
import { ui } from '../lib/strings';

interface Props {
	locale: Locale;
}

const { locale } = Astro.props;
const t = ui[locale];
const footerNav = getFooterNavForLocale(locale);
const blurbMd = getFooterBlurbMarkdown(locale);
const blurbParsed = blurbMd ? marked.parse(blurbMd, { async: false }) : '';
const footerBlurbHtml = typeof blurbParsed === 'string' ? blurbParsed : '';
const footerHasExtras = footerNav.length > 0 || footerBlurbHtml.trim().length > 0;
const year = new Date().getFullYear();
---

<footer class:list={['site-footer', { 'site-footer--links': footerHasExtras }]}>
	{
		footerNav.length > 0 ? (
			<nav aria-label={t.footerSitePages}>
				{footerNav.map((e) => {
					const href = e.kind === 'internal' ? getRelativeLocaleUrl(locale, e.path) : e.url;
					const external = e.kind === 'external';
					return (
						<a
							href={href}
							target={external ? '_blank' : undefined}
							rel={external ? 'noopener noreferrer' : undefined}
						>
							{e.title}
						</a>
					);
				})}
			</nav>
		) : null
	}
	{
		footerBlurbHtml.trim() ? (
			<div class="site-footer__blurb prose" set:html={footerBlurbHtml} />
		) : null
	}
	<p class="site-footer__meta">
		© {year} {t.siteTitle}
	</p>
</footer>
