---
import { getRelativeLocaleUrl } from 'astro:i18n';
import SiteFooter from './SiteFooter.astro';
import { absoluteSeoUrl } from '../lib/seo';
import type { Locale } from '../lib/strings';
import LocaleFlag from './LocaleFlag.astro';
import { localeNames, ui } from '../lib/strings';

interface Props {
	locale: Locale;
	/** Path after locale, e.g. "" | "tours" | "tours/slug" */
	subpath?: string;
	title?: string;
	/** Overrides `title` for &lt;title&gt;, og:title, twitter:title when set */
	seoTitle?: string;
	seoDescription?: string;
	/** Path starting with / (e.g. /en/tours/slug); defaults to current URL path */
	canonicalPath?: string;
	seoImage?: string | null;
	ogType?: 'website' | 'article';
	jsonLd?: Record<string, unknown> | null;
	robotsNoindex?: boolean;
}

const {
	locale,
	subpath = '',
	title,
	seoTitle,
	seoDescription,
	canonicalPath,
	seoImage,
	ogType = 'website',
	jsonLd,
	robotsNoindex,
} = Astro.props;
const t = ui[locale];
const user = Astro.locals.user;

const site = Astro.site;
const pathForCanonical = canonicalPath ?? Astro.url.pathname;
const canonicalHref = site ? new URL(pathForCanonical, site).href : Astro.url.href;
const titleSegment = seoTitle?.trim() || title?.trim();
const pageTitle = titleSegment ? `${titleSegment} · ${t.siteTitle}` : t.siteTitle;
const ogTitleText = titleSegment || t.siteTitle;
const metaDesc = seoDescription?.trim();
const ogImageAbs = absoluteSeoUrl(seoImage ?? undefined, site);
const twitterCard = ogImageAbs ? 'summary_large_image' : 'summary';
const jsonLdStr = jsonLd ? JSON.stringify(jsonLd) : '';

const locales: Locale[] = ['en', 'ka', 'ru'];
---

<!doctype html>
<html lang={locale}>
	<head>
		<meta charset="utf-8" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<meta name="generator" content={Astro.generator} />
		<link rel="preconnect" href="https://fonts.googleapis.com" />
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
		<link
			href="https://fonts.googleapis.com/css2?family=DM+Sans:ital,opsz,wght@0,9..40,400;0,9..40,500;0,9..40,600;0,9..40,700;1,9..40,400&display=swap"
			rel="stylesheet"
		/>
		{robotsNoindex ? <meta name="robots" content="noindex, nofollow" /> : null}
		<title>{pageTitle}</title>
		{metaDesc ? <meta name="description" content={metaDesc} /> : null}
		<link rel="canonical" href={canonicalHref} />
		<meta property="og:title" content={ogTitleText} />
		{metaDesc ? <meta property="og:description" content={metaDesc} /> : null}
		<meta property="og:url" content={canonicalHref} />
		<meta property="og:type" content={ogType} />
		<meta property="og:locale" content={locale === 'en' ? 'en_US' : locale === 'ka' ? 'ka_GE' : 'ru_RU'} />
		<meta property="og:site_name" content={t.siteTitle} />
		{ogImageAbs ? <meta property="og:image" content={ogImageAbs} /> : null}
		<meta name="twitter:card" content={twitterCard} />
		<meta name="twitter:title" content={ogTitleText} />
		{metaDesc ? <meta name="twitter:description" content={metaDesc} /> : null}
		{ogImageAbs ? <meta name="twitter:image" content={ogImageAbs} /> : null}
		{jsonLdStr ? <script type="application/ld+json" set:html={jsonLdStr} /> : null}
		<style is:global>
			:root {
				--font-sans: 'DM Sans', ui-sans-serif, system-ui, 'Segoe UI', Roboto, 'Noto Sans Georgian', sans-serif;
				--bg: #f1f5f9;
				--surface: #ffffff;
				--text: #0f172a;
				--muted: #64748b;
				--accent: #0d9488;
				--accent-dim: #0f766e;
				--accent-glow: color-mix(in srgb, var(--accent) 22%, transparent);
				--btn-text: #ffffff;
				--border: #e2e8f0;
				--danger: #dc2626;
				--header-bg: color-mix(in srgb, var(--surface) 78%, transparent);
				--shadow-sm: 0 1px 2px rgba(15, 23, 42, 0.05);
				--shadow-md: 0 4px 20px rgba(15, 23, 42, 0.07);
				--shadow-lg: 0 16px 48px rgba(15, 23, 42, 0.1);
				--radius-sm: 10px;
				--radius-md: 14px;
				--radius-lg: 18px;
				font-family: var(--font-sans);
			}
			* {
				box-sizing: border-box;
			}
			body {
				margin: 0;
				min-height: 100vh;
				background-color: var(--bg);
				background-image:
					radial-gradient(ellipse 120% 90% at 0% -30%, color-mix(in srgb, var(--accent) 14%, transparent), transparent 52%),
					radial-gradient(ellipse 90% 70% at 100% -10%, rgba(99, 102, 241, 0.07), transparent 48%),
					linear-gradient(180deg, #f8fafc 0%, var(--bg) 45%, #eef2f7 100%);
				color: var(--text);
				line-height: 1.65;
				font-family: var(--font-sans);
				font-size: 1.02rem;
				-webkit-font-smoothing: antialiased;
			}
			a {
				color: var(--accent);
				text-decoration: none;
				transition: color 0.15s ease, opacity 0.15s ease;
			}
			a:hover {
				color: var(--accent-dim);
				text-decoration: underline;
				text-underline-offset: 3px;
			}
			.wrap {
				max-width: min(1200px, calc(100vw - 2rem));
				margin: 0 auto;
				padding: 0 1.25rem 3.5rem;
			}
			/**
			 * Blur lives on .site__glass-bg, not on header itself — otherwise `backdrop-filter` on the
			 * header creates a containing block and `position: fixed` on the mobile drawer is clipped
			 * to the short header bar.
			 */
			header.site {
				position: sticky;
				top: 0;
				/* Above in-page UI (maps, heroes, Leaflet); stay below tour lightbox (.tdh-lb ~99999) */
				z-index: 90000;
				width: 100%;
				margin-bottom: 2rem;
				padding: 1rem 0;
				border-bottom: 1px solid var(--border);
				background: transparent;
				box-shadow: var(--shadow-sm);
			}
			.site__glass-bg {
				position: absolute;
				inset: 0;
				z-index: 0;
				background: var(--header-bg);
				backdrop-filter: blur(14px);
				-webkit-backdrop-filter: blur(14px);
				pointer-events: none;
			}
			.site__inner {
				position: relative;
				z-index: 1;
				max-width: min(1200px, calc(100vw - 2rem));
				margin: 0 auto;
				padding: 0 1.25rem;
				display: flex;
				flex-wrap: wrap;
				align-items: center;
				justify-content: space-between;
				gap: 1rem 1.25rem;
			}
			.brand {
				font-weight: 700;
				font-size: clamp(0.95rem, 2.8vw, 1.125rem);
				letter-spacing: 0.02em;
				flex: 0 1 auto;
				min-width: 0;
				overflow: hidden;
			}
			.brand a,
			.brand__link {
				display: inline-flex;
				align-items: center;
				gap: 0.55rem;
				min-width: 0;
				max-width: 100%;
				color: var(--text);
				text-decoration: none;
			}
			.brand a:hover,
			.brand__link:hover {
				color: var(--accent);
			}
			.brand__logo {
				flex-shrink: 0;
				width: 2.35rem;
				height: 2.35rem;
				border-radius: 10px;
				object-fit: contain;
				display: block;
			}
			.brand__text {
				min-width: 0;
				white-space: nowrap;
				overflow: hidden;
				text-overflow: ellipsis;
			}
			.site-nav-toggle {
				display: none;
				align-items: center;
				justify-content: center;
				width: 2.65rem;
				height: 2.65rem;
				margin: 0;
				padding: 0;
				flex-shrink: 0;
				border: 1px solid var(--border);
				border-radius: var(--radius-sm);
				background: var(--surface);
				color: var(--text);
				cursor: pointer;
				box-shadow: var(--shadow-sm);
				transition:
					border-color 0.15s ease,
					background 0.15s ease,
					box-shadow 0.15s ease;
			}
			.site-nav-toggle:hover {
				border-color: color-mix(in srgb, var(--accent) 35%, var(--border));
				background: color-mix(in srgb, var(--accent) 6%, var(--surface));
			}
			.site-nav-toggle:focus-visible {
				outline: 2px solid var(--accent);
				outline-offset: 2px;
			}
			.site-nav-toggle__bars {
				display: flex;
				flex-direction: column;
				gap: 5px;
				width: 1.1rem;
			}
			.site-nav-toggle__bars span {
				display: block;
				height: 2px;
				border-radius: 1px;
				background: currentColor;
			}
			.site-nav-backdrop {
				display: none;
				position: fixed;
				inset: 0;
				z-index: 90100;
				background: rgba(15, 23, 42, 0.45);
				backdrop-filter: blur(2px);
				-webkit-backdrop-filter: blur(2px);
				opacity: 0;
				transition: opacity 0.22s ease;
				pointer-events: none;
			}
			.site-nav-backdrop.is-open {
				opacity: 1;
				pointer-events: auto;
			}
			.site-header__main {
				display: flex;
				flex-wrap: wrap;
				align-items: center;
				justify-content: flex-end;
				gap: 0.85rem 1.25rem;
				flex: 1 1 auto;
				min-width: 0;
			}
			.site-nav {
				display: flex;
				flex-wrap: wrap;
				align-items: center;
				gap: 0.35rem 0.5rem;
			}
			.site-nav a {
				color: var(--muted);
				font-size: 0.94rem;
				font-weight: 500;
				white-space: nowrap;
				padding: 0.45rem 0.85rem;
				border-radius: 999px;
				text-decoration: none;
			}
			.site-nav a:hover {
				color: var(--text);
				background: color-mix(in srgb, var(--accent) 8%, transparent);
				text-decoration: none;
			}
			.site-nav a[aria-current='page'] {
				color: var(--accent-dim);
				font-weight: 600;
				background: var(--accent-glow);
				text-decoration: none;
			}
			.site-header__tools {
				display: flex;
				flex-wrap: wrap;
				align-items: center;
				gap: 0.45rem;
				flex: 0 0 auto;
			}
			.site-dd {
				position: relative;
			}
			.site-dd__trigger {
				display: flex;
				align-items: center;
				justify-content: space-between;
				gap: 0.4rem;
				min-height: 2.5rem;
				padding: 0.35rem 0.75rem;
				margin: 0;
				list-style: none;
				cursor: pointer;
				font: inherit;
				font-size: 0.9rem;
				font-weight: 600;
				color: var(--text);
				background: var(--surface);
				border: 1px solid var(--border);
				border-radius: 999px;
				box-shadow: var(--shadow-sm);
				transition:
					border-color 0.15s ease,
					background 0.15s ease,
					color 0.15s ease,
					box-shadow 0.15s ease;
			}
			.site-dd__trigger::-webkit-details-marker {
				display: none;
			}
			.site-dd__trigger::marker {
				content: '';
			}
			.site-dd__trigger:hover {
				border-color: color-mix(in srgb, var(--accent) 35%, var(--border));
				background: color-mix(in srgb, var(--accent) 6%, var(--surface));
			}
			.site-dd[open] > .site-dd__trigger {
				border-color: color-mix(in srgb, var(--accent) 45%, var(--border));
				box-shadow: 0 0 0 3px var(--accent-glow);
			}
			.site-dd__trigger:focus-visible {
				outline: 2px solid var(--accent);
				outline-offset: 2px;
			}
			.site-dd__trigger-inner {
				display: inline-flex;
				align-items: center;
				gap: 0.4rem;
			}
			.site-dd__trigger--lang {
				padding-inline: 0.55rem 0.5rem;
			}
			.site-dd__lang-chip {
				display: inline-flex;
				align-items: center;
				gap: 0.35rem;
			}
			.site-dd__link .locale-flag {
				flex-shrink: 0;
			}
			.site-dd__lang-code {
				font-size: 0.78rem;
				font-weight: 700;
				letter-spacing: 0.06em;
				color: var(--muted);
			}
			.site-dd__trigger-text {
				max-width: 7rem;
				overflow: hidden;
				text-overflow: ellipsis;
				white-space: nowrap;
			}
			.site-dd__chev-svg {
				display: block;
				flex-shrink: 0;
				color: var(--muted);
				transition: transform 0.2s ease;
			}
			.site-dd[open] .site-dd__chev-svg {
				transform: rotate(180deg);
			}
			.site-dd__panel {
				position: absolute;
				top: calc(100% + 0.45rem);
				right: 0;
				min-width: min(16rem, calc(100vw - 2.5rem));
				padding: 0.4rem;
				margin: 0;
				background: var(--surface);
				border: 1px solid var(--border);
				border-radius: var(--radius-md);
				box-shadow: var(--shadow-lg);
				z-index: 90200;
			}
			.site-dd--lang .site-dd__panel {
				min-width: 12.5rem;
			}
			.site-dd__link {
				display: flex;
				align-items: center;
				gap: 0.55rem;
				padding: 0.55rem 0.85rem;
				border-radius: var(--radius-sm);
				color: var(--text) !important;
				font-size: 0.92rem;
				font-weight: 500;
				text-decoration: none !important;
			}
			.site-dd__link:hover {
				background: color-mix(in srgb, var(--accent) 10%, transparent);
			}
			.site-dd__link.is-current {
				background: var(--accent-glow);
				font-weight: 600;
				color: var(--accent-dim) !important;
			}
			.site-dd__user-icon {
				flex-shrink: 0;
				opacity: 0.85;
			}
			.site-dd__email {
				margin: 0;
				padding: 0.45rem 0.95rem 0.5rem;
				font-size: 0.8rem;
				line-height: 1.35;
				word-break: break-all;
				border-bottom: 1px solid var(--border);
			}
			.site-dd__form {
				margin: 0;
				padding: 0.35rem 0.5rem 0.45rem;
			}
			.site-dd__btn-logout {
				display: block;
				width: 100%;
				margin: 0;
				padding: 0.55rem 0.75rem;
				font: inherit;
				font-size: 0.9rem;
				font-weight: 600;
				text-align: center;
				color: var(--danger);
				background: color-mix(in srgb, var(--danger) 8%, transparent);
				border: 1px solid color-mix(in srgb, var(--danger) 22%, transparent);
				border-radius: var(--radius-sm);
				cursor: pointer;
				transition:
					background 0.15s ease,
					border-color 0.15s ease;
			}
			.site-dd__btn-logout:hover {
				background: color-mix(in srgb, var(--danger) 14%, transparent);
				border-color: color-mix(in srgb, var(--danger) 38%, transparent);
			}
			@media (max-width: 768px) {
				.site__inner {
					flex-direction: row;
					flex-wrap: nowrap;
					align-items: center;
					gap: 0.65rem 0.75rem;
				}
				.brand {
					text-align: left;
					flex: 1 1 0;
					min-width: 0;
					font-size: clamp(0.72rem, 2.4vw, 0.98rem);
				}
				.brand__logo {
					width: 2.05rem;
					height: 2.05rem;
					border-radius: 9px;
				}
				.site-nav-toggle {
					display: inline-flex;
				}
				.site-nav-backdrop {
					display: block;
				}
				.site-header__main {
					flex-direction: row;
					flex-wrap: nowrap;
					align-items: center;
					justify-content: flex-end;
					gap: 0.45rem 0.5rem;
					flex: 0 0 auto;
				}
				.site-nav {
					position: fixed;
					top: 0;
					left: 0;
					right: auto;
					width: min(300px, 86vw);
					min-height: 100vh;
					min-height: 100dvh;
					height: 100vh;
					height: 100dvh;
					max-height: none;
					margin: 0;
					padding: 5.25rem 1rem 1.5rem;
					box-sizing: border-box;
					flex-direction: column;
					flex-wrap: nowrap;
					align-items: stretch;
					justify-content: flex-start;
					gap: 0.35rem;
					background: var(--surface);
					border-right: 1px solid var(--border);
					box-shadow: var(--shadow-lg);
					z-index: 90300;
					transform: translateX(-100%);
					transition: transform 0.26s ease;
					overflow-y: auto;
					-webkit-overflow-scrolling: touch;
				}
				.site-nav.is-open {
					transform: translateX(0);
				}
				.site-nav a {
					white-space: normal;
					text-align: left;
					border-radius: var(--radius-sm);
				}
				.site-header__tools {
					justify-content: flex-end;
					padding-top: 0;
					border-top: none;
					flex-shrink: 0;
				}
				.site-dd__panel {
					left: auto;
					right: 0;
					transform: none;
				}
				/* Drawer/backdrop are portaled to <body> on mobile; keep bar above dimmer when open */
				html.tg-site-nav-open header.site {
					z-index: 90450;
				}
				/* Portaled nodes: explicit z-index vs in-page fixed/stacked UI (still below .tdh-lb) */
				body > .site-nav-backdrop {
					z-index: 90355;
				}
				body > #site-primary-nav.site-nav {
					z-index: 90400;
				}
				#site-nav-toggle {
					touch-action: manipulation;
					-webkit-tap-highlight-color: transparent;
				}
			}
			.card-grid {
				display: grid;
				gap: 1.35rem;
				grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
			}
			.card {
				background: var(--surface);
				border: 1px solid var(--border);
				border-radius: var(--radius-lg);
				padding: 1.35rem;
				display: flex;
				flex-direction: column;
				gap: 0.85rem;
				box-shadow: var(--shadow-md);
				transition:
					box-shadow 0.2s ease,
					border-color 0.2s ease,
					transform 0.2s ease;
			}
			.card:hover {
				box-shadow: var(--shadow-lg);
				border-color: color-mix(in srgb, var(--accent) 22%, var(--border));
			}
			.card h2 {
				margin: 0;
				font-size: 1.12rem;
				font-weight: 700;
				letter-spacing: -0.02em;
			}
			.muted {
				color: var(--muted);
				font-size: 0.92rem;
			}
			.btn {
				display: inline-flex;
				align-items: center;
				justify-content: center;
				padding: 0.62rem 1.2rem;
				background: linear-gradient(165deg, var(--accent) 0%, var(--accent-dim) 100%);
				color: var(--btn-text) !important;
				border-radius: 999px;
				font-weight: 600;
				font-size: 0.9rem;
				border: none;
				cursor: pointer;
				text-decoration: none !important;
				box-shadow: 0 2px 12px color-mix(in srgb, var(--accent) 35%, transparent);
				transition:
					transform 0.15s ease,
					box-shadow 0.15s ease,
					filter 0.15s ease;
			}
			.btn:hover {
				filter: brightness(1.05);
				transform: translateY(-1px);
				box-shadow: 0 6px 20px color-mix(in srgb, var(--accent) 42%, transparent);
			}
			.btn-ghost {
				background: var(--surface);
				color: var(--accent-dim) !important;
				border: 1px solid var(--border);
				box-shadow: var(--shadow-sm);
			}
			.btn-ghost:hover {
				background: color-mix(in srgb, var(--accent) 6%, var(--surface));
				border-color: color-mix(in srgb, var(--accent) 35%, var(--border));
			}
			form.auth {
				max-width: 360px;
				display: flex;
				flex-direction: column;
				gap: 1rem;
			}
			label span {
				display: block;
				font-size: 0.85rem;
				color: var(--muted);
				margin-bottom: 0.25rem;
			}
			input {
				width: 100%;
				padding: 0.62rem 0.85rem;
				border-radius: var(--radius-sm);
				border: 1px solid var(--border);
				background: var(--surface);
				color: var(--text);
				font: inherit;
				transition:
					border-color 0.15s ease,
					box-shadow 0.15s ease;
			}
			input:focus {
				outline: none;
				border-color: color-mix(in srgb, var(--accent) 55%, var(--border));
				box-shadow: 0 0 0 3px var(--accent-glow);
			}
			.alert {
				padding: 0.75rem 1rem;
				border-radius: var(--radius-sm);
				background: color-mix(in srgb, var(--danger) 10%, var(--surface));
				color: var(--danger);
				font-size: 0.9rem;
				font-weight: 500;
				border: 1px solid color-mix(in srgb, var(--danger) 22%, transparent);
			}
			.hero {
				margin-bottom: 2.75rem;
			}
			.hero h1 {
				font-size: clamp(1.85rem, 4.2vw, 2.5rem);
				margin: 0 0 0.85rem;
				line-height: 1.18;
				letter-spacing: -0.03em;
				font-weight: 700;
			}
			.prose {
				max-width: min(72ch, 100%);
			}
			.prose :where(h2, h3) {
				margin-top: 1.5rem;
			}
			.prose :where(p) {
				margin: 0.75rem 0;
			}
			.prose :where(ul, ol) {
				margin: 0.75rem 0;
				padding-left: 1.35rem;
			}
			.prose :where(li) {
				margin: 0.25rem 0;
			}
			.prose :where(a) {
				color: var(--accent);
			}
			.prose :where(strong) {
				color: var(--text);
			}
			.site-footer {
				margin-top: 3.5rem;
				padding-top: 2rem;
				border-top: 1px solid var(--border);
				display: flex;
				flex-wrap: wrap;
				align-items: center;
				gap: 1rem 1.5rem;
			}
			.site-footer--links {
				justify-content: space-between;
			}
			.site-footer:not(.site-footer--links) {
				justify-content: flex-end;
			}
			.site-footer nav {
				display: flex;
				flex-wrap: wrap;
				gap: 0.75rem 1.25rem;
			}
			.site-footer nav a {
				font-size: 0.9rem;
				color: var(--muted);
			}
			.site-footer nav a:hover {
				color: var(--accent);
			}
			.site-footer__blurb {
				width: 100%;
				font-size: 0.9rem;
				color: var(--muted);
				line-height: 1.55;
			}
			.site-footer__blurb :where(p) {
				margin: 0.35rem 0;
			}
			.site-footer__blurb :where(a) {
				color: var(--accent);
			}
			.site-footer--links .site-footer__blurb {
				margin-bottom: 0.25rem;
			}
			.site-footer__meta {
				margin: 0;
				font-size: 0.85rem;
				color: var(--muted);
			}
		</style>
	</head>
	<body>
		<header class="site">
			<div class="site__glass-bg" aria-hidden="true"></div>
			<div class="site__inner">
				<div class="brand">
					<a class="brand__link" href={getRelativeLocaleUrl(locale, '/')}>
						<img
							class="brand__logo"
							src="/logo.svg"
							width="38"
							height="38"
							alt=""
							decoding="async"
							fetchpriority="high"
						/>
						<span class="brand__text" lang="en" translate="no">TRAVELGEORGIA.GE</span>
					</a>
				</div>
				<div class="site-header__main" id="site-header-main">
					<button
						type="button"
						class="site-nav-toggle"
						id="site-nav-toggle"
						aria-expanded="false"
						aria-controls="site-primary-nav"
						aria-label={t.navMainMenu}
					>
						<span class="site-nav-toggle__bars" aria-hidden="true">
							<span></span>
							<span></span>
							<span></span>
						</span>
					</button>
					<div class="site-nav-backdrop" id="site-nav-backdrop" hidden aria-hidden="true"></div>
					<nav class="site-nav" id="site-primary-nav" aria-label="Main">
						<a href={getRelativeLocaleUrl(locale, '/')} aria-current={subpath === '' ? 'page' : undefined}>{t.home}</a>
						<a
							href={getRelativeLocaleUrl(locale, 'tours')}
							aria-current={subpath.startsWith('tours') ? 'page' : undefined}>{t.tours}</a>
						<a
							href={getRelativeLocaleUrl(locale, 'what-to-do')}
							aria-current={subpath.startsWith('what-to-do') ? 'page' : undefined}>{t.whatToDo}</a>
						<a
							href={getRelativeLocaleUrl(locale, 'map')}
							aria-current={subpath === 'map' ? 'page' : undefined}>{t.map}</a>
					</nav>
					<div class="site-header__tools">
						<details class="site-dd site-dd--lang">
							<summary class="site-dd__trigger site-dd__trigger--lang" aria-label={t.navLanguage}>
								<span class="site-dd__lang-chip">
									<LocaleFlag locale={locale} />
									<span class="site-dd__lang-code">{locale.toUpperCase()}</span>
								</span>
								<svg
									class="site-dd__chev-svg"
									width="12"
									height="12"
									viewBox="0 0 12 12"
									aria-hidden="true"
								>
									<path
										fill="none"
										stroke="currentColor"
										stroke-width="1.75"
										stroke-linecap="round"
										stroke-linejoin="round"
										d="M2.5 4.25 6 7.75 9.5 4.25"
									/>
								</svg>
							</summary>
							<div class="site-dd__panel" role="group" aria-label={t.navLanguage}>
								{
									locales.map((loc) => (
										<a
											class:list={['site-dd__link', { 'is-current': loc === locale }]}
											href={getRelativeLocaleUrl(loc, subpath || '/')}
											aria-current={loc === locale ? 'page' : undefined}
										>
											<LocaleFlag locale={loc} />
											<span>{localeNames[loc]}</span>
										</a>
									))
								}
							</div>
						</details>
						<details class="site-dd site-dd--account">
							<summary class="site-dd__trigger" aria-label={t.navAccount}>
								<span class="site-dd__trigger-inner">
									<svg
										class="site-dd__user-icon"
										width="18"
										height="18"
										viewBox="0 0 24 24"
										aria-hidden="true"
									>
										<path
											fill="currentColor"
											d="M12 12c2.21 0 4-1.79 4-4s-1.79-4-4-4-4 1.79-4 4 1.79 4 4 4zm0 2c-2.67 0-8 1.34-8 4v2h16v-2c0-2.66-5.33-4-8-4z"
										/>
									</svg>
									<span class="site-dd__trigger-text">{t.navAccount}</span>
									<svg
										class="site-dd__chev-svg"
										width="12"
										height="12"
										viewBox="0 0 12 12"
										aria-hidden="true"
									>
										<path
											fill="none"
											stroke="currentColor"
											stroke-width="1.75"
											stroke-linecap="round"
											stroke-linejoin="round"
											d="M2.5 4.25 6 7.75 9.5 4.25"
										/>
									</svg>
								</span>
							</summary>
							<div class="site-dd__panel" role="group" aria-label={t.navAccount}>
								{
									user ? (
										<>
											<p class="site-dd__email muted">{user.email}</p>
											<a class="site-dd__link" href={getRelativeLocaleUrl(locale, 'contribute')}>
												{t.contribute}
											</a>
											{
												user.role === 'admin' ? (
													<a class="site-dd__link" href={getRelativeLocaleUrl(locale, 'admin')}>
														{t.admin}
													</a>
												) : null
											}
											<form class="site-dd__form" method="post" action="/api/auth/logout">
												<button class="site-dd__btn-logout" type="submit">{t.logout}</button>
											</form>
										</>
									) : (
										<>
											<a class="site-dd__link" href={getRelativeLocaleUrl(locale, 'login')}>{t.login}</a>
											<a class="site-dd__link" href={getRelativeLocaleUrl(locale, 'register')}>{t.register}</a>
										</>
									)
								}
							</div>
						</details>
					</div>
				</div>
			</div>
		</header>
		<div class="wrap">
			<slot />
			<SiteFooter locale={locale} />
		</div>
		<script is:inline>
			(function () {
				function qs(id) {
					return document.getElementById(id);
				}

				function isMobileNav() {
					return window.matchMedia('(max-width: 768px)').matches;
				}

				/**
				 * Fixed + sticky ancestors are inconsistent across browsers/pages.
				 * On mobile, attach drawer + dimmer to <body> so they always cover the viewport.
				 */
				function syncMobileNavPortal() {
					var backdrop = qs('site-nav-backdrop');
					var nav = qs('site-primary-nav');
					var host = qs('site-header-main');
					var tools = host && host.querySelector('.site-header__tools');
					if (!backdrop || !nav || !host || !tools) return;
					if (isMobileNav()) {
						if (backdrop.parentNode !== document.body) {
							document.body.appendChild(backdrop);
							document.body.appendChild(nav);
						}
					} else if (backdrop.parentNode === document.body) {
						host.insertBefore(backdrop, tools);
						host.insertBefore(nav, tools);
					}
				}

				function openNav(nav, backdrop, btn) {
					document.documentElement.classList.add('tg-site-nav-open');
					nav.classList.add('is-open');
					backdrop.classList.add('is-open');
					backdrop.removeAttribute('hidden');
					backdrop.setAttribute('aria-hidden', 'false');
					btn.setAttribute('aria-expanded', 'true');
					document.body.style.overflow = 'hidden';
					var first = nav.querySelector('a');
					if (first) first.focus();
				}

				function closeNav(nav, backdrop, btn) {
					document.documentElement.classList.remove('tg-site-nav-open');
					nav.classList.remove('is-open');
					backdrop.classList.remove('is-open');
					backdrop.setAttribute('hidden', '');
					backdrop.setAttribute('aria-hidden', 'true');
					btn.setAttribute('aria-expanded', 'false');
					document.body.style.overflow = '';
					try {
						btn.focus();
					} catch (e) {}
				}

				function bindNav() {
					function navParts() {
						return {
							nav: qs('site-primary-nav'),
							backdrop: qs('site-nav-backdrop'),
							btn: qs('site-nav-toggle'),
						};
					}

					/* Direct binding: document-level capture can lose to other listeners on heavy pages */
					function bindToggle() {
						var btn = qs('site-nav-toggle');
						if (!btn || btn.dataset.tgNavToggleBound === '1') return;
						btn.dataset.tgNavToggleBound = '1';

						function onToggle(e) {
							if (!isMobileNav()) return;
							var p = navParts();
							if (!p.nav || !p.backdrop || !p.btn) return;
							e.preventDefault();
							e.stopPropagation();
							if (p.nav.classList.contains('is-open')) {
								closeNav(p.nav, p.backdrop, p.btn);
							} else {
								openNav(p.nav, p.backdrop, p.btn);
							}
						}

						btn.addEventListener('click', onToggle, true);
					}

					bindToggle();

					document.addEventListener(
						'click',
						function (e) {
							var t = e.target;
							if (!t || !t.closest) return;
							if (t.closest('#site-nav-toggle')) return;

							var p = navParts();
							if (!p.nav || !p.backdrop || !p.btn) return;
							if (!isMobileNav()) return;
							if (!p.nav.classList.contains('is-open')) return;

							if (e.target === p.backdrop || p.backdrop.contains(e.target)) {
								closeNav(p.nav, p.backdrop, p.btn);
								return;
							}

							var navLink = t.closest('#site-primary-nav a');
							if (navLink) {
								closeNav(p.nav, p.backdrop, p.btn);
							}
						},
						true,
					);

					document.addEventListener('keydown', function (e) {
						if (e.key !== 'Escape') return;
						var p = navParts();
						if (!p.nav || !p.backdrop || !p.btn || !p.nav.classList.contains('is-open')) return;
						closeNav(p.nav, p.backdrop, p.btn);
					});

					function onViewportChange() {
						syncMobileNavPortal();
						if (isMobileNav()) return;
						var p = navParts();
						if (!p.nav || !p.backdrop || !p.btn || !p.nav.classList.contains('is-open')) return;
						closeNav(p.nav, p.backdrop, p.btn);
					}

					window.addEventListener('resize', onViewportChange, { passive: true });
					window.addEventListener('orientationchange', onViewportChange, { passive: true });
					window.addEventListener('pageshow', function () {
						syncMobileNavPortal();
					});

					try {
						var mm = window.matchMedia('(max-width: 768px)');
						function onMq() {
							onViewportChange();
						}
						if (mm.addEventListener) {
							mm.addEventListener('change', onMq);
						} else if (mm.addListener) {
							mm.addListener(onMq);
						}
					} catch (err) {}
				}

				function boot() {
					syncMobileNavPortal();
					if (!window.__tgSiteNavInit) {
						window.__tgSiteNavInit = true;
						bindNav();
					}
					requestAnimationFrame(function () {
						syncMobileNavPortal();
						requestAnimationFrame(syncMobileNavPortal);
					});
				}

				if (document.readyState === 'loading') {
					document.addEventListener('DOMContentLoaded', boot, { once: true });
				} else {
					boot();
				}
			})();
		</script>
	</body>
</html>
