---
import Shell from './Shell.astro';
import TourComments from './TourComments.astro';
import { getRelativeLocaleUrl } from 'astro:i18n';
import { marked } from 'marked';
import type { UserPublic } from '../lib/auth';
import {
	getSlotsForPackage,
	listSimilarPublishedPackages,
	type GuidePackage,
} from '../lib/guide-packages-db';
import { getGuideById } from '../lib/guides-db';
import { averageRatingFor, listCommentsForPost } from '../lib/tour-comments';
import { tourCoverImageUrl } from '../lib/tours-db';
import type { Locale } from '../lib/strings';
import { ui } from '../lib/strings';

interface Props {
	locale: Locale;
	pkg: GuidePackage;
	/** Full path e.g. `/en/tours/my-tour` for canonical + SEO */
	canonicalPath: string;
	user?: UserPublic;
}

const { locale, pkg, canonicalPath, user } = Astro.props;
const t = ui[locale];

const block = pkg.i18n[locale] ?? pkg.i18n['en'] ?? pkg.i18n['ka'] ?? pkg.i18n['ru'];
if (!block?.title) {
	throw new Error('GuidePackageDetail: package has no title for this locale');
}

const guide = getGuideById(pkg.guide_id);
const guideName = guide?.i18n[locale]?.name ?? guide?.i18n['en']?.name ?? 'Guide';
const guideSlug = guide?.slug;

const descHtmlRaw = block.description ? marked.parse(block.description, { async: false }) : '';
const descHtml = typeof descHtmlRaw === 'string' ? descHtmlRaw : await descHtmlRaw;

const bodyMd = block.body?.trim();
const bodyHtmlRaw = bodyMd ? marked.parse(bodyMd, { async: false }) : '';
const bodyHtml = typeof bodyHtmlRaw === 'string' ? bodyHtmlRaw : await bodyHtmlRaw;

function mdToHtml(md: string): string {
	const raw = marked.parse(md || '', { async: false });
	return typeof raw === 'string' ? raw : '';
}

const itineraryDays = block.itinerary_days ?? [];
const kindLabel: Record<string, string> = {
	start: 'Start',
	stop: 'Stop',
	optional: 'Optional',
	end: 'End',
};

const similarPkgs = listSimilarPublishedPackages(locale, pkg.slug, pkg.category, 4);
const pkgComments = await listCommentsForPost('packages', pkg.id);
const pkgAvg = averageRatingFor(pkgComments);
const tourReviewsLoginHref = `${getRelativeLocaleUrl(locale, 'login')}?${new URLSearchParams({ next: `/${locale}/tours/${pkg.slug}` }).toString()}`;

// Future open slots
const today = new Date().toISOString().slice(0, 10);
const slots = getSlotsForPackage(pkg.id)
	.filter((s) => s.status === 'open' && s.date >= today && s.booked_count < s.capacity)
	.sort((a, b) => (a.date < b.date ? -1 : 1));

const slotsMapJson = JSON.stringify(
	Object.fromEntries(slots.map((s) => [s.date, s]))
).replace(/</g, '\\u003c');

// Active tiers for private tours
const enabledTiers = pkg.tour_style === 'private'
	? pkg.private_tiers.filter((t) => t.price > 0)
	: [];

const pkgJson = JSON.stringify({
	id: pkg.id,
	tour_style: pkg.tour_style,
	base_price: pkg.base_price,
	currency: pkg.currency,
	min_people: pkg.min_people,
	max_people: pkg.max_people,
	pricing_rules: pkg.pricing_rules,
	private_tiers: enabledTiers,
}).replace(/</g, '\\u003c');

const metaDesc = block.seo_description?.trim() || block.description?.slice(0, 155) || `Book ${block.title} with ${guideName}`;
const guideHref = guideSlug ? getRelativeLocaleUrl(locale, `guides/${guideSlug}`) : null;

const currencySymbol: Record<string, string> = { USD: '$', EUR: '€', GEL: '₾' };
const sym = currencySymbol[pkg.currency] ?? pkg.currency;

// Transport badge
const vehicleLabel: Record<string, string> = {
	sedan: '🚗 Sedan', suv: '🚙 SUV', minivan: '🚐 Minivan',
	minibus: '🚌 Minibus', bus: '🚌 Coach Bus', boat: '⛵ Boat', other: '🚗 Vehicle',
};

// Difficulty
const diffLabel: Record<string, string> = { easy: '🟢 Easy', moderate: '🟡 Moderate', challenging: '🔴 Challenging' };

// Price summary for header (private = lowest tier; group = base_price)
const lowestTierPrice = enabledTiers.length ? Math.min(...enabledTiers.map((t) => t.price)) : null;
---

<Shell
	locale={locale}
	subpath={`tours/${pkg.slug}`}
	title={block.title}
	seoTitle={block.seo_title ?? block.title}
	seoDescription={metaDesc}
	canonicalPath={canonicalPath}
	seoImage={pkg.cover_photo ?? null}
	ogType="article"
>
	<p class="muted" style="margin:0 0 1rem">
		<a href={getRelativeLocaleUrl(locale, 'tours')}>{t.tours}</a>
		<span aria-hidden="true"> / </span>
		<span>{block.title}</span>
	</p>
	<article class="pkg-detail">
		{pkg.cover_photo && (
			<div class="pkg-hero">
				<img src={pkg.cover_photo} alt={block.title} class="pkg-hero__img" />
			</div>
		)}

		{pkg.gallery && pkg.gallery.length > 0 && (
			<div class="pkg-gallery-strip" aria-label="Tour gallery">
				{pkg.gallery.map((src) => (
					<button type="button" class="pkg-gallery-thumb-btn" data-full-src={src}>
						<img src={src} alt="" class="pkg-gallery-thumb" loading="lazy" decoding="async" width="200" height="120" />
					</button>
				))}
			</div>
		)}

		<div class="pkg-body">
			<!-- ── Left: details ── -->
			<div class="pkg-content">
				<h1 class="pkg-title">{block.title}</h1>

				{guideHref && (
					<p class="pkg-guide-by">
						by <a href={guideHref}>{guideName}</a>
					</p>
				)}

				<!-- Meta row -->
				<div class="pkg-meta-row">
					<span class={`pkg-meta-badge ${pkg.tour_style === 'private' ? 'pkg-meta-badge--private' : 'pkg-meta-badge--group'}`}>
						{pkg.tour_style === 'private' ? '🔒 Private Tour' : '👥 Group Tour'}
					</span>
					<span class="pkg-meta-item">⏱ {pkg.duration_label ?? `${pkg.duration_hours}h`}</span>
					{pkg.tour_style === 'group' && (
						<span class="pkg-meta-item">👤 {pkg.min_people}–{pkg.max_people} people</span>
					)}
					{pkg.languages.length > 0 && (
						<span class="pkg-meta-item">🌐 {pkg.languages.join(', ')}</span>
					)}
					{pkg.difficulty && (
						<span class="pkg-meta-item">{diffLabel[pkg.difficulty]}</span>
					)}
					{pkg.min_age && (
						<span class="pkg-meta-item">🔞 Ages {pkg.min_age}+</span>
					)}
				</div>

				<!-- Transport & pickup badges -->
				{(pkg.transport_included || pkg.pickup_offered) && (
					<div class="pkg-logistics-badges">
						{pkg.transport_included && (
							<span class="logistics-badge logistics-badge--transport">
								{pkg.transport_type ? vehicleLabel[pkg.transport_type] : '🚗 Transport'} included
								{pkg.tour_style !== 'private' && pkg.transport_notes && (
									<> — <em>{pkg.transport_notes}</em></>
								)}
							</span>
						)}
						{pkg.pickup_offered && (
							<span class="logistics-badge logistics-badge--pickup">
								📍 Pickup available
								{pkg.pickup_notes && <> — <em>{pkg.pickup_notes}</em></>}
							</span>
						)}
					</div>
				)}

				{descHtml && (
					<div class="pkg-desc prose" set:html={descHtml} />
				)}

				{itineraryDays.length > 0 && (
					<section class="pkg-section pkg-itinerary" aria-labelledby="pkg-itin-heading">
						<h2 id="pkg-itin-heading" class="pkg-section__h">Itinerary</h2>
						{itineraryDays.map((day) => (
							<div class="pkg-itin-day">
								{itineraryDays.length > 1 && (
									<h3 class="pkg-itin-day__h">
										Day {day.day_index}
										{day.title && <span class="pkg-itin-day__title"> — {day.title}</span>}
									</h3>
								)}
								{itineraryDays.length === 1 && day.title && (
									<p class="pkg-itin-day__subtitle">{day.title}</p>
								)}
								<ol class="pkg-itin-timeline">
									{day.stops.map((stop) => (
										<li class={`pkg-itin-stop pkg-itin-stop--${stop.kind}`}>
											<div class="pkg-itin-stop__marker" aria-hidden="true">
												{stop.kind === 'start' && 'S'}
												{stop.kind === 'end' && 'E'}
												{stop.kind === 'stop' && '●'}
												{stop.kind === 'optional' && '★'}
											</div>
											<div class="pkg-itin-stop__body">
												<div class="pkg-itin-stop__meta">
													<span class="pkg-itin-stop__kind">{kindLabel[stop.kind] ?? stop.kind}</span>
													{stop.timing_note && (
														<span class="pkg-itin-stop__timing">{stop.timing_note}</span>
													)}
												</div>
												<h4 class="pkg-itin-stop__title">{stop.title}</h4>
												{stop.body?.trim() && (
													<div class="pkg-itin-stop__text prose" set:html={mdToHtml(stop.body)} />
												)}
											</div>
										</li>
									))}
								</ol>
							</div>
						))}
					</section>
				)}

				{bodyHtml && (
					<div class="pkg-section prose" set:html={bodyHtml} />
				)}

				{block.includes_text && (
					<div class="pkg-section">
						<h2 class="pkg-section__h">What's included</h2>
						<ul class="pkg-list pkg-list--included">
							{block.includes_text.split('\n').filter(Boolean).map((item) => (
								<li>✓ {item.replace(/^[-*•]\s*/, '')}</li>
							))}
						</ul>
					</div>
				)}

				{block.excludes_text && (
					<div class="pkg-section">
						<h2 class="pkg-section__h">Not included</h2>
						<ul class="pkg-list pkg-list--excluded">
							{block.excludes_text.split('\n').filter(Boolean).map((item) => (
								<li>✗ {item.replace(/^[-*•]\s*/, '')}</li>
							))}
						</ul>
					</div>
				)}

				<!-- Private tour pricing table -->
				{pkg.tour_style === 'private' && enabledTiers.length > 0 && (
					<div class="pkg-section">
						<h2 class="pkg-section__h">Pricing by Group Size</h2>
						<div class="private-pricing-table">
							{enabledTiers.map((tier) => (
								<div class="private-pricing-row">
									<div class="private-pricing-row__label">
										<strong>{tier.label}</strong>
										<span class="private-pricing-row__range">
											{tier.min_pax}–{tier.max_pax} people
											{tier.vehicle_type && (
												<span class="private-pricing-row__veh"> · {vehicleLabel[tier.vehicle_type]}</span>
											)}
										</span>
										{tier.transport_notes && (
											<span class="private-pricing-row__notes">{tier.transport_notes}</span>
										)}
									</div>
									<div class="private-pricing-row__price">
										{sym}{tier.price.toFixed(2)}
										<span class="private-pricing-row__unit"> total</span>
									</div>
								</div>
							))}
						</div>
						{pkg.pricing_rules.length > 0 && (
							<p class="muted" style="font-size:0.85rem;margin-top:0.5rem">Early bird & seasonal discounts may apply at checkout.</p>
						)}
					</div>
				)}

				{pkg.tour_style === 'group' && pkg.pricing_rules.length > 0 && (
					<div class="pkg-section">
						<h2 class="pkg-section__h">Discounts</h2>
						<ul class="pkg-list">
							{pkg.pricing_rules.map((rule) => {
								let desc = rule.label ?? '';
								if (rule.kind === 'group') {
									const min = rule.min_pax ?? 2;
									const max = rule.max_pax;
									desc = desc || `Group of ${min}${max ? '–' + max : '+'}`;
								} else if (rule.kind === 'early_bird') {
									desc = desc || `Book ${rule.days_before}+ days in advance`;
								} else if (rule.kind === 'seasonal') {
									desc = desc || `${rule.date_from} – ${rule.date_to}`;
								}
								return <li><strong>{rule.discount_pct}% off</strong> — {desc}</li>;
							})}
						</ul>
					</div>
				)}

				{block.meeting_point_text && (
					<div class="pkg-section">
						<h2 class="pkg-section__h">Meeting point</h2>
						<p>📍 {block.meeting_point_text}</p>
					</div>
				)}

				{pkg.cancellation_policy && (
					<div class="pkg-section">
						<h2 class="pkg-section__h">Cancellation policy</h2>
						<p class="muted">{pkg.cancellation_policy}</p>
					</div>
				)}
			</div>

			<!-- ── Right: booking card ── -->
			<div class="pkg-sidebar">
				{(pkg.category || pkg.physical_rating || pkg.driving_distance) && (
					<div class="pkg-glance-card">
						<h2 class="pkg-glance-card__h">{t.tourSidebarSectionTitle}</h2>
						<dl class="pkg-glance-card__dl">
							{pkg.category && (
								<div class="pkg-glance-card__row">
									<dt>{t.tourSidebarCategory}</dt>
									<dd>{t.tourCategories[pkg.category]}</dd>
								</div>
							)}
							{pkg.physical_rating && (
								<div class="pkg-glance-card__row">
									<dt>{t.tourSidebarPhysicalRating}</dt>
									<dd>{t.tourPhysicalRatings[pkg.physical_rating]}</dd>
								</div>
							)}
							{pkg.driving_distance && (
								<div class="pkg-glance-card__row">
									<dt>{t.tourSidebarDrivingDistance}</dt>
									<dd>{pkg.driving_distance}</dd>
								</div>
							)}
						</dl>
					</div>
				)}
				<div class="pkg-booking-card" id="booking-card">

					<!-- Price header -->
					<div class="pkg-price-row" id="price-header-row">
						{pkg.tour_style === 'private' ? (
							<>
								<span class="pkg-price-amount" id="price-header-orig">
									{lowestTierPrice ? `${sym}${lowestTierPrice.toFixed(2)}` : 'Select tier'}
								</span>
								<span class="pkg-price-label" id="price-header-label"> {lowestTierPrice ? '/ group' : ''}</span>
								<span class="pkg-price-amount pkg-price-discounted" id="price-header-discounted" style="display:none"></span>
								<span class="pkg-discount-badge" id="price-header-badge" style="display:none"></span>
							</>
						) : (
							<>
								<span class="pkg-price-amount" id="price-header-orig">{sym}{pkg.base_price}</span>
								<span class="pkg-price-amount pkg-price-discounted" id="price-header-discounted" style="display:none"></span>
								<span class="pkg-price-label" id="price-header-label"> / person</span>
								<span class="pkg-discount-badge" id="price-header-badge" style="display:none"></span>
							</>
						)}
					</div>

					{slots.length === 0 ? (
						<div class="notice notice-info" style="font-size:0.9rem">
							No available dates at the moment. Check back soon or contact the guide directly.
						</div>
					) : (
						<form id="booking-form" novalidate>
							<!-- Date selector (shared) -->
							<div class="form-row">
								<label for="book-date">Select date</label>
								<select id="book-date" name="date" required>
									<option value="">— Choose a date —</option>
									{slots.map((s) => (
										<option value={s.date}>
											{s.date}{s.time_start ? ` at ${s.time_start}` : ''}
										</option>
									))}
								</select>
							</div>

							{/* ── PRIVATE: tier selector ── */}
							{pkg.tour_style === 'private' && (
								<div id="tier-selector-section" class="form-row">
									<label>Select group size</label>
									<div id="tier-cards" class="tier-cards">
										{enabledTiers.map((tier) => (
											<button
												type="button"
												class="tier-card"
												data-tier-id={tier.id}
												data-tier-price={tier.price}
												data-tier-min={tier.min_pax}
												data-tier-max={tier.max_pax}
												data-tier-label={tier.label}
											>
												<span class="tier-card__main">
													<span class="tier-card__label">{tier.label}</span>
													<span class="tier-card__range">{tier.min_pax}–{tier.max_pax} people</span>
													{tier.vehicle_type && (
														<span class="tier-card__vehicle">{vehicleLabel[tier.vehicle_type]}</span>
													)}
													{tier.transport_notes && (
														<span class="tier-card__transport-notes">{tier.transport_notes}</span>
													)}
												</span>
												<span class="tier-card__price">{sym}{tier.price.toFixed(2)}</span>
											</button>
										))}
									</div>
									<input type="hidden" id="book-tier-id" name="tier_id" />
								</div>
							)}

							{/* ── PRIVATE: exact headcount (shows after tier selected) ── */}
							{pkg.tour_style === 'private' && (
								<div class="form-row" id="private-pax-row" style="display:none">
									<label for="book-pax">Exact number of people <span class="form-hint-inline" id="pax-range-hint"></span></label>
									<input type="number" id="book-pax" name="pax" min="1" max="30" value="1" required />
									<p class="form-hint">For planning — exact headcount within your tier.</p>
								</div>
							)}

							{/* ── GROUP: per-person pax input ── */}
							{pkg.tour_style === 'group' && (
								<div class="form-row">
									<label for="book-pax">Number of people</label>
									<input type="number" id="book-pax" name="pax" min={pkg.min_people} max={pkg.max_people} value={pkg.min_people} required />
									<p class="form-hint">{pkg.min_people}–{pkg.max_people} people</p>
								</div>
							)}

							<!-- Price breakdown (shared) -->
							<div id="price-breakdown" class="price-breakdown" style="display:none">
								<div class="price-row">
									<span id="price-unit-label"></span>
									<span id="price-unit-val"></span>
								</div>
								<div class="price-row price-row--discount" id="price-discount-row" style="display:none">
									<span id="price-discount-label"></span>
									<span id="price-discount-val"></span>
								</div>
								<div class="price-row price-row--total">
									<span>Total</span>
									<span id="price-total-val"></span>
								</div>
							</div>

							<!-- Contact details -->
							<div class="form-row">
								<label for="book-name">Your name</label>
								<input type="text" id="book-name" name="customer_name" required placeholder="Full name" />
							</div>
							<div class="form-row">
								<label for="book-email">Email</label>
								<input type="email" id="book-email" name="customer_email" required placeholder="your@email.com" />
							</div>
							<div class="form-row">
								<label for="book-phone">Phone (optional)</label>
								<input type="tel" id="book-phone" name="customer_phone" placeholder="+995 …" />
							</div>
							<div class="form-row">
								<label for="book-requests">Special requests (optional)</label>
								<textarea id="book-requests" name="special_requests" rows="3" placeholder="Dietary needs, accessibility, questions…"></textarea>
							</div>

							<div id="booking-error" class="notice notice-error" style="display:none"></div>

							<button type="submit" class="button button--primary booking-btn" id="book-submit-btn" style="width:100%;margin-top:0.5rem">
								Request Booking
							</button>
							<p style="font-size:0.8rem;color:#64748b;text-align:center;margin-top:0.5rem">
								{pkg.tour_style === 'private' ? 'Your private tour will be confirmed by the guide.' : 'Free cancellation if the guide cannot confirm.'}
							</p>
						</form>
					)}

					<div id="booking-success" style="display:none;text-align:center;padding:1.5rem 0">
						<div style="font-size:2rem;margin-bottom:0.5rem">🎉</div>
						<h3 style="margin:0 0 0.5rem">Booking request sent!</h3>
						<p class="muted" id="booking-success-ref"></p>
						<p class="muted" style="font-size:0.875rem">Check your email for confirmation. The guide will confirm shortly.</p>
					</div>
				</div>
			</div>
		</div>
	</article>

	{
		similarPkgs.length > 0 ? (
			<section class="similar-tours" data-similar-tours aria-labelledby="similar-pkg-heading">
				<h2 id="similar-pkg-heading" class="similar-tours__heading">
					{t.similarTours}
				</h2>
				<div class="similar-tours__grid">
					{similarPkgs.map((sp) => {
						const sb = sp.i18n[locale] ?? sp.i18n.en ?? sp.i18n.ka ?? sp.i18n.ru;
						const title = sb?.title?.trim() || sp.slug;
						const excerpt = (sb?.description ?? '').trim().slice(0, 280);
						const thumb = tourCoverImageUrl({ image: sp.cover_photo, gallery: sp.gallery });
						const href = getRelativeLocaleUrl(locale, `tours/${sp.slug}`);
						return (
							<article class="card similar-tours__card">
								{thumb ? (
									<a href={href} class="similar-tours__thumb-link" tabindex="-1" aria-hidden="true">
										<img
											class="similar-tours__thumb"
											src={thumb}
											alt=""
											loading="lazy"
											decoding="async"
											width="400"
											height="225"
										/>
									</a>
								) : null}
								<h3 class="similar-tours__card-title">{title}</h3>
								<p class="muted" style="margin:0">
									{excerpt}
								</p>
								<p class="muted" style="margin:0">
									{t.duration}: {sp.duration_label ?? `${sp.duration_hours}h`}
								</p>
								<a class="btn" href={href}>
									{t.viewTour}
								</a>
							</article>
						);
					})}
				</div>
			</section>
		) : null
	}

	<TourComments
		locale={locale}
		apiSegment="packages"
		tourId={pkg.id}
		comments={pkgComments}
		averageRating={pkgAvg}
		user={user}
		loginHref={tourReviewsLoginHref}
		labels={{
			title: t.tourReviewsTitle,
			outOf: t.tourReviewsOutOf,
			count: t.tourReviewsCount,
			loginPrompt: t.tourReviewsLoginPrompt,
			ratingLabel: t.tourReviewsRatingLabel,
			commentLabel: t.tourReviewsCommentLabel,
			submit: t.tourReviewsSubmit,
			empty: t.tourReviewsEmpty,
			signedInAs: t.tourReviewsSignedInAs,
			errorGeneric: t.tourReviewsErrorGeneric,
			posting: t.tourReviewsPosting,
			login: t.login,
			edit: t.tourReviewsEdit,
			reply: t.tourReviewsReply,
			save: t.tourReviewsSave,
			edited: t.tourReviewsEdited,
			replySubmit: t.tourReviewsReplySubmit,
			delete: t.tourReviewsDelete,
			deleting: t.tourReviewsDeleting,
			deleteConfirm: t.tourReviewsDeleteConfirm,
			alreadyReviewedTitle: t.tourReviewsAlreadyReviewedTitle,
