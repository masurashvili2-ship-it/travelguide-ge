<script is:inline>
// ── Mobile bottom sheet ────────────────────────────────
(function () {
	var sidebar = document.getElementById('pkg-sidebar');
	var backdrop = document.getElementById('pkg-book-backdrop');
	var openBtn = document.getElementById('pkg-book-open-btn');
	var closeBtn = document.getElementById('pkg-sheet-close-btn');
	if (!sidebar || !backdrop || !openBtn) return;

	function openSheet() {
		sidebar.classList.add('sheet-open');
		backdrop.classList.add('backdrop-open');
		document.body.style.overflow = 'hidden';
	}
	function closeSheet() {
		sidebar.classList.remove('sheet-open');
		backdrop.classList.remove('backdrop-open');
		document.body.style.overflow = '';
	}

	openBtn.addEventListener('click', openSheet);
	backdrop.addEventListener('click', closeSheet);
	if (closeBtn) closeBtn.addEventListener('click', closeSheet);
	document.addEventListener('keydown', function (e) { if (e.key === 'Escape') closeSheet(); });
})();
</script>

<script is:inline>
	document.addEventListener('click', function (e) {
		var t = e.target;
		if (!(t instanceof Element)) return;
		var btn = t.closest('.pkg-gallery-thumb-btn');
		if (!btn || !(btn instanceof HTMLButtonElement)) return;
		var src = btn.getAttribute('data-full-src');
		if (!src) return;
		var overlay = document.createElement('div');
		overlay.className = 'pkg-gallery-lightbox';
		overlay.setAttribute('role', 'dialog');
		overlay.innerHTML =
			'<button type="button" class="pkg-gallery-lightbox__close" aria-label="Close">×</button><img src="" alt="" />';
		var img = overlay.querySelector('img');
		if (img) img.src = src;
		document.body.appendChild(overlay);
		function close() {
			overlay.remove();
			document.removeEventListener('keydown', onKey);
		}
		function onKey(ev) {
			if (ev.key === 'Escape') close();
		}
		document.addEventListener('keydown', onKey);
		overlay.addEventListener('click', function (ev) {
			var el = ev.target;
			if (ev.target === overlay || (el && el.classList && el.classList.contains('pkg-gallery-lightbox__close'))) close();
		});
	});
</script>

<script is:inline define:vars={{ slotsMapJson, pkgJson, bookingPhoneRequired: t.bookingPhoneRequired }}>
(function () {
	var slotsMap = JSON.parse(slotsMapJson);
	var pkg = JSON.parse(pkgJson);
	var sym = { USD: '$', EUR: '€', GEL: '₾' }[pkg.currency] ?? pkg.currency;
	var isPrivate = pkg.tour_style === 'private';

	// ── Price calculation ─────────────────────────────────────
	function calcGroupPrice(pax, date) {
		var slot = slotsMap[date];
		var unitPrice = (slot && slot.custom_price != null) ? slot.custom_price : pkg.base_price;
		var total = unitPrice * pax;
		var bestDiscount = 0; var bestLabel = null;
		(pkg.pricing_rules || []).forEach(function (rule) {
			var applies = false;
			if (rule.kind === 'group') {
				var min = rule.min_pax ?? 1; var max = rule.max_pax ?? Infinity;
				if (pax >= min && pax <= max) applies = true;
			} else if (rule.kind === 'early_bird') {
				if (rule.days_before != null) {
					var diff = Math.floor((new Date(date) - new Date()) / 86400000);
					if (diff >= rule.days_before) applies = true;
				}
			} else if (rule.kind === 'seasonal') {
				if (rule.date_from && rule.date_to && date >= rule.date_from && date <= rule.date_to) applies = true;
			}
			if (applies && rule.discount_pct > bestDiscount) { bestDiscount = rule.discount_pct; bestLabel = rule.label; }
		});
		var discountedTotal = Math.round(total * (1 - bestDiscount / 100) * 100) / 100;
		return { unitPrice, pax, total, discountedTotal, discountPct: bestDiscount, discountLabel: bestLabel };
	}

	function calcPrivatePrice(tierId, date) {
		var tier = (pkg.private_tiers || []).find(function (t) { return t.id === tierId; });
		if (!tier) return null;
		var tierPrice = tier.price;
		var bestDiscount = 0; var bestLabel = null;
		(pkg.pricing_rules || []).forEach(function (rule) {
			var applies = false;
			if (rule.kind === 'early_bird' && rule.days_before != null) {
				var diff = Math.floor((new Date(date) - new Date()) / 86400000);
				if (diff >= rule.days_before) applies = true;
			} else if (rule.kind === 'seasonal') {
				if (rule.date_from && rule.date_to && date >= rule.date_from && date <= rule.date_to) applies = true;
			}
			if (applies && rule.discount_pct > bestDiscount) { bestDiscount = rule.discount_pct; bestLabel = rule.label; }
		});
		var discountedTotal = Math.round(tierPrice * (1 - bestDiscount / 100) * 100) / 100;
		return { tierPrice, discountedTotal, discountPct: bestDiscount, discountLabel: bestLabel, tier };
	}

	// ── Selected tier state (private tours) ──────────────────
	var selectedTierId = null;
	var tierSelect = document.getElementById('tier-select');
	var tierHidden = document.getElementById('book-tier-id');

	function syncTierFromSelect() {
		if (!tierSelect || !tierHidden) return;
		var opt = tierSelect.options[tierSelect.selectedIndex];
		selectedTierId = tierSelect.value || null;
		tierHidden.value = selectedTierId || '';
		var paxRow = document.getElementById('private-pax-row');
		if (!selectedTierId) {
			if (paxRow) paxRow.style.display = 'none';
			updatePriceBreakdown();
			return;
		}
		if (opt && opt.dataset) {
			if (paxRow) {
				paxRow.style.display = '';
				var hint = document.getElementById('pax-range-hint');
				if (hint) hint.textContent = '(' + opt.dataset.tierMin + '–' + opt.dataset.tierMax + ')';
				var paxInput = document.getElementById('book-pax');
				if (paxInput) {
					paxInput.min = opt.dataset.tierMin;
					paxInput.max = opt.dataset.tierMax;
					paxInput.value = opt.dataset.tierMin;
				}
			}
		}
		updatePriceBreakdown();
	}

	if (isPrivate && tierSelect) {
		tierSelect.addEventListener('change', syncTierFromSelect);
	}

	pkg.extras = pkg.extras || [];

	function collectExtrasTotal(pax) {
		if (!pkg.extras.length) return 0;
		var total = 0;
		document.querySelectorAll('.book-extra-qty').forEach(function (inp) {
			var q = parseInt(inp.value || '0', 10);
			if (!q || q < 0) return;
			var id = inp.getAttribute('data-extra-id');
			var ex = pkg.extras.find(function (e) { return e.id === id; });
			if (!ex) return;
			var line = ex.unit === 'per_person' ? q * ex.price * pax : q * ex.price;
			total += line;
		});
		return Math.round(total * 100) / 100;
	}

	function paintChromeBookingPrice(prePayTotal, finalTotal, isPrivateTour) {
		var breakdown = document.getElementById('price-breakdown');
		var barAmt = document.getElementById('bar-price-amount');
		var barUnit = document.getElementById('bar-price-unit');
		var headerOrig = document.getElementById('price-header-orig');
		var headerDisc = document.getElementById('price-header-discounted');
		var headerLabel = document.getElementById('price-header-label');
		var headerBadge = document.getElementById('price-header-badge');
		var pd = getPaymentDiscount();
		if (!breakdown || breakdown.style.display !== 'block') return;
		if (pd.pct > 0) {
			if (barAmt) {
				barAmt.innerHTML =
					'<span style="text-decoration:line-through;opacity:.72;font-size:0.82em;margin-right:0.35rem">' +
					sym +
					prePayTotal.toFixed(0) +
					'</span><span>' +
					sym +
					finalTotal.toFixed(0) +
					'</span>';
			}
			if (barUnit) barUnit.textContent = isPrivateTour ? ' / group' : ' total';
			if (headerOrig) {
				headerOrig.classList.add('pkg-price-amount--struck');
				headerOrig.textContent = sym + prePayTotal.toFixed(2);
			}
			if (headerDisc) {
				headerDisc.textContent = sym + finalTotal.toFixed(2);
				headerDisc.style.display = '';
				headerDisc.classList.add('pkg-price-discounted');
			}
			if (headerLabel) headerLabel.textContent = isPrivateTour ? ' / group' : ' total';
			if (headerBadge) {
				headerBadge.textContent = 'Pay −' + pd.pct + '%';
				headerBadge.style.display = '';
			}
		}
	}

	// ── Payment discount helper ───────────────────────────────
	function getPaymentDiscount() {
		var method = null;
		document.querySelectorAll('[name="payment_method"]').forEach(function(r) {
			if (r.checked) method = r.value;
		});
		if (!method || !pkg.payment_options) return { pct: 0, label: '' };
		var opt = pkg.payment_options[method];
		if (!opt || !opt.discount_pct) return { pct: 0, label: '' };
		var labels = { paypal_full: 'PayPal discount', paypal_deposit: 'PayPal discount', cash: 'Cash discount' };
		return { pct: opt.discount_pct, label: labels[method] || 'Payment discount' };
	}

	function applyPaymentDiscount(subTotal) {
		var pd = getPaymentDiscount();
		var payRow = document.getElementById('price-pay-discount-row');
		if (!payRow) return subTotal;
		if (pd.pct > 0) {
			var savings = Math.round(subTotal * pd.pct / 100 * 100) / 100;
			var after = Math.round((subTotal - savings) * 100) / 100;
			payRow.style.display = 'flex';
			document.getElementById('price-pay-discount-label').textContent = pd.label + ' (' + pd.pct + '% off)';
			document.getElementById('price-pay-discount-val').textContent = '−' + sym + savings.toFixed(2);
			return after;
		} else {
			payRow.style.display = 'none';
			return subTotal;
		}
	}

	// ── Price breakdown update ────────────────────────────────
	function updatePriceBreakdown() {
		var date = document.getElementById('book-date')?.value;
		var breakdown = document.getElementById('price-breakdown');
		var headerOrig = document.getElementById('price-header-orig');
		var headerDisc = document.getElementById('price-header-discounted');
		var headerLabel = document.getElementById('price-header-label');
		var headerBadge = document.getElementById('price-header-badge');

		if (isPrivate) {
			if (!date || !selectedTierId) {
				if (breakdown) breakdown.style.display = 'none';
				return;
			}
			var p = calcPrivatePrice(selectedTierId, date);
			if (!p) return;
			breakdown.style.display = 'block';
			document.getElementById('price-unit-label').textContent = p.tier.label + ' (' + p.tier.min_pax + '–' + p.tier.max_pax + ' pax)';
			document.getElementById('price-unit-val').textContent = sym + p.tierPrice.toFixed(2);
			var discRow = document.getElementById('price-discount-row');
			if (p.discountPct > 0) {
				discRow.style.display = 'flex';
				document.getElementById('price-discount-label').textContent = (p.discountLabel || 'Discount') + ' (' + p.discountPct + '% off)';
				document.getElementById('price-discount-val').textContent = '−' + sym + (p.tierPrice - p.discountedTotal).toFixed(2);
			} else {
				discRow.style.display = 'none';
			}
			var paxPr = parseInt(document.getElementById('book-pax')?.value || '1', 10);
			var extrasT = collectExtrasTotal(paxPr);
			var exRow = document.getElementById('price-extras-row');
			if (extrasT > 0) {
				exRow.style.display = 'flex';
				document.getElementById('price-extras-val').textContent = sym + extrasT.toFixed(2);
			} else if (exRow) exRow.style.display = 'none';

			var prePay = Math.round((p.discountedTotal + extrasT) * 100) / 100;
			var finalTotal = applyPaymentDiscount(prePay);
			var totalEl = document.getElementById('price-total-val');
			totalEl.textContent = sym + finalTotal.toFixed(2);

			var pd = getPaymentDiscount();
			if (pd.pct > 0) {
				paintChromeBookingPrice(prePay, finalTotal, true);
			} else {
				if (headerOrig) headerOrig.classList.remove('pkg-price-amount--struck');
				if (p.discountPct > 0) {
					if (headerOrig) headerOrig.classList.add('pkg-price-amount--struck');
					if (headerOrig) headerOrig.textContent = sym + p.tierPrice.toFixed(2);
					if (headerDisc) {
						headerDisc.textContent = sym + p.discountedTotal.toFixed(2);
						headerDisc.style.display = '';
					}
					if (headerLabel) headerLabel.textContent = ' / group';
					if (headerBadge) {
						headerBadge.textContent = p.discountPct + '% off';
						headerBadge.style.display = '';
					}
				} else {
					if (headerOrig) {
						headerOrig.textContent = sym + p.tierPrice.toFixed(2);
						headerOrig.classList.remove('pkg-price-amount--struck');
					}
					if (headerDisc) headerDisc.style.display = 'none';
					if (headerLabel) headerLabel.textContent = ' / group';
					if (headerBadge) headerBadge.style.display = 'none';
				}
				var barAmt = document.getElementById('bar-price-amount');
				var barUnit = document.getElementById('bar-price-unit');
				if (barAmt) barAmt.textContent = sym + finalTotal.toFixed(0);
				if (barUnit) barUnit.textContent = ' / group';
			}
		} else {
			// Group tour
			var pax = parseInt(document.getElementById('book-pax')?.value || '1', 10);
			if (!date || !pax || pax < 1) {
				if (breakdown) breakdown.style.display = 'none';
				if (headerOrig) headerOrig.classList.remove('pkg-price-amount--struck');
				if (headerDisc) headerDisc.style.display = 'none';
				if (headerBadge) headerBadge.style.display = 'none';
				if (headerLabel) headerLabel.textContent = ' / person';
				return;
			}
			var gp = calcGroupPrice(pax, date);
			breakdown.style.display = 'block';
			document.getElementById('price-unit-label').textContent = sym + gp.unitPrice + ' × ' + pax + (pax === 1 ? ' person' : ' people');
			document.getElementById('price-unit-val').textContent = sym + gp.total.toFixed(2);
			var dRow = document.getElementById('price-discount-row');
			if (gp.discountPct > 0) {
				var savings = gp.total - gp.discountedTotal;
				dRow.style.display = 'flex';
				document.getElementById('price-discount-label').textContent = (gp.discountLabel || 'Discount') + ' (' + gp.discountPct + '% off)';
				document.getElementById('price-discount-val').textContent = '−' + sym + savings.toFixed(2);
			} else {
				dRow.style.display = 'none';
			}
			var extrasG = collectExtrasTotal(pax);
			var exRowG = document.getElementById('price-extras-row');
			if (extrasG > 0) {
				exRowG.style.display = 'flex';
				document.getElementById('price-extras-val').textContent = sym + extrasG.toFixed(2);
			} else if (exRowG) exRowG.style.display = 'none';

			var prePayG = Math.round((gp.discountedTotal + extrasG) * 100) / 100;
			var groupFinal = applyPaymentDiscount(prePayG);
			var tEl = document.getElementById('price-total-val');
			tEl.textContent = sym + groupFinal.toFixed(2);

			var pdG = getPaymentDiscount();
			if (pdG.pct > 0) {
				paintChromeBookingPrice(prePayG, groupFinal, false);
			} else {
				if (headerOrig) headerOrig.classList.remove('pkg-price-amount--struck');
				if (gp.discountPct > 0) {
					var discUnit = Math.round(gp.unitPrice * (1 - gp.discountPct / 100) * 100) / 100;
					if (headerOrig) headerOrig.classList.add('pkg-price-amount--struck');
					if (headerOrig) headerOrig.textContent = sym + gp.unitPrice.toFixed(2);
					if (headerDisc) {
						headerDisc.textContent = sym + discUnit.toFixed(2);
						headerDisc.style.display = '';
					}
					if (headerLabel) headerLabel.textContent = ' / person';
					if (headerBadge) {
						headerBadge.textContent = gp.discountPct + '% off';
						headerBadge.style.display = '';
					}
				} else {
					if (headerOrig) {
						headerOrig.textContent = sym + gp.unitPrice.toFixed(2);
						headerOrig.classList.remove('pkg-price-amount--struck');
					}
					if (headerDisc) headerDisc.style.display = 'none';
					if (headerLabel) headerLabel.textContent = ' / person';
					if (headerBadge) headerBadge.style.display = 'none';
				}
				var barAmtG = document.getElementById('bar-price-amount');
				var barUnitG = document.getElementById('bar-price-unit');
				if (barAmtG) barAmtG.textContent = sym + groupFinal.toFixed(0);
				if (barUnitG) barUnitG.textContent = ' total';
			}
		}
	}

	document.getElementById('book-date')?.addEventListener('change', updatePriceBreakdown);
	document.getElementById('book-pax')?.addEventListener('input', updatePriceBreakdown);
	document.querySelectorAll('[name="payment_method"]').forEach(function(r) {
		r.addEventListener('change', updatePriceBreakdown);
	});
	document.querySelectorAll('.book-extra-qty').forEach(function (inp) {
		inp.addEventListener('input', updatePriceBreakdown);
	});
	(function selectDefaultPayment() {
		var first = document.querySelector('#pay-options input[name="payment_method"]');
		if (first) first.checked = true;
	})();

	function collectExtrasPayload() {
		var out = [];
		document.querySelectorAll('.book-extra-qty').forEach(function (inp) {
			var q = parseInt(inp.value || '0', 10);
			if (q > 0) out.push({ id: inp.getAttribute('data-extra-id'), quantity: q });
		});
		return out;
	}

	// ── Form submit ───────────────────────────────────────────
	document.getElementById('booking-form')?.addEventListener('submit', async function (e) {
		e.preventDefault();
		var errEl = document.getElementById('booking-error');
		var submitBtn = document.getElementById('book-submit-btn');
		errEl.style.display = 'none';

		var fd = new FormData(this);
		function fv(n) { return (fd.get(n) || '').toString().trim(); }

		var paymentMethod = fv('payment_method') || null;

		var payload = {
			package_id: pkg.id,
			date: fv('date'),
			pax: parseInt(fv('pax')) || 1,
			tier_id: isPrivate ? (fv('tier_id') || null) : null,
			customer_name: fv('customer_name'),
			customer_email: fv('customer_email'),
			customer_phone: fv('customer_phone'),
			special_requests: fv('special_requests') || null,
			payment_method: paymentMethod,
			locale: document.documentElement.lang || 'en',
			extras: collectExtrasPayload(),
		};

		if (!payload.date) { errEl.textContent = 'Please select a date.'; errEl.style.display = 'block'; return; }
		if (isPrivate && !payload.tier_id) { errEl.textContent = 'Please select a group size.'; errEl.style.display = 'block'; return; }
		if (!payload.customer_name) { errEl.textContent = 'Please enter your name.'; errEl.style.display = 'block'; return; }
		if (!payload.customer_email) { errEl.textContent = 'Please enter your email.'; errEl.style.display = 'block'; return; }
		if (!payload.customer_phone || payload.customer_phone.length < 6) {
			errEl.textContent = bookingPhoneRequired;
			errEl.style.display = 'block';
			return;
		}

		var hasPayOptions = document.getElementById('pay-options');
		if (hasPayOptions && !paymentMethod) {
			errEl.textContent = 'Please select a payment method.';
			errEl.style.display = 'block';
			return;
		}

		submitBtn.disabled = true;

		var isPayPal = paymentMethod === 'paypal_full' || paymentMethod === 'paypal_deposit';
		submitBtn.textContent = isPayPal ? 'Redirecting to PayPal…' : 'Sending…';

		try {
			var res = await fetch('/api/bookings', {
				method: 'POST',
				headers: { 'Content-Type': 'application/json' },
				body: JSON.stringify(payload),
			});
			var data = await res.json();
			if (res.ok && data.ok) {
				if (data.paypal_approval_url) {
					// Redirect to PayPal
					window.location.href = data.paypal_approval_url;
					return;
				}
				document.getElementById('booking-form').style.display = 'none';
				document.getElementById('booking-success').style.display = 'block';
				document.getElementById('booking-success-ref').textContent = 'Your reference: ' + data.ref;
			} else {
				errEl.textContent = data.error || 'Booking failed. Please try again.';
				errEl.style.display = 'block';
				submitBtn.disabled = false;
				submitBtn.textContent = 'Request Booking';
			}
		} catch {
			errEl.textContent = 'Network error. Please try again.';
			errEl.style.display = 'block';
			submitBtn.disabled = false;
			submitBtn.textContent = 'Request Booking';
		}
	});
})();
</script>

