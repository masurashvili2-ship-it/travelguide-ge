---
import AdminPostEditMark from './AdminPostEditMark.astro';
import { tourImageAltFromUrl } from '../lib/tour-upload-name';
import type { Locale } from '../lib/strings';
import { ui } from '../lib/strings';

interface Props {
	slug: string;
	locale: Locale;
	title: string;
	duration: string;
	price: string | null;
	excerpt: string;
	/** Gallery image URLs only (cover excluded by caller) */
	images: string[];
	/** When set (e.g. admin user), small edit link next to the title */
	adminEditHref?: string | null;
	/** Canonical page URL for Web Share / copy link */
	shareUrl: string;
}

const { slug, locale, title, duration, price, excerpt, images, adminEditHref = null, shareUrl } = Astro.props;
const t = ui[locale];
const n = images.length;
const hasGallery = n > 0;
const photoCountLabel =
	n === 1 ? t.galleryPhotoCountOne : t.galleryPhotoCountMany.replace('{n}', String(n));

const PREVIEW_MAX = 5;
const previewImages = images.slice(0, PREVIEW_MAX);
const extraHidden = Math.max(0, n - PREVIEW_MAX);
const moreLabel = extraHidden > 0 ? t.galleryMorePhotos.replace('{n}', String(extraHidden)) : '';
const lightboxItems = images.map((src) => ({
	src,
	alt: tourImageAltFromUrl(title, src),
}));
/** Safe for embedding in HTML (closes script tags in strings) */
const lightboxItemsJsonForDom = JSON.stringify(lightboxItems).replace(/</g, '\\u003c');
const shareText = excerpt.trim().slice(0, 280);
---

<section class="tdh" id={`tdh-section-${slug}`} aria-label={hasGallery ? t.gallerySection : undefined} data-tour-hero={slug}>
	{
		hasGallery ? (
			<div class="tdh__bleed">
				<header class="tdh__head">
					<div class="tdh__title-row tdh__title-row--hero">
						<h1 class="tdh__title-plain tdh__title--hero">{title}</h1>
						<div class="tdh__title-actions">
							<button
								type="button"
								class="tdh__share"
								data-tdh-share
								data-share-url={shareUrl}
								data-share-title={title}
								data-share-text={shareText}
								data-share-aria={t.sharePageAria}
								data-msg-copied={t.linkCopied}
								data-msg-failed={t.shareFailed}
								aria-label={t.sharePageAria}
								title={t.sharePage}
							>
								<svg class="tdh__share-icon" viewBox="0 0 24 24" width="16" height="16" aria-hidden="true">
									<path
										fill="currentColor"
										d="M18 16.08c-.76 0-1.44.3-1.96.77L8.91 12.7c.05-.23.09-.46.09-.7s-.04-.47-.09-.7l7.05-4.11c.54.5 1.25.81 2.04.81 1.66 0 3-1.34 3-3s-1.34-3-3-3-3 1.34-3 3c0 .24.04.47.09.7L8.04 9.81C7.5 9.31 6.79 9 6 9c-1.66 0-3 1.34-3 3s1.34 3 3 3c.79 0 1.5-.31 2.04-.81l7.12 4.16c-.05.21-.08.43-.08.65 0 1.61 1.31 2.92 2.92 2.92 1.61 0 2.92-1.31 2.92-2.92s-1.31-2.92-2.92-2.92z"
									/>
								</svg>
							</button>
							{adminEditHref ? <AdminPostEditMark href={adminEditHref} label={t.adminEditPostAria} /> : null}
						</div>
					</div>
				</header>

				<div
					class:list={['tdh__mosaic', { 'tdh__mosaic--solo': previewImages.length === 1 }]}
					data-tdh-mosaic
				>
					{previewImages.length > 0 ? (
						<>
							<button
								type="button"
								class="tdh__tile tdh__tile--lead"
								data-tdh-open
								data-tdh-start="0"
								aria-label={`${t.galleryLightboxLabel} — 1 / ${n}`}
							>
								<img
									src={previewImages[0]}
									alt={tourImageAltFromUrl(title, previewImages[0])}
									width="800"
									height="520"
									loading="eager"
									decoding="async"
									draggable="false"
								/>
							</button>
							{previewImages.length > 1 ? (
								<div class="tdh__side-grid">
									{previewImages.slice(1).map((src, j) => {
										const i = j + 1;
										const showMoreBadge = extraHidden > 0 && i === previewImages.length - 1;
										return (
											<button
												type="button"
												class:list={['tdh__tile', 'tdh__tile--side', { 'tdh__tile--more': showMoreBadge }]}
												data-tdh-open
												data-tdh-start={String(i)}
												aria-label={
													showMoreBadge
														? `${t.galleryLightboxLabel} — ${moreLabel}, ${photoCountLabel}`
														: `${t.galleryLightboxLabel} — ${i + 1} / ${n}`
												}
											>
												<img
													src={src}
													alt={tourImageAltFromUrl(title, src)}
													width="400"
													height="260"
													loading={i < 5 ? 'eager' : 'lazy'}
													decoding="async"
													draggable="false"
												/>
												{showMoreBadge ? (
													<>
														<span class="tdh__tile-shade tdh__tile-shade--more" aria-hidden="true" />
														<span class="tdh__tile-more" aria-hidden="true">
															<span class="tdh__tile-more-text">{moreLabel}</span>
														</span>
													</>
												) : null}
											</button>
										);
									})}
								</div>
							) : null}
						</>
					) : null}
				</div>

				{excerpt.trim() ? <p class="tdh__excerpt">{excerpt}</p> : null}

				<div id={`tdh-lb-json-${slug}`} class="tdh-lb-payload" hidden set:html={lightboxItemsJsonForDom} />

				<div class="tdh-lb" id={`tdh-lb-${slug}`} data-tdh-lb hidden>
					<div class="tdh-lb__backdrop" data-lb-backdrop />
					<div
						class="tdh-lb__dialog"
						role="dialog"
						aria-modal="true"
						aria-label={t.galleryLightboxLabel}
					>
						<div class="tdh-lb__toolbar">
							<span class="tdh-lb__counter" aria-live="polite">
								<span data-lb-i>1</span>
								<span class="tdh-lb__counter-sep" aria-hidden="true">
									/
								</span>
								<span data-lb-n>{n}</span>
							</span>
							<button type="button" class="tdh-lb__icon-btn tdh-lb__close" data-lb-close aria-label={t.galleryClose}>
								<span aria-hidden="true">×</span>
							</button>
						</div>

						<button
							type="button"
							class="tdh-lb__chev tdh-lb__chev--prev"
							data-lb-prev
							aria-label={t.galleryPrev}
						>
							‹
						</button>
						<button
							type="button"
							class="tdh-lb__chev tdh-lb__chev--next"
							data-lb-next
							aria-label={t.galleryNext}
						>
							›
						</button>

						<div class="tdh-lb__stage" data-lb-stage>
							<img class="tdh-lb__img" data-lb-img alt="" src="" draggable="false" />
						</div>
					</div>
				</div>
			</div>
		) : (
			<header class="tdh__fallback">
				<div class="tdh__title-row">
					<h1 class="tdh__title-plain">{title}</h1>
					<div class="tdh__title-actions">
						<button
							type="button"
							class="tdh__share"
							data-tdh-share
							data-share-url={shareUrl}
							data-share-title={title}
							data-share-text={shareText}
							data-share-aria={t.sharePageAria}
							data-msg-copied={t.linkCopied}
							data-msg-failed={t.shareFailed}
							aria-label={t.sharePageAria}
							title={t.sharePage}
						>
							<svg class="tdh__share-icon" viewBox="0 0 24 24" width="16" height="16" aria-hidden="true">
								<path
									fill="currentColor"
									d="M18 16.08c-.76 0-1.44.3-1.96.77L8.91 12.7c.05-.23.09-.46.09-.7s-.04-.47-.09-.7l7.05-4.11c.54.5 1.25.81 2.04.81 1.66 0 3-1.34 3-3s-1.34-3-3-3-3 1.34-3 3c0 .24.04.47.09.7L8.04 9.81C7.5 9.31 6.79 9 6 9c-1.66 0-3 1.34-3 3s1.34 3 3 3c.79 0 1.5-.31 2.04-.81l7.12 4.16c-.05.21-.08.43-.08.65 0 1.61 1.31 2.92 2.92 2.92 1.61 0 2.92-1.31 2.92-2.92s-1.31-2.92-2.92-2.92z"
								/>
							</svg>
						</button>
						{adminEditHref ? <AdminPostEditMark href={adminEditHref} label={t.adminEditPostAria} /> : null}
					</div>
				</div>
				<p class="tdh__meta-line tdh__meta-line--plain">
					<span>
						{t.duration}: {duration}
					</span>
					{price ? (
						<>
							<span class="tdh__dot" aria-hidden="true">
								·
							</span>
							<span>{price}</span>
						</>
					) : null}
				</p>
				{excerpt.trim() ? <p class="tdh__excerpt tdh__excerpt--plain">{excerpt}</p> : null}
			</header>
		)
	}
</section>

{
	hasGallery ? (
		<script is:inline define:vars={{ slug }}>
			(function () {
				function bootTourGallery() {
					var jsonEl = document.getElementById('tdh-lb-json-' + slug);
					var rawJson = jsonEl && jsonEl.textContent ? jsonEl.textContent.trim() : '[]';
					var items;
					try {
						items = JSON.parse(rawJson);
					} catch (e) {
						return;
					}
					if (!items || !items.length) return;

					var root = document.getElementById('tdh-section-' + slug);
					var lb = document.getElementById('tdh-lb-' + slug);
					if (!root || !lb) return;

					if (document.body && lb.parentElement !== document.body) {
						document.body.appendChild(lb);
					}

					var backdrop = lb.querySelector('[data-lb-backdrop]');
					var img = lb.querySelector('[data-lb-img]');
					var idxEl = lb.querySelector('[data-lb-i]');
					var btnClose = lb.querySelector('[data-lb-close]');
					var btnPrev = lb.querySelector('[data-lb-prev]');
					var btnNext = lb.querySelector('[data-lb-next]');

					if (!img) return;

					var total = items.length;
					var index = 0;
					var lastScroll = '';

					function showIndex(i) {
						if (i < 0 || i >= total) return;
						index = i;
						var it = items[i];
						img.src = it.src;
						img.alt = it.alt;
						if (idxEl) idxEl.textContent = String(i + 1);
						if (btnPrev) btnPrev.toggleAttribute('disabled', i <= 0);
						if (btnNext) btnNext.toggleAttribute('disabled', i >= total - 1);
					}

					function isClosed() {
						return lb.hasAttribute('hidden');
					}

					function openAt(i) {
						showIndex(i);
						lb.removeAttribute('hidden');
						lastScroll = document.body.style.overflow;
						document.body.style.overflow = 'hidden';
						if (btnClose) btnClose.focus();
					}

					function closeLb() {
						lb.setAttribute('hidden', '');
						document.body.style.overflow = lastScroll;
					}

					function onThumbClick(ev) {
						var el = ev.target;
						if (!el || !el.closest) return;
						var btn = el.closest('[data-tdh-open]');
						if (!btn || !root.contains(btn)) return;
						ev.preventDefault();
						var s = btn.getAttribute('data-tdh-start');
						var start = s !== null ? parseInt(s, 10) : 0;
						openAt(isFinite(start) ? start : 0);
					}

					root.addEventListener('click', onThumbClick);

					if (btnClose) btnClose.addEventListener('click', closeLb);
					if (backdrop) backdrop.addEventListener('click', closeLb);

					if (btnPrev) btnPrev.addEventListener('click', function () { showIndex(index - 1); });
					if (btnNext) btnNext.addEventListener('click', function () { showIndex(index + 1); });

					document.addEventListener('keydown', function (e) {
						if (isClosed()) return;
						if (e.key === 'Escape') {
							e.preventDefault();
							closeLb();
						} else if (e.key === 'ArrowLeft') {
							e.preventDefault();
							showIndex(index - 1);
						} else if (e.key === 'ArrowRight') {
							e.preventDefault();
							showIndex(index + 1);
						}
					});
				}

				if (document.readyState === 'loading') {
					document.addEventListener('DOMContentLoaded', bootTourGallery);
				} else {
					bootTourGallery();
				}
			})();
		</script>
	) : null
}

<script is:inline define:vars={{ slug }}>
	(function () {
		function bootShare() {
			var root = document.getElementById('tdh-section-' + slug);
			if (!root) return;
			var btn = root.querySelector('[data-tdh-share]');
			if (!btn) return;

			btn.addEventListener('click', function () {
				var url = btn.getAttribute('data-share-url') || '';
				var title = btn.getAttribute('data-share-title') || '';
				var text = btn.getAttribute('data-share-text') || '';
				var copiedMsg = btn.getAttribute('data-msg-copied') || '';
				var failMsg = btn.getAttribute('data-msg-failed') || '';
				var ariaDefault = btn.getAttribute('data-share-aria') || '';

				function restoreAria() {
					btn.setAttribute('aria-label', ariaDefault);
				}

				function doCopy() {
					if (navigator.clipboard && navigator.clipboard.writeText) {
						navigator.clipboard.writeText(url).then(function () {
							btn.setAttribute('aria-label', copiedMsg);
							setTimeout(restoreAria, 2600);
						}).catch(function () {
							window.prompt(failMsg, url);
						});
					} else {
						window.prompt(failMsg, url);
					}
				}

				if (navigator.share) {
					navigator
						.share({ title: title, text: text, url: url })
						.then(function () {})
						.catch(function (err) {
							if (err && err.name === 'AbortError') return;
							doCopy();
						});
					return;
				}
				doCopy();
			});
		}

		if (document.readyState === 'loading') {
			document.addEventListener('DOMContentLoaded', bootShare);
		} else {
			bootShare();
		}
	})();
</script>

<style>
	.tdh {
		margin: 0 0 2rem;
	}

	.tdh__bleed {
		width: min(100vw - 2rem, calc(100% + 2.5rem));
		margin-left: max(-1.25rem, calc(50% - 50vw + 1rem));
		margin-right: max(-1.25rem, calc(50% - 50vw + 1rem));
	}

	@media (min-width: 960px) {
		.tdh__bleed {
			width: calc(100% + 2.5rem);
			margin-left: -1.25rem;
			margin-right: -1.25rem;
		}
	}

	.tdh__head {
		margin: 0 0 1rem;
		padding: 0 0.25rem;
	}

	.tdh__title-row {
		display: flex;
		flex-wrap: wrap;
		align-items: flex-start;
		gap: 0.35rem 0.5rem;
	}
	.tdh__title-row--hero {
		margin: 0 0 0.65rem;
	}
	.tdh__title-row .tdh__title-plain {
		flex: 1 1 auto;
		min-width: 0;
		margin: 0;
	}
	.tdh__title--hero {
		font-size: clamp(1.65rem, 4.5vw, 2.35rem);
		font-weight: 800;
		line-height: 1.12;
		letter-spacing: -0.03em;
	}

	.tdh__title-actions {
		display: inline-flex;
		flex-wrap: wrap;
		align-items: center;
		gap: 0.35rem;
		flex-shrink: 0;
		margin-top: 0.2em;
	}

	.tdh__share {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		flex-shrink: 0;
		padding: 0.2rem;
		min-width: 2.25rem;
		min-height: 2.25rem;
		line-height: 0;
		font: inherit;
		color: var(--muted);
		border-radius: 6px;
		border: 1px solid var(--border);
		background: var(--surface);
		cursor: pointer;
		transition:
			color 0.15s ease,
			border-color 0.15s ease,
			background 0.15s ease;
	}
	.tdh__share:hover {
		color: var(--accent);
		border-color: color-mix(in srgb, var(--accent) 45%, var(--border));
		background: color-mix(in srgb, var(--accent) 10%, var(--surface));
	}
	.tdh__share:focus-visible {
		outline: 2px solid var(--accent);
		outline-offset: 2px;
	}
	.tdh__share-icon {
		display: block;
	}

	.tdh__dot {
		margin: 0 0.35rem;
		opacity: 0.7;
	}

	.tdh__mosaic {
		display: grid;
		gap: 0.55rem;
		grid-template-columns: 1fr;
	}

	.tdh__side-grid {
		display: grid;
		grid-template-columns: 1fr 1fr;
		grid-template-rows: 1fr 1fr;
		gap: 0.55rem;
		min-height: 0;
		align-items: stretch;
	}

	.tdh__tile {
		position: relative;
		display: block;
		padding: 0;
		border: none;
		border-radius: var(--radius-md, 14px);
		overflow: hidden;
		cursor: pointer;
		background: var(--text, #0f172a);
		box-shadow: var(--shadow-md, 0 4px 20px rgba(15, 23, 42, 0.1));
		min-height: 0;
	}

	.tdh__tile--lead {
		width: 100%;
		min-height: min(52vw, 280px);
	}

	.tdh__tile--side {
		min-height: 0;
		height: 100%;
	}

	.tdh__tile img {
		width: 100%;
		height: 100%;
		object-fit: cover;
		display: block;
		vertical-align: middle;
	}

	.tdh__tile-shade--more {
		position: absolute;
		inset: 0;
		background: linear-gradient(to top, rgba(0, 0, 0, 0.55) 0%, rgba(0, 0, 0, 0.2) 50%, transparent 100%);
		pointer-events: none;
	}

	.tdh__tile-more {
		position: absolute;
		inset: 0;
		display: flex;
		align-items: center;
		justify-content: center;
		pointer-events: none;
		z-index: 2;
	}

	.tdh__tile-more-text {
		padding: 0.45rem 0.75rem;
		font-size: 0.95rem;
		font-weight: 700;
		letter-spacing: 0.02em;
		color: #fff;
		text-shadow: 0 2px 14px rgba(0, 0, 0, 0.75);
		background: rgba(0, 0, 0, 0.42);
		border-radius: 8px;
		border: 1px solid rgba(255, 255, 255, 0.2);
	}

	.tdh__tile:focus-visible {
		outline: none;
		box-shadow: 0 0 0 2px var(--bg), 0 0 0 4px var(--accent);
	}

	@media (min-width: 720px) {
		.tdh__mosaic {
			grid-template-columns: minmax(0, 1.12fr) minmax(0, 1fr);
			grid-template-rows: minmax(280px, min(42vw, 420px));
			align-items: stretch;
		}

		.tdh__mosaic--solo {
			grid-template-columns: 1fr;
			grid-template-rows: minmax(280px, min(46vw, 440px));
		}

		.tdh__tile--lead {
			grid-column: 1;
			grid-row: 1;
			min-height: 0;
			height: 100%;
			max-height: none;
		}

		.tdh__mosaic--solo .tdh__tile--lead {
			grid-column: 1;
		}

		.tdh__side-grid {
			grid-column: 2;
			grid-row: 1;
			height: 100%;
			min-height: 0;
			align-self: stretch;
		}

		.tdh__tile--side {
			min-height: 0;
		}
	}

	.tdh__excerpt {
		margin: 1.15rem 0.25rem 0;
		padding: 0 0.15rem;
		font-size: 1rem;
		line-height: 1.55;
		color: var(--muted);
		max-width: 65ch;
	}

	/* ——— Lightbox ——— */
	.tdh-lb {
		position: fixed;
		inset: 0;
		z-index: 99999;
		display: flex;
		align-items: stretch;
		justify-content: center;
		padding: 0;
		box-sizing: border-box;
	}

	.tdh-lb[hidden] {
		display: none !important;
	}

	.tdh-lb__backdrop {
		position: absolute;
		inset: 0;
		background: rgba(8, 10, 14, 0.94);
		cursor: pointer;
	}

	.tdh-lb__dialog {
		position: relative;
		z-index: 1;
		flex: 1;
		display: flex;
		flex-direction: column;
		min-height: 0;
		max-width: 100vw;
	}

	.tdh-lb__toolbar {
		display: flex;
		flex-wrap: wrap;
		align-items: center;
		justify-content: space-between;
		gap: 0.5rem 1rem;
		padding: 0.65rem 0.75rem;
		background: linear-gradient(to bottom, rgba(0, 0, 0, 0.65), transparent);
		width: 100%;
		box-sizing: border-box;
	}

	.tdh-lb__counter {
		font-size: 0.95rem;
		font-weight: 600;
		color: #fff;
		font-variant-numeric: tabular-nums;
		text-shadow: 0 1px 6px rgba(0, 0, 0, 0.5);
	}

	.tdh-lb__counter-sep {
		margin: 0 0.2rem;
		opacity: 0.85;
	}

	.tdh-lb__icon-btn {
		font: inherit;
		font-size: 0.85rem;
		font-weight: 600;
		min-width: 2.35rem;
		min-height: 2.35rem;
		padding: 0 0.5rem;
		border-radius: 8px;
		border: 1px solid rgba(255, 255, 255, 0.2);
		background: rgba(255, 255, 255, 0.1);
		color: #fff;
		cursor: pointer;
		transition:
			background 0.2s ease,
			border-color 0.2s ease;
	}

	.tdh-lb__icon-btn:hover:not(:disabled) {
		background: rgba(255, 255, 255, 0.18);
		border-color: rgba(255, 255, 255, 0.35);
	}

	.tdh-lb__icon-btn:disabled {
		opacity: 0.35;
		cursor: not-allowed;
	}

	.tdh-lb__close {
		font-size: 1.35rem;
		line-height: 1;
		padding: 0 0.45rem;
		margin-left: auto;
	}

	.tdh-lb__chev {
		position: absolute;
		top: 50%;
		transform: translateY(-50%);
