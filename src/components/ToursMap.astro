---
import type { ContentPostKind, TourMapMarker } from '../lib/tours-db';

interface Props {
	markers: TourMapMarker[];
	focus?: { lat: number; lng: number; zoom?: number; slug: string; kind: ContentPostKind };
	popupViewDetailsLabel: string;
	variant?: 'page' | 'embed';
}
const { markers, focus, popupViewDetailsLabel, variant = 'page' } = Astro.props;
const markersJson = JSON.stringify(markers).replace(/</g, '\\u003c');
const focusJson = focus ? JSON.stringify(focus).replace(/</g, '\\u003c') : '';
---

<div
	class:list={['tours-map-wrap', variant === 'embed' && 'tours-map-wrap--embed']}
	data-popup-details={popupViewDetailsLabel}
>
	<div id="tours-leaflet-map" class="tours-map-el"></div>
</div>

<script type="application/json" id="tours-map-data" set:html={markersJson}></script>
{focusJson ? <script type="application/json" id="tours-map-focus" set:html={focusJson} /> : null}
<script>
	import { initTourMap } from '../lib/tours-map-client.ts';

	function boot() {
		const dataEl = document.getElementById('tours-map-data');
		const raw = dataEl?.textContent?.trim() || '[]';
		let markerList;
		try {
			markerList = JSON.parse(raw);
		} catch {
			return;
		}
		const wrap = document.querySelector('.tours-map-wrap');
		const label =
			(wrap && wrap instanceof HTMLElement && wrap.dataset.popupDetails?.trim()) || 'View details';
		const focusEl = document.getElementById('tours-map-focus');
		let focusOpt:
			| { lat: number; lng: number; zoom?: number; slug?: string; kind?: string }
			| undefined;
		if (focusEl?.textContent?.trim()) {
			try {
				focusOpt = JSON.parse(focusEl.textContent.trim());
			} catch {
				focusOpt = undefined;
			}
		}
		const enableFilters = Boolean(document.getElementById('tours-map-filters'));
		initTourMap(markerList, {
			focus: focusOpt,
			popupViewDetailsLabel: label,
			enableFilters,
		});
	}

	if (document.readyState === 'loading') {
		document.addEventListener('DOMContentLoaded', boot, { once: true });
	} else {
		boot();
	}
</script>

<style is:global>
	.tours-map-wrap .tours-map-el {
		height: 420px;
		width: 100%;
		border-radius: 8px;
		overflow: hidden;
		border: 1px solid var(--border);
		font-family: inherit;
	}
	.tours-map-wrap--embed .tours-map-el {
		height: 300px;
	}
	.tours-map-wrap .tours-map-el.leaflet-container {
		font-family: inherit;
	}
	.map-popup-wrap .leaflet-popup-content-wrapper {
		border-radius: 10px;
		padding: 0;
		overflow: hidden;
	}
	.map-popup-wrap .leaflet-popup-content {
		margin: 0;
		min-width: 220px;
		max-width: 300px;
	}
	.map-popup {
		padding: 0.65rem 0.75rem 0.75rem;
	}
	.map-popup__label {
		font-size: 0.72rem;
		font-weight: 700;
		text-transform: uppercase;
		letter-spacing: 0.04em;
		color: var(--muted, #64748b);
		margin-bottom: 0.35rem;
	}
	.map-popup__media {
		display: block;
		margin: 0 -0.75rem 0.5rem;
		line-height: 0;
		background: var(--surface, #f8fafc);
	}
	.map-popup__img {
		width: 100%;
		height: auto;
		max-height: 140px;
		object-fit: cover;
		display: block;
	}
	.map-popup__title {
		margin: 0 0 0.35rem;
		font-size: 1rem;
		font-weight: 700;
		line-height: 1.25;
	}
	.map-popup__title a {
		color: inherit;
		text-decoration: none;
	}
	.map-popup__title a:hover {
		text-decoration: underline;
	}
	.map-popup__excerpt {
		margin: 0 0 0.5rem;
		font-size: 0.86rem;
		line-height: 1.45;
		color: var(--text, #1e293b);
		opacity: 0.92;
	}
	.map-popup__cta {
		margin: 0;
	}
	.map-popup__link {
		font-weight: 600;
		font-size: 0.9rem;
	}
</style>
