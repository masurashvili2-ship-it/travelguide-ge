---
import Shell from '../../../components/Shell.astro';
import { getRelativeLocaleUrl } from 'astro:i18n';
import { listRegionIndexCards, REGION_LEVEL_IDS, type RegionLevel } from '../../../lib/regions-db';
import type { Locale } from '../../../lib/strings';
import { ui } from '../../../lib/strings';
import { tourCoverImageUrl } from '../../../lib/tours-db';

const loc = Astro.params.locale;
if (loc !== 'en' && loc !== 'ka' && loc !== 'ru') {
	return new Response(null, { status: 404 });
}
const locale = loc as Locale;
const t = ui[locale];

const levelParam = Astro.url.searchParams.get('level')?.trim().toLowerCase() ?? '';
const levelFilter: RegionLevel | undefined =
	levelParam && (REGION_LEVEL_IDS as readonly string[]).includes(levelParam)
		? (levelParam as RegionLevel)
		: undefined;

const searchQuery = Astro.url.searchParams.get('q')?.trim().toLowerCase() ?? '';
const pageParam = parseInt(Astro.url.searchParams.get('page') ?? '1', 10);
const PAGE_SIZE = 60;

const allCards = listRegionIndexCards(locale);

// Default view: show only regions + municipalities (not all 2000 villages)
// When village filter is active, show villages with search + pagination
let cards = levelFilter
	? allCards.filter((c) => c.level === levelFilter)
	: allCards.filter((c) => c.level !== 'village');

// Apply search filter
if (searchQuery) {
	cards = cards.filter(
		(c) =>
			c.title.toLowerCase().includes(searchQuery) ||
			c.excerpt.toLowerCase().includes(searchQuery) ||
			(c.subtitle ?? '').toLowerCase().includes(searchQuery),
	);
}

const totalCount = cards.length;
const totalPages = Math.max(1, Math.ceil(totalCount / PAGE_SIZE));
const page = Math.min(Math.max(1, pageParam), totalPages);

// Only paginate when browsing villages (or search results)
const usePagination = levelFilter === 'village' || !!searchQuery;
const displayCards = usePagination ? cards.slice((page - 1) * PAGE_SIZE, page * PAGE_SIZE) : cards;

const regionsPath = getRelativeLocaleUrl(locale, 'regions');

function levelLabel(level: RegionLevel): string {
	if (level === 'region') return t.regionsLevelRegion;
	if (level === 'municipality') return t.regionsLevelMunicipality;
	return t.regionsLevelVillage;
}

function pageUrl(p: number) {
	const u = new URL(Astro.url.href);
	u.searchParams.set('page', String(p));
	return u.pathname + u.search;
}

const villageTotalCount = allCards.filter((c) => c.level === 'village').length;
const muniTotalCount = allCards.filter((c) => c.level === 'municipality').length;
const regionTotalCount = allCards.filter((c) => c.level === 'region').length;
---

<Shell
	locale={locale}
	subpath="regions"
	title={t.regions}
	seoDescription={t.regionsMetaDescription}
	canonicalPath={levelFilter ? `/${locale}/regions?level=${levelFilter}` : `/${locale}/regions`}
>
	<section class="hero">
		<h1>{t.regions}</h1>
		<p class="muted">{t.regionsIntro}</p>
	</section>

	<nav class="regions-filter" aria-label="Place type">
		<a
			class:list={['regions-filter__a', !levelFilter && 'is-active']}
			href={regionsPath}
			aria-current={!levelFilter ? 'page' : undefined}>All</a>
		{
			REGION_LEVEL_IDS.map((id) => {
				const count = id === 'region' ? regionTotalCount : id === 'municipality' ? muniTotalCount : villageTotalCount;
				return (
					<a
						class:list={['regions-filter__a', levelFilter === id && 'is-active']}
						href={`${regionsPath}?level=${id}`}
						aria-current={levelFilter === id ? 'page' : undefined}
					>
						{levelLabel(id)} <span class="regions-filter__count">{count}</span>
					</a>
				);
			})
		}
	</nav>

	{/* Search bar — always visible so users can find villages by name */}
	<form class="regions-search" method="get" action={regionsPath}>
		{levelFilter && <input type="hidden" name="level" value={levelFilter} />}
		<input
			class="regions-search__input"
			type="search"
			name="q"
			value={searchQuery}
			placeholder={`Search ${levelFilter ? levelLabel(levelFilter) + 's' : 'regions, municipalities & villages'}…`}
			autocomplete="off"
		/>
		<button class="regions-search__btn" type="submit">Search</button>
		{searchQuery && (
			<a class="regions-search__clear" href={levelFilter ? `${regionsPath}?level=${levelFilter}` : regionsPath}>
				✕ Clear
			</a>
		)}
	</form>

	{searchQuery && (
		<p class="muted regions-results-info">
			{totalCount} result{totalCount !== 1 ? 's' : ''} for "<strong>{searchQuery}</strong>"
			{levelFilter ? ` in ${levelLabel(levelFilter)}s` : ''}
		</p>
	)}

	{
		displayCards.length === 0 ? (
			<p class="muted" style="margin-top:2rem">
				{searchQuery ? `No places match "${searchQuery}".` : 'No places in this list yet.'}
			</p>
		) : (
			<div class:list={['regions-grid', levelFilter === 'village' && 'regions-grid--villages']}>
				{displayCards.map((c) => {
					const cover = tourCoverImageUrl({ image: c.image, gallery: c.gallery });
					const href = getRelativeLocaleUrl(locale, `regions/${c.slug}`);
					if (c.level === 'village') {
						// Compact list-row for villages
						return (
							<a class="village-row" href={href}>
								<span class="village-row__name">{c.title}</span>
								{c.subtitle ? <span class="village-row__sub">{c.subtitle}</span> : null}
							</a>
						);
					}
					return (
						<a class:list={['regions-tile', !cover && 'regions-tile--no-photo']} href={href}>
							{cover ? (
								<div class="regions-tile__photo" aria-hidden="true">
									<img src={cover} alt="" width="800" height="450" loading="lazy" decoding="async" />
								</div>
							) : null}
							<div class="regions-tile__scrim" aria-hidden="true" />
							<div class="regions-tile__body">
								<span class="regions-tile__badge">{levelLabel(c.level)}</span>
								<h2 class="regions-tile__title">{c.title}</h2>
								{c.subtitle ? <p class="regions-tile__subtitle">{c.subtitle}</p> : null}
								<p class="regions-tile__excerpt">{c.excerpt}</p>
								<span class="regions-tile__cta">
									<span class="regions-tile__cta-inner">{t.viewRegion}</span>
								</span>
							</div>
						</a>
					);
				})}
			</div>
		)
	}

	{/* Pagination */}
	{usePagination && totalPages > 1 && (
		<nav class="regions-pager" aria-label="Pages">
			{page > 1 && (
				<a class="regions-pager__a" href={pageUrl(page - 1)}>← Previous</a>
			)}
			<span class="regions-pager__info">
				Page {page} of {totalPages} &nbsp;·&nbsp; {totalCount} total
			</span>
			{page < totalPages && (
				<a class="regions-pager__a" href={pageUrl(page + 1)}>Next →</a>
			)}
		</nav>
	)}

	{!levelFilter && (
		<div class="villages-hint">
			<p>
				<strong>{villageTotalCount.toLocaleString()} villages</strong> are in the database.
				<a href={`${regionsPath}?level=village`}>Browse all villages →</a>
			</p>
		</div>
	)}
</Shell>

<style>
	/* ── Search ────────────────────────────────────────────────── */
	.regions-search {
		display: flex;
		gap: 0.5rem;
		align-items: center;
		margin: 1.25rem 0 0.75rem;
		flex-wrap: wrap;
	}
	.regions-search__input {
		flex: 1;
		min-width: 200px;
		padding: 0.55rem 0.9rem;
		border: 1px solid var(--border, #e2e8f0);
		border-radius: var(--radius, 8px);
		background: var(--surface, #fff);
		color: var(--text, #1e293b);
		font-size: 0.95rem;
	}
	.regions-search__input:focus {
		outline: 2px solid var(--accent);
		outline-offset: 1px;
		border-color: var(--accent);
	}
	.regions-search__btn {
		padding: 0.55rem 1.15rem;
		border-radius: var(--radius, 8px);
		background: var(--accent, #e86339);
		color: #fff;
		border: none;
		font-weight: 600;
		cursor: pointer;
		font-size: 0.9rem;
	}
	.regions-search__clear {
		font-size: 0.85rem;
		color: var(--muted, #64748b);
		text-decoration: none;
		padding: 0.3rem 0.5rem;
	}
	.regions-search__clear:hover { color: var(--text); }

	.regions-results-info {
		margin: 0.25rem 0 0.75rem;
		font-size: 0.9rem;
	}

	/* ── Filter nav ────────────────────────────────────────────── */
	.regions-filter {
		display: flex;
		flex-wrap: wrap;
		gap: 0.5rem 0.75rem;
		margin: 1rem 0 0;
	}
	.regions-filter__a {
		font-size: 0.88rem;
		font-weight: 600;
		text-decoration: none;
		padding: 0.35rem 0.75rem;
		border-radius: 999px;
		border: 1px solid var(--border, #e2e8f0);
		color: var(--text, #1e293b);
	}
	.regions-filter__a:hover {
		border-color: color-mix(in srgb, var(--text) 28%, var(--border));
	}
	.regions-filter__a.is-active {
		background: var(--text, #1e293b);
		color: var(--bg, #fff);
		border-color: var(--text, #1e293b);
	}

	.regions-grid {
		display: grid;
		gap: 1.35rem;
		grid-template-columns: repeat(auto-fill, minmax(min(100%, 300px), 1fr));
		margin-top: 1rem;
	}
	@media (min-width: 900px) {
		.regions-grid {
			grid-template-columns: repeat(2, minmax(0, 1fr));
			gap: 1.5rem;
		}
	}
	@media (min-width: 1200px) {
		.regions-grid {
			grid-template-columns: repeat(3, minmax(0, 1fr));
		}
	}

	.regions-tile {
		position: relative;
		display: flex;
		flex-direction: column;
		justify-content: flex-end;
		min-height: 17.5rem;
		border-radius: var(--radius-lg, 14px);
		overflow: hidden;
		text-decoration: none;
		color: inherit;
		border: 1px solid color-mix(in srgb, var(--border) 80%, transparent);
		box-shadow: var(--shadow-md, 0 8px 28px rgba(15, 23, 42, 0.1));
		transition:
			transform 0.28s ease,
			box-shadow 0.28s ease,
			border-color 0.28s ease;
		isolation: isolate;
	}
	.regions-tile:hover {
		transform: translateY(-4px);
		box-shadow: 0 18px 44px rgba(15, 23, 42, 0.16);
		border-color: color-mix(in srgb, var(--accent) 35%, var(--border));
	}
	.regions-tile:focus-visible {
		outline: 2px solid var(--accent);
		outline-offset: 3px;
	}

	.regions-tile--no-photo {
		background:
			linear-gradient(145deg, color-mix(in srgb, var(--accent) 12%, var(--surface)) 0%, var(--surface) 48%, color-mix(in srgb, var(--accent) 8%, var(--surface)) 100%),
			var(--surface);
		min-height: 14rem;
	}
	.regions-tile--no-photo .regions-tile__scrim {
		background: linear-gradient(
			to top,
			rgba(15, 23, 42, 0.88) 0%,
			rgba(15, 23, 42, 0.35) 55%,
			transparent 100%
		);
	}

	.regions-tile__photo {
		position: absolute;
		inset: 0;
		z-index: 0;
	}
	.regions-tile__photo img {
		width: 100%;
		height: 100%;
		object-fit: cover;
		object-position: center;
		transform: scale(1.02);
		transition: transform 0.45s ease;
	}
	.regions-tile:hover .regions-tile__photo img {
		transform: scale(1.07);
	}

	.regions-tile__scrim {
		position: absolute;
		inset: 0;
		z-index: 1;
		pointer-events: none;
		background: linear-gradient(
			to top,
			rgba(15, 23, 42, 0.92) 0%,
			rgba(15, 23, 42, 0.45) 42%,
			rgba(15, 23, 42, 0.12) 68%,
			transparent 100%
		);
	}

	.regions-tile__body {
		position: relative;
		z-index: 2;
		padding: 1.35rem 1.35rem 1.25rem;
		display: flex;
		flex-direction: column;
		gap: 0.45rem;
		color: #f8fafc;
	}

	.regions-tile__badge {
		align-self: flex-start;
		font-size: 0.68rem;
		font-weight: 700;
		text-transform: uppercase;
		letter-spacing: 0.08em;
		padding: 0.28rem 0.6rem;
		border-radius: 999px;
		background: rgba(255, 255, 255, 0.14);
		border: 1px solid rgba(255, 255, 255, 0.22);
		backdrop-filter: blur(8px);
		color: rgba(248, 250, 252, 0.95);
	}

	.regions-tile__title {
		margin: 0;
		font-size: clamp(1.15rem, 2.5vw, 1.35rem);
		font-weight: 700;
		letter-spacing: -0.02em;
		line-height: 1.2;
		color: #fff;
		text-shadow: 0 2px 16px rgba(0, 0, 0, 0.35);
	}

	.regions-tile__subtitle {
		margin: 0;
		font-size: 0.92rem;
		font-weight: 500;
		color: rgba(248, 250, 252, 0.88);
		line-height: 1.35;
	}

	.regions-tile__excerpt {
		margin: 0.15rem 0 0;
		font-size: 0.86rem;
		line-height: 1.5;
		color: rgba(226, 232, 240, 0.92);
		display: -webkit-box;
		-webkit-line-clamp: 3;
		-webkit-box-orient: vertical;
		overflow: hidden;
	}

	.regions-tile__cta {
		margin-top: 0.5rem;
		padding-top: 0.65rem;
		border-top: 1px solid rgba(255, 255, 255, 0.14);
	}
	.regions-tile__cta-inner {
		display: inline-flex;
		align-items: center;
		font-size: 0.82rem;
		font-weight: 700;
		letter-spacing: 0.03em;
		text-transform: uppercase;
		color: #fff;
		opacity: 0.95;
		transition: transform 0.2s ease, opacity 0.2s ease;
	}
	.regions-tile:hover .regions-tile__cta-inner {
		transform: translateX(3px);
		opacity: 1;
	}

	/* ── Filter count badge ────────────────────────────────────── */
	.regions-filter__count {
		font-size: 0.72em;
		background: rgba(0,0,0,0.08);
		border-radius: 999px;
		padding: 0.1em 0.5em;
		margin-left: 0.2em;
		font-weight: 600;
	}
	.regions-filter__a.is-active .regions-filter__count {
		background: rgba(255,255,255,0.22);
	}

	/* ── Village compact list ──────────────────────────────────── */
	.regions-grid--villages {
		display: flex;
		flex-direction: column;
		gap: 0;
		border: 1px solid var(--border, #e2e8f0);
		border-radius: var(--radius-lg, 14px);
		overflow: hidden;
		margin-top: 1rem;
	}
	.village-row {
		display: flex;
		align-items: center;
		gap: 1rem;
		padding: 0.75rem 1.1rem;
		text-decoration: none;
		color: var(--text, #1e293b);
		border-bottom: 1px solid var(--border, #e2e8f0);
		transition: background 0.15s ease;
	}
	.village-row:last-child { border-bottom: none; }
	.village-row:hover { background: color-mix(in srgb, var(--accent) 6%, var(--surface)); }
	.village-row__name {
		font-weight: 600;
		font-size: 0.95rem;
		flex: 1;
	}
	.village-row__sub {
		font-size: 0.8rem;
		color: var(--muted, #64748b);
		white-space: nowrap;
	}

	/* ── Pagination ────────────────────────────────────────────── */
	.regions-pager {
		display: flex;
		align-items: center;
		justify-content: center;
		gap: 1.25rem;
		margin: 2rem 0 1rem;
		flex-wrap: wrap;
	}
	.regions-pager__a {
		padding: 0.5rem 1.1rem;
		border: 1px solid var(--border, #e2e8f0);
		border-radius: var(--radius, 8px);
		text-decoration: none;
		font-weight: 600;
		font-size: 0.9rem;
		color: var(--text);
		transition: border-color 0.15s, background 0.15s;
	}
	.regions-pager__a:hover {
		border-color: var(--accent);
		background: color-mix(in srgb, var(--accent) 8%, var(--surface));
	}
	.regions-pager__info {
		font-size: 0.88rem;
		color: var(--muted, #64748b);
	}

	/* ── Villages hint on default view ────────────────────────── */
	.villages-hint {
		margin-top: 2.5rem;
		padding: 1rem 1.25rem;
		border: 1px solid var(--border, #e2e8f0);
		border-radius: var(--radius-lg, 14px);
		background: color-mix(in srgb, var(--accent) 5%, var(--surface));
	}
	.villages-hint p {
		margin: 0;
		font-size: 0.95rem;
		color: var(--text);
	}
	.villages-hint a {
		color: var(--accent);
		font-weight: 600;
		margin-left: 0.5rem;
	}
</style>
