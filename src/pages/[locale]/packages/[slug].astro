---
/**
 * Guide packages are served under /[locale]/tours/[slug] (same as editorial tours).
 * Keep this route as a permanent redirect for old links and bookmarks.
 */
import { getRelativeLocaleUrl } from 'astro:i18n';
import type { Locale } from '../../../lib/strings';

export const prerender = false;

const loc = Astro.params.locale;
const slug = Astro.params.slug;
if ((loc !== 'en' && loc !== 'ka' && loc !== 'ru') || !slug) {
	return new Response(null, { status: 404 });
}
const locale = loc as Locale;

return Astro.redirect(getRelativeLocaleUrl(locale, `tours/${slug}`), 308);
---
