---
import MapFiltersPanel from '../../components/MapFiltersPanel.astro';
import Shell from '../../components/Shell.astro';
import ToursMap from '../../components/ToursMap.astro';
import { listRegionMapMarkers } from '../../lib/regions-db';
import { listPublishedPackageMapMarkers } from '../../lib/guide-packages-db';
import { listTourMapMarkers, listWhatToDoMapMarkers } from '../../lib/tours-db';
import type { Locale } from '../../lib/strings';
import { ui } from '../../lib/strings';

const loc = Astro.params.locale;
if (loc !== 'en' && loc !== 'ka' && loc !== 'ru') {
	return new Response(null, { status: 404 });
}
const locale = loc as Locale;
const t = ui[locale];
const markers = [
	...listTourMapMarkers(locale),
	...listPublishedPackageMapMarkers(locale),
	...listWhatToDoMapMarkers(locale),
	...listRegionMapMarkers(locale),
];
---

<Shell
	locale={locale}
	subpath="map"
	title={t.map}
	seoDescription={t.mapMetaDescription}
	canonicalPath={`/${locale}/map`}
>
	<section class="hero">
		<h1>{t.map}</h1>
		<p class="muted">{t.mapIntro}</p>
	</section>

	{markers.length === 0 ? <p class="muted">{t.mapEmpty}</p> : null}
	{
		markers.length > 0 ? (
			<div class="map-page-stack">
				<MapFiltersPanel
					filterLabels={{
						all: t.mapFilterAll,
						whatToDo: t.mapFilterWhatToDo,
						regions: t.mapFilterRegions,
						activityTypes: t.mapFilterActivityTypes,
						clear: t.mapFilterClear,
						showing: t.mapFilterShowing,
						hint: t.mapFilterHint,
					}}
					whatToDoCategoryLabels={t.whatToDoCategories}
				/>
				<ToursMap markers={markers} popupViewDetailsLabel={t.mapPopupViewDetails} />
			</div>
		) : null
	}
</Shell>

<style>
	.map-page-stack {
		margin-top: 0.5rem;
	}
</style>
