---
import Shell from '../../../components/Shell.astro';
import type { Locale } from '../../../lib/strings';

const loc = Astro.params.locale;
if (loc !== 'en' && loc !== 'ka' && loc !== 'ru') return new Response(null, { status: 404 });
const locale = loc as Locale;

const ref = Astro.url.searchParams.get('ref') ?? '';
const error = Astro.url.searchParams.get('error') ?? '';
---

<Shell
	locale={locale}
	title="Payment Cancelled · TravelGeorgia.ge"
	seoDescription="Payment was cancelled or did not complete."
	robotsNoindex={true}
>
	<div class="wrap">
		<main id="main-content" style="padding-top:3rem;padding-bottom:5rem;text-align:center;max-width:500px;margin:0 auto">
			<div style="font-size:3.5rem" aria-hidden="true">❌</div>
			<h1 style="font-size:1.75rem;margin:1rem 0 0.5rem">Payment cancelled</h1>
			<p class="muted" style="margin:0 0 1.5rem;font-size:1rem">
				Your payment was not completed. Your booking request is still saved — you can try again.
			</p>

			{ref && (
				<p class="muted" style="margin:0 0 1rem;font-size:0.9rem">
					Booking reference: <strong>{ref}</strong>
				</p>
			)}

			{error && error !== 'no_token' && (
				<p style="color:#dc2626;font-size:0.85rem;margin:0 0 1.5rem">
					Error: {decodeURIComponent(error)}
				</p>
			)}

			<div style="display:flex;gap:0.75rem;justify-content:center;flex-wrap:wrap;margin-top:1.5rem">
				<a href={`/${locale}/tours`} class="btn">Browse tours</a>
				<button onclick="history.back()" class="btn btn--outline" type="button">Go back</button>
			</div>
		</main>
	</div>
</Shell>

<style>
.btn--outline {
	background: transparent;
	border: 1.5px solid currentColor;
	cursor: pointer;
}
</style>
