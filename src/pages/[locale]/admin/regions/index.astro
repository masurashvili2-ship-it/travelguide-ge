---
import AdminLayout from '../../../../components/admin/AdminLayout.astro';
import { getRelativeLocaleUrl } from 'astro:i18n';
import {
	ADMIN_LIST_PAGE_SIZE,
	buildAdminQueryLink,
	filterRegionRowsForAdmin,
	listRangeLabel,
	paginateSlice,
	parseAdminListPage,
} from '../../../../lib/admin-list-helpers';
import { listAllRegionsAdmin } from '../../../../lib/regions-db';
import type { Locale } from '../../../../lib/strings';

export const prerender = false;

const loc = Astro.params.locale;
if (loc !== 'en' && loc !== 'ka' && loc !== 'ru') {
	return new Response(null, { status: 404 });
}
const locale = loc as Locale;

if (!Astro.locals.user || Astro.locals.user.role !== 'admin') {
	const login = getRelativeLocaleUrl(locale, 'login');
	const next = getRelativeLocaleUrl(locale, 'admin/regions');
	return Astro.redirect(`${login}?next=${encodeURIComponent(next)}`);
}

const regionRows = listAllRegionsAdmin();
const formError = Astro.url.searchParams.get('error');
const userEmail = Astro.locals.user.email;
const sp = Astro.url.searchParams;
const q = (sp.get('q') ?? '').trim();
const levelFilter = (sp.get('level') ?? '').trim();
const regionRowsFiltered = filterRegionRowsForAdmin(regionRows, q, levelFilter);
const regionsPag = paginateSlice(
	regionRowsFiltered,
	parseAdminListPage(sp, 'page'),
	ADMIN_LIST_PAGE_SIZE,
);

const pathOnly = Astro.url.pathname;
const searchOnly = Astro.url.search;

const newRegionUrl = getRelativeLocaleUrl(locale, 'admin/regions/new');
const dashboardUrl = getRelativeLocaleUrl(locale, 'admin');

function queryLink(updates: Record<string, string | null | undefined>): string {
	return buildAdminQueryLink(pathOnly, searchOnly, updates);
}

const LEVEL_FILTERS = [
	{ value: '', label: 'All' },
	{ value: 'region', label: 'Regions' },
	{ value: 'municipality', label: 'Municipalities' },
	{ value: 'village', label: 'Villages' },
] as const;
---

<AdminLayout
	locale={locale}
	title="Regions · Travel Guide Georgia"
	headline="Regions, municipalities & villages"
	subtitle="Public URLs: /{locale}/regions/… · Data: data/regions/"
	activeNav="regions-all"
	userEmail={userEmail}
>
	{
		formError ? (
			<div class="notice notice-error" role="alert">
				{formError}
			</div>
		) : null
	}

	<section class="admin-card">
		<h2 class="admin-card__h">All places</h2>
		<div class="admin-card__bd">
		<p style="margin:0 0 1rem;display:flex;flex-wrap:wrap;gap:0.5rem;align-items:center">
			<a class="button button-primary" href={newRegionUrl}>
				Add new place
			</a>
			<a class="button" href={dashboardUrl}>
				Dashboard
			</a>
			<button id="import-villages-btn" class="button" type="button" style="background:#0ea5e9;color:#fff;border-color:#0ea5e9">
				⬇ Import villages from Wikidata
			</button>
		</p>
		<div id="import-villages-status" style="display:none;margin:0.75rem 0 0;padding:0.75rem 1rem;border-radius:8px;font-size:0.92rem"></div>
		<script is:inline>
		document.getElementById('import-villages-btn')?.addEventListener('click', async function() {
			const btn = this;
			const status = document.getElementById('import-villages-status');
			btn.disabled = true;
			btn.textContent = '⏳ Importing… (this may take ~30s)';
			status.style.display = 'block';
			status.style.background = '#f0f9ff';
			status.style.border = '1px solid #bae6fd';
			status.textContent = 'Querying Wikidata SPARQL endpoint…';
			try {
				const res = await fetch('/api/admin/import-villages', { method: 'POST' });
				const data = await res.json();
				if (data.ok) {
					status.style.background = '#f0fdf4';
					status.style.border = '1px solid #86efac';
					status.innerHTML = '✅ ' + data.message + (data.total_added > 0 ? ' <strong>Reload the page to see updates.</strong>' : '');
				} else {
					status.style.background = '#fef2f2';
					status.style.border = '1px solid #fca5a5';
					status.textContent = '❌ ' + (data.error ?? 'Import failed');
				}
			} catch (e) {
				status.style.background = '#fef2f2';
				status.style.border = '1px solid #fca5a5';
				status.textContent = '❌ Network error: ' + e.message;
			}
			btn.disabled = false;
			btn.textContent = '⬇ Import villages from Wikidata';
		});
		</script>

			<div class="admin-filter-bar">
				<span class="admin-filter-bar__label">Type:</span>
				{
					LEVEL_FILTERS.map(({ value, label }) => (
						<a
							class:list={['admin-filter-btn', levelFilter === value && 'is-active']}
							href={queryLink({ level: value || null, page: null, q: null })}
						>
							{label}{' '}
							<span class="admin-filter-btn__count">
								{value
									? regionRows.filter((r) => r.level === value).length
									: regionRows.length}
							</span>
						</a>
					))
				}
			</div>

			<div class="admin-toolbar">
				<span class="muted" style="font-size:0.88rem;margin:0">
					{listRangeLabel(regionsPag.page, ADMIN_LIST_PAGE_SIZE, regionsPag.total, 'places')}
					{q ? ` · search "${q}"` : ''}{levelFilter ? ` · type: ${levelFilter}` : ''} · {ADMIN_LIST_PAGE_SIZE} per page · page {regionsPag.page} / {regionsPag.totalPages}
				</span>
				<form method="get" action={pathOnly} class="admin-toolbar__search">
					{levelFilter ? <input type="hidden" name="level" value={levelFilter} /> : null}
					<input type="hidden" name="page" value="1" />
					<label class="visually-hidden" for="regions-list-q">Search regions</label>
					<input
						id="regions-list-q"
						type="search"
						name="q"
						value={q}
						placeholder="Search slug, titles…"
						autocomplete="off"
						class="admin-toolbar__search-input"
					/>
					<button type="submit" class="button button-sm">Search</button>
					{
						q ? (
							<a class="button button-sm btn--ghost" href={queryLink({ q: null, page: null })}>
								Clear
							</a>
						) : null
					}
				</form>
			</div>

			{
				regionsPag.total === 0 ? (
					<p class="muted" style="margin:0">
						{regionRows.length === 0 ? (
							<>
								No places yet. Add a <strong>region</strong> first (no parent), then municipalities under it, then
								villages.
							</>
						) : (
							<>No places match this filter.</>
						)}
					</p>
				) : (
					<>
						<div class="admin-table-wrap">
							<table class="admin-table">
								<thead>
									<tr>
										<th>Slug</th>
										<th>Type</th>
										<th>English</th>
										<th>Georgian</th>
										<th>Russian</th>
										<th>Actions</th>
									</tr>
								</thead>
								<tbody>
									{
										regionsPag.slice.map((row) => (
											<tr>
												<td>
													<code>{row.slug}</code>
												</td>
												<td>{row.level}</td>
												<td>{row.titles.en || '—'}</td>
												<td>{row.titles.ka || '—'}</td>
												<td>{row.titles.ru || '—'}</td>
												<td>
													<a class="button button-sm" href={getRelativeLocaleUrl(locale, `admin/regions/edit/${row.id}`)}>Edit</a>
													<div class="view-links muted" style="margin-top:0.35rem">
														{row.locales.map((code) => (
															<a href={getRelativeLocaleUrl(code, `regions/${row.slug}`)}>
																View ({code})
															</a>
														))}
														{row.locales.length === 0 ? <span>No locales</span> : null}
													</div>
												</td>
											</tr>
										))
									}
								</tbody>
							</table>
						</div>
						<nav class="admin-pagination" aria-label="Regions pages">
							<span class="muted">
								{regionsPag.page > 1 ? (
									<a href={queryLink({ page: String(regionsPag.page - 1) })}>← Previous</a>
								) : (
									<span style="opacity:0.55">← Previous</span>
								)}
								{' · '}
								{regionsPag.page < regionsPag.totalPages ? (
									<a href={queryLink({ page: String(regionsPag.page + 1) })}>Next →</a>
								) : (
									<span style="opacity:0.55">Next →</span>
								)}
							</span>
							<span class="muted">
								Page {regionsPag.page} / {regionsPag.totalPages}
							</span>
						</nav>
					</>
				)
			}
		</div>
	</section>
</AdminLayout>
