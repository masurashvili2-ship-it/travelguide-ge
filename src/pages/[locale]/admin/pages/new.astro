---
import AdminLayout from '../../../../components/admin/AdminLayout.astro';
import AdminPageLocalesFields from '../../../../components/admin/AdminPageLocalesFields.astro';
import { getRelativeLocaleUrl } from 'astro:i18n';
import type { Locale } from '../../../../lib/strings';

const loc = Astro.params.locale;
if (loc !== 'en' && loc !== 'ka' && loc !== 'ru') {
	return new Response(null, { status: 404 });
}
const locale = loc as Locale;

if (!Astro.locals.user || Astro.locals.user.role !== 'admin') {
	const login = getRelativeLocaleUrl(locale, 'login');
	const next = getRelativeLocaleUrl(locale, 'admin/pages/new');
	return Astro.redirect(`${login}?next=${encodeURIComponent(next)}`);
}

const pagesList = getRelativeLocaleUrl(locale, 'admin/pages');
const userEmail = Astro.locals.user.email;
---

<AdminLayout
	locale={locale}
	title="Add page ‹ Travel Guide Georgia"
	headline="Add new page"
	subtitle="Published at /{locale}/your-slug when at least one language has a title."
	activeNav="pages-new"
	userEmail={userEmail}
>
	<form method="post" action="/api/admin/pages">
		<input type="hidden" name="intent" value="create" />
		<input type="hidden" name="redirect" value={pagesList} />

		<div class="postbox">
			<div class="postbox__header">Page settings</div>
			<div class="postbox__inside">
				<div class="row">
					<label>
						<span>Slug (URL)</span>
						<input
							type="text"
							name="slug"
							required
							placeholder="e.g. about or privacy-policy"
							pattern="[a-z0-9]+(-[a-z0-9]+)*"
						/>
					</label>
					<p class="muted" style="margin:0.35rem 0 0">Lowercase Latin letters, numbers, hyphens. Cannot be admin, tours, login, etc.</p>
				</div>
				<div class="row">
					<label>
						<span>List order (admin)</span>
						<input type="number" name="sort_order" value="0" step="1" />
					</label>
					<p class="muted" style="margin:0.35rem 0 0">Lower numbers appear first in the Pages list in this admin.</p>
				</div>
			</div>
		</div>

		<div class="postbox">
			<div class="postbox__header">Content</div>
			<div class="postbox__inside">
				<AdminPageLocalesFields />
			</div>
		</div>

		<p class="submit">
			<button class="btn button-primary" type="submit">Publish</button>
			<a class="button" href={pagesList}>Cancel</a>
		</p>
	</form>
</AdminLayout>
