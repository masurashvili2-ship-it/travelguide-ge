---
import AdminLayout from '../../../../components/admin/AdminLayout.astro';
import { getRelativeLocaleUrl } from 'astro:i18n';
import { marked } from 'marked';
import type { Locale } from '../../../../lib/strings';
import { localeNames } from '../../../../lib/strings';
import {
	getFooterConfig,
	getFooterNavForLocale,
	getFooterBlurbMarkdown,
	getFooterExploreNavForLocale,
	getFooterCompanyNavForLocale,
	getFooterBrandLine,
	getFooterAboutMarkdown,
	getFooterExploreHeading,
	getFooterCompanyHeading,
	type FooterNavEntry,
} from '../../../../lib/footer-db';
import { ui } from '../../../../lib/strings';

const loc = Astro.params.locale;
if (loc !== 'en' && loc !== 'ka' && loc !== 'ru') {
	return new Response(null, { status: 404 });
}
const locale = loc as Locale;

if (!Astro.locals.user || Astro.locals.user.role !== 'admin') {
	const login = getRelativeLocaleUrl(locale, 'login');
	const next = getRelativeLocaleUrl(locale, 'admin/footer');
	return Astro.redirect(`${login}?next=${encodeURIComponent(next)}`);
}

const cfg = getFooterConfig();
const userEmail = Astro.locals.user.email;
const saved = Astro.url.searchParams.has('saved');

const previewLocales = ['en', 'ka', 'ru'] as const;
function previewNavHref(ploc: (typeof previewLocales)[number], e: FooterNavEntry): string {
	if (e.kind === 'external') return e.url;
	if (e.path === '') return getRelativeLocaleUrl(ploc, '/');
	return getRelativeLocaleUrl(ploc, e.path);
}

const previews = previewLocales.map((ploc) => {
	const nav = getFooterNavForLocale(ploc);
	const explore = getFooterExploreNavForLocale(ploc);
	const company = getFooterCompanyNavForLocale(ploc);
	const md = getFooterBlurbMarkdown(ploc);
	const h = md ? marked.parse(md, { async: false }) : '';
	const tu = ui[ploc];
	return {
		loc: ploc,
		name: localeNames[ploc],
		nav,
		explore,
		company,
		blurbHtml: typeof h === 'string' ? h : '',
		brandLine: getFooterBrandLine(ploc) ?? 'TRAVELGEORGIA.GE',
		aboutSnippet: getFooterAboutMarkdown(ploc).trim() || tu.footerAboutText,
		exploreH: getFooterExploreHeading(ploc) ?? tu.footerColExplore,
		companyH: getFooterCompanyHeading(ploc) ?? tu.footerColCompany,
	};
});
---

<AdminLayout
	locale={locale}
	title="Footer · Travel Guide Georgia"
	headline="Site footer"
	subtitle="Main footer columns, optional extra link row, and Markdown blurb — stored in data/footer.json."
	activeNav="footer"
	userEmail={userEmail}
>
	{
		saved ? (
			<div class="notice" style="border-left-color:#00a32a;background:#edfaef" role="status">
				Footer saved. Refresh the public site to see changes.
			</div>
		) : null
	}

	<section class="admin-card">
		<h2 class="admin-card__h">Live preview (by language)</h2>
		<div class="admin-card__bd">
			<p class="muted" style="margin:0 0 1rem">
				Saved content (reload after save). Titles fall back to another language if a translation is empty.
			</p>
			<div
				style="display:grid;grid-template-columns:repeat(auto-fit,minmax(220px,1fr));gap:1rem;align-items:start"
			>
				{
					previews.map((p) => (
						<div
							style="border:1px solid var(--border);border-radius:4px;padding:0.75rem;background:#fafafa;font-size:12px"
						>
							<p style="margin:0 0 0.5rem;font-weight:700">{p.name} ({p.loc})</p>
							<p style="margin:0;font-weight:800;font-size:13px">{p.brandLine}</p>
							<p class="muted" style="margin:0.35rem 0 0.65rem;line-height:1.35;font-size:11px">
								{p.aboutSnippet.length > 140 ? `${p.aboutSnippet.slice(0, 140)}…` : p.aboutSnippet}
							</p>
							<p style="margin:0;font-weight:700;font-size:11px">{p.exploreH}</p>
							<ul style="margin:0.2rem 0 0.6rem;padding-left:1.1rem">
								{p.explore.map((e) => (
									<li style="margin:0.15rem 0">
										<a href={previewNavHref(p.loc, e)}>{e.title}</a>
									</li>
								))}
							</ul>
							<p style="margin:0;font-weight:700;font-size:11px">{p.companyH}</p>
							<ul style="margin:0.2rem 0 0.6rem;padding-left:1.1rem">
								{p.company.map((e) => (
									<li style="margin:0.15rem 0">
										<a href={previewNavHref(p.loc, e)}>{e.title}</a>
									</li>
								))}
							</ul>
							{p.nav.length > 0 ? (
								<>
									<p style="margin:0.4rem 0 0.2rem;font-weight:700;font-size:11px">Extra links</p>
									<ul style="margin:0;padding-left:1.1rem">
										{p.nav.map((e) => (
											<li style="margin:0.15rem 0">
												<a href={previewNavHref(p.loc, e)}>{e.title}</a>
												<span class="muted" style="font-size:10px">
													{' '}
													({e.kind === 'internal' ? (e.path === '' ? 'home' : e.path) : 'ext'})
												</span>
											</li>
										))}
									</ul>
								</>
							) : null}
							{p.blurbHtml.trim() ? (
								<div
									class="footer-preview-blurb"
									style="margin-top:0.65rem;padding-top:0.5rem;border-top:1px dashed var(--border)"
									set:html={p.blurbHtml}
								/>
							) : null}
						</div>
					))
				}
			</div>
		</div>
	</section>

	<section class="admin-card">
		<h2 class="admin-card__h">Main footer — brand &amp; tagline</h2>
		<div class="admin-card__bd">
			<p class="muted" style="margin:0 0 1rem">
				Leave <strong>brand</strong> empty to keep <code>TRAVELGEORGIA.GE</code>. Leave <strong>tagline</strong> empty to use the built-in translation per language. Column headings empty → default “Explore” / “Company”.
			</p>
			<div class="row" style="display:grid;grid-template-columns:1fr 1fr 1fr;gap:0.75rem">
				<label><span>Brand EN</span><input type="text" id="brand-en" value={cfg.brand_title.en} placeholder="TRAVELGEORGIA.GE" /></label>
				<label><span>Brand KA</span><input type="text" id="brand-ka" value={cfg.brand_title.ka} /></label>
				<label><span>Brand RU</span><input type="text" id="brand-ru" value={cfg.brand_title.ru} /></label>
			</div>
			<div class="row" style="margin-top:0.75rem">
				<label><span>Tagline EN (Markdown ok)</span><textarea id="about-en" rows="3" style="font-family:ui-monospace,monospace;font-size:13px">{cfg.about_text.en}</textarea></label>
			</div>
			<div class="row">
				<label><span>Tagline KA</span><textarea id="about-ka" rows="3" style="font-family:ui-monospace,monospace;font-size:13px">{cfg.about_text.ka}</textarea></label>
			</div>
			<div class="row">
				<label><span>Tagline RU</span><textarea id="about-ru" rows="3" style="font-family:ui-monospace,monospace;font-size:13px">{cfg.about_text.ru}</textarea></label>
			</div>
			<div class="row" style="display:grid;grid-template-columns:1fr 1fr 1fr;gap:0.75rem;margin-top:0.75rem">
				<label><span>Explore heading EN</span><input type="text" id="exh-en" value={cfg.explore_heading.en} /></label>
				<label><span>Explore heading KA</span><input type="text" id="exh-ka" value={cfg.explore_heading.ka} /></label>
				<label><span>Explore heading RU</span><input type="text" id="exh-ru" value={cfg.explore_heading.ru} /></label>
			</div>
			<div class="row" style="display:grid;grid-template-columns:1fr 1fr 1fr;gap:0.75rem">
				<label><span>Company heading EN</span><input type="text" id="comh-en" value={cfg.company_heading.en} /></label>
				<label><span>Company heading KA</span><input type="text" id="comh-ka" value={cfg.company_heading.ka} /></label>
				<label><span>Company heading RU</span><input type="text" id="comh-ru" value={cfg.company_heading.ru} /></label>
			</div>
		</div>
	</section>

	<section class="admin-card">
		<h2 class="admin-card__h">Explore column links</h2>
		<div class="admin-card__bd">
			<p class="muted" style="margin:0 0 1rem">
				<strong>Leave this table empty</strong> to use the default list (Home, Tours, What to do, Regions, Map, Search). Internal path <strong>empty</strong> = site home.
			</p>
			<div class="admin-table-wrap">
				<table class="admin-table">
					<thead>
						<tr>
							<th style="width:4rem">Order</th>
							<th style="width:7rem">Type</th>
							<th>Internal path</th>
							<th>External URL</th>
							<th>Title EN</th>
							<th>Title KA</th>
							<th>Title RU</th>
							<th style="width:4rem"></th>
						</tr>
					</thead>
					<tbody id="footer-explore-rows">
						{cfg.explore_links
							.sort((a, b) => (a.order !== b.order ? a.order - b.order : a.id.localeCompare(b.id)))
							.map((link) => {
								const external = link.external_url ?? '';
								const kind = external ? 'external' : 'internal';
								const internal = kind === 'internal' ? (link.internal_path ?? '') : '';
								return (
									<tr data-footer-row="1" data-id={link.id}>
										<td>
											<input class="f-order" type="number" step="1" value={link.order} style="width:100%;max-width:4rem" />
										</td>
										<td>
											<select class="f-kind" value={kind}>
												<option value="internal">Internal</option>
												<option value="external">External</option>
											</select>
										</td>
										<td>
											<input class="f-internal" type="text" value={internal} placeholder="empty = home" autocomplete="off" />
										</td>
										<td>
											<input class="f-external" type="url" value={external} placeholder="https://…" autocomplete="off" />
										</td>
										<td><input class="f-te" type="text" value={link.title_en} /></td>
										<td><input class="f-tk" type="text" value={link.title_ka} /></td>
										<td><input class="f-tr" type="text" value={link.title_ru} /></td>
										<td>
											<button type="button" class="button js-remove-footer-row">Remove</button>
										</td>
									</tr>
								);
							})}
					</tbody>
				</table>
			</div>
			<p style="margin:1rem 0 0">
				<button type="button" class="button" id="footer-explore-add">Add Explore link</button>
			</p>
		</div>
	</section>

	<section class="admin-card">
		<h2 class="admin-card__h">Company column links</h2>
		<div class="admin-card__bd">
			<p class="muted" style="margin:0 0 1rem">
				<strong>Leave empty</strong> for defaults (Privacy, Contribute, Contact, Log in, Register).
			</p>
			<div class="admin-table-wrap">
				<table class="admin-table">
					<thead>
						<tr>
							<th style="width:4rem">Order</th>
							<th style="width:7rem">Type</th>
							<th>Internal path</th>
							<th>External URL</th>
							<th>Title EN</th>
							<th>Title KA</th>
							<th>Title RU</th>
							<th style="width:4rem"></th>
						</tr>
					</thead>
					<tbody id="footer-company-rows">
						{cfg.company_links
							.sort((a, b) => (a.order !== b.order ? a.order - b.order : a.id.localeCompare(b.id)))
							.map((link) => {
								const external = link.external_url ?? '';
								const kind = external ? 'external' : 'internal';
								const internal = kind === 'internal' ? (link.internal_path ?? '') : '';
								return (
									<tr data-footer-row="1" data-id={link.id}>
										<td>
											<input class="f-order" type="number" step="1" value={link.order} style="width:100%;max-width:4rem" />
										</td>
										<td>
											<select class="f-kind" value={kind}>
												<option value="internal">Internal</option>
												<option value="external">External</option>
											</select>
										</td>
										<td>
											<input class="f-internal" type="text" value={internal} placeholder="policy, contact, …" autocomplete="off" />
										</td>
										<td>
											<input class="f-external" type="url" value={external} placeholder="https://…" autocomplete="off" />
										</td>
										<td><input class="f-te" type="text" value={link.title_en} /></td>
										<td><input class="f-tk" type="text" value={link.title_ka} /></td>
										<td><input class="f-tr" type="text" value={link.title_ru} /></td>
										<td>
											<button type="button" class="button js-remove-footer-row">Remove</button>
										</td>
									</tr>
								);
							})}
					</tbody>
				</table>
			</div>
			<p style="margin:1rem 0 0">
				<button type="button" class="button" id="footer-company-add">Add Company link</button>
			</p>
		</div>
	</section>

	<section class="admin-card">
		<h2 class="admin-card__h">Extra footer links</h2>
		<div class="admin-card__bd">
			<p class="muted" style="margin:0 0 1rem">
				Optional row <strong>below</strong> the three columns. <strong>Internal</strong> paths are relative to the language prefix (e.g. <code>about</code> → <code>/en/about</code>). <strong>External</strong> uses a full URL or <code>mailto:…</code>. Internal path <strong>empty</strong> = home.
			</p>
			<div class="admin-table-wrap">
				<table class="admin-table">
					<thead>
						<tr>
							<th style="width:4rem">Order</th>
							<th style="width:7rem">Type</th>
							<th>Internal path</th>
							<th>External URL</th>
							<th>Title EN</th>
							<th>Title KA</th>
							<th>Title RU</th>
							<th style="width:4rem"></th>
						</tr>
					</thead>
					<tbody id="footer-rows">
						{
							cfg.links
								.sort((a, b) => (a.order !== b.order ? a.order - b.order : a.id.localeCompare(b.id)))
								.map((link) => {
									const external = link.external_url ?? '';
									const kind = external ? 'external' : 'internal';
									const internal = kind === 'internal' ? (link.internal_path ?? '') : '';
									return (
										<tr data-footer-row="1" data-id={link.id}>
											<td>
												<input
													class="f-order"
													type="number"
													step="1"
													value={link.order}
													style="width:100%;max-width:4rem"
												/>
											</td>
											<td>
												<select class="f-kind" value={kind}>
													<option value="internal">Internal</option>
													<option value="external">External</option>
												</select>
											</td>
											<td>
												<input
													class="f-internal"
													type="text"
													value={internal}
													placeholder="empty = home, or about, tours/slug…"
													autocomplete="off"
												/>
											</td>
											<td>
												<input
													class="f-external"
													type="url"
													value={external}
													placeholder="https://…"
													autocomplete="off"
												/>
											</td>
											<td>
												<input class="f-te" type="text" value={link.title_en} />
											</td>
											<td>
												<input class="f-tk" type="text" value={link.title_ka} />
											</td>
											<td>
												<input class="f-tr" type="text" value={link.title_ru} />
											</td>
											<td>
												<button type="button" class="button js-remove-footer-row">
													Remove
												</button>
											</td>
										</tr>
									);
								})
						}
					</tbody>
				</table>
			</div>
			<p style="margin:1rem 0 0">
				<button type="button" class="button" id="footer-add-row">Add link</button>
			</p>
		</div>
	</section>

	<template id="footer-row-tpl">
		<tr data-footer-row="1" data-id="">
			<td>
				<input class="f-order" type="number" step="1" value="0" style="width:100%;max-width:4rem" />
			</td>
			<td>
				<select class="f-kind">
					<option value="internal">Internal</option>
					<option value="external">External</option>
				</select>
			</td>
			<td>
				<input class="f-internal" type="text" value="" placeholder="about or tours/slug" autocomplete="off" />
			</td>
			<td>
				<input class="f-external" type="url" value="" placeholder="https://…" autocomplete="off" />
			</td>
			<td>
				<input class="f-te" type="text" value="" />
			</td>
			<td>
				<input class="f-tk" type="text" value="" />
			</td>
			<td>
				<input class="f-tr" type="text" value="" />
			</td>
			<td>
				<button type="button" class="button js-remove-footer-row">Remove</button>
			</td>
		</tr>
	</template>

	<section class="admin-card">
		<h2 class="admin-card__h">Footer text (Markdown, optional)</h2>
		<div class="admin-card__bd">
			<p class="muted" style="margin:0 0 1rem">
				Shown under the link row and above the copyright on all public pages. Safe HTML is generated from Markdown.
			</p>
			<div class="row">
				<label>
					<span>English</span>
					<textarea id="blurb-en" rows="4" style="font-family:ui-monospace,monospace;font-size:13px">
						{cfg.blurb.en}
					</textarea>
				</label>
			</div>
			<div class="row">
				<label>
					<span>Georgian</span>
					<textarea id="blurb-ka" rows="4" style="font-family:ui-monospace,monospace;font-size:13px">
						{cfg.blurb.ka}
					</textarea>
				</label>
			</div>
			<div class="row">
				<label>
					<span>Russian</span>
					<textarea id="blurb-ru" rows="4" style="font-family:ui-monospace,monospace;font-size:13px">
						{cfg.blurb.ru}
					</textarea>
				</label>
			</div>
			<p style="margin:1rem 0 0">
				<button type="button" class="button button-primary" id="footer-save">
					Save entire footer
				</button>
			</p>
		</div>
	</section>
</AdminLayout>

<script is:inline>
	document.addEventListener('DOMContentLoaded', function () {
		var tpl = document.getElementById('footer-row-tpl');
		var tbodyExtra = document.getElementById('footer-rows');
		var tbodyExplore = document.getElementById('footer-explore-rows');
		var tbodyCompany = document.getElementById('footer-company-rows');
		var addExtra = document.getElementById('footer-add-row');
		var addExplore = document.getElementById('footer-explore-add');
		var addCompany = document.getElementById('footer-company-add');
		var saveBtn = document.getElementById('footer-save');
		if (!tpl || !tbodyExtra || !saveBtn) return;

		function bindRemove(btn, hostTbody) {
			btn.addEventListener('click', function () {
				var tr = btn.closest('tr');
				if (!tr || !hostTbody.contains(tr)) return;
				tr.remove();
			});
		}

		function wireRemoves(host) {
			host.querySelectorAll('.js-remove-footer-row').forEach(function (b) {
				bindRemove(b, host);
			});
		}

		wireRemoves(tbodyExtra);
		if (tbodyExplore) wireRemoves(tbodyExplore);
		if (tbodyCompany) wireRemoves(tbodyCompany);

		function addRow(host) {
			if (!host) return;
			var node = tpl.content.cloneNode(true);
			var rows = host.querySelectorAll('tr[data-footer-row]');
			var orderInput = node.querySelector('.f-order');
			if (orderInput) orderInput.value = String(rows.length);
			host.appendChild(node);
			var last = host.querySelector('tr[data-footer-row]:last-child .js-remove-footer-row');
			if (last) bindRemove(last, host);
		}

		if (addExtra) addExtra.addEventListener('click', function () { addRow(tbodyExtra); });
		if (addExplore) addExplore.addEventListener('click', function () { addRow(tbodyExplore); });
		if (addCompany) addCompany.addEventListener('click', function () { addRow(tbodyCompany); });

		function collectLinks(host) {
			if (!host) return [];
			var rows = host.querySelectorAll('tr[data-footer-row]');
			var links = [];
			for (var i = 0; i < rows.length; i++) {
				var tr = rows[i];
				var id = tr.getAttribute('data-id') || '';
				var orderRaw = tr.querySelector('.f-order');
				var order = parseInt(orderRaw && orderRaw.value, 10);
				if (!Number.isFinite(order)) order = i;
				var kindEl = tr.querySelector('.f-kind');
				var kind = kindEl && kindEl.value === 'external' ? 'external' : 'internal';
				var internal = (tr.querySelector('.f-internal') && tr.querySelector('.f-internal').value.trim()) || '';
				var external = (tr.querySelector('.f-external') && tr.querySelector('.f-external').value.trim()) || '';
				links.push({
					id: id || undefined,
					order: order,
					internal_path: kind === 'internal' ? internal : null,
					external_url: kind === 'external' ? external || null : null,
					title_en: (tr.querySelector('.f-te') && tr.querySelector('.f-te').value.trim()) || '',
					title_ka: (tr.querySelector('.f-tk') && tr.querySelector('.f-tk').value.trim()) || '',
					title_ru: (tr.querySelector('.f-tr') && tr.querySelector('.f-tr').value.trim()) || '',
				});
			}
			return links;
		}

		saveBtn.addEventListener('click', async function () {
			var payload = {
				brand_title: {
					en: (document.getElementById('brand-en') && document.getElementById('brand-en').value) || '',
					ka: (document.getElementById('brand-ka') && document.getElementById('brand-ka').value) || '',
					ru: (document.getElementById('brand-ru') && document.getElementById('brand-ru').value) || '',
				},
				about_text: {
					en: (document.getElementById('about-en') && document.getElementById('about-en').value) || '',
					ka: (document.getElementById('about-ka') && document.getElementById('about-ka').value) || '',
					ru: (document.getElementById('about-ru') && document.getElementById('about-ru').value) || '',
				},
				explore_heading: {
					en: (document.getElementById('exh-en') && document.getElementById('exh-en').value) || '',
					ka: (document.getElementById('exh-ka') && document.getElementById('exh-ka').value) || '',
					ru: (document.getElementById('exh-ru') && document.getElementById('exh-ru').value) || '',
				},
				company_heading: {
					en: (document.getElementById('comh-en') && document.getElementById('comh-en').value) || '',
					ka: (document.getElementById('comh-ka') && document.getElementById('comh-ka').value) || '',
					ru: (document.getElementById('comh-ru') && document.getElementById('comh-ru').value) || '',
				},
				explore_links: collectLinks(tbodyExplore),
				company_links: collectLinks(tbodyCompany),
				links: collectLinks(tbodyExtra),
				blurb: {
					en: (document.getElementById('blurb-en') && document.getElementById('blurb-en').value) || '',
					ka: (document.getElementById('blurb-ka') && document.getElementById('blurb-ka').value) || '',
					ru: (document.getElementById('blurb-ru') && document.getElementById('blurb-ru').value) || '',
				},
			};
			try {
				var res = await fetch('/api/admin/footer', {
					method: 'POST',
					headers: { 'Content-Type': 'application/json' },
					credentials: 'same-origin',
					body: JSON.stringify(payload),
				});
				var data = {};
				try {
					data = await res.json();
				} catch (e) {}
				if (!res.ok) {
					alert(data.error || 'Save failed');
					return;
				}
				window.location.href = window.location.pathname + '?saved=1';
			} catch (err) {
				alert(err.message || 'Save failed');
			}
		});
	});
</script>
