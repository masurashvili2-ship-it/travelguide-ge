---
import Shell from '../../../../../components/Shell.astro';
import TourDetailHeroGallery from '../../../../../components/TourDetailHeroGallery.astro';
import { getRelativeLocaleUrl } from 'astro:i18n';
import { marked } from 'marked';
import { buildTourJsonLd, resolveTourMetaDescription, absoluteSeoUrl } from '../../../../../lib/seo';
import {
	pagePayloadToSyntheticPagePost,
	tourLikePayloadToSyntheticTourPost,
} from '../../../../../lib/contribute-synthetic-post';
import WhatToDoContactAsideCard from '../../../../../components/WhatToDoContactAsideCard.astro';
import { hasRenderableContactSocialLinks } from '../../../../../lib/contact-social-links';
import { googleDirectionsUrlFromCoords } from '../../../../../lib/google-maps-urls';
import {
	flattenTourPostToRow,
	tourCoverImageUrl,
	type TourPost,
	type TourRow,
} from '../../../../../lib/tours-db';
import {
	getSubmissionById,
	type PageSubmissionPayload,
	type TourLikeSubmissionPayload,
} from '../../../../../lib/submissions-db';
import type { Locale } from '../../../../../lib/strings';
import { ui } from '../../../../../lib/strings';
import type { PageLocaleBlock } from '../../../../../lib/pages-db';

const LOCALE_ORDER: Locale[] = ['en', 'ka', 'ru'];

const loc = Astro.params.locale;
const idParam = Astro.params.id;
if (loc !== 'en' && loc !== 'ka' && loc !== 'ru' || !idParam) {
	return new Response(null, { status: 404 });
}
const locale = loc as Locale;

if (!Astro.locals.user || Astro.locals.user.role !== 'admin') {
	const login = getRelativeLocaleUrl(locale, 'login');
	const next = getRelativeLocaleUrl(locale, `admin/submissions/preview/${idParam}`);
	return Astro.redirect(`${login}?next=${encodeURIComponent(next)}`);
}

const sub = getSubmissionById(idParam);
if (!sub || sub.status !== 'pending') {
	return new Response(null, { status: 404 });
}

const approvalsHref = getRelativeLocaleUrl(locale, 'admin/submissions');
const previewBase = getRelativeLocaleUrl(locale, `admin/submissions/preview/${sub.id}`);

const qp = Astro.url.searchParams.get('locale');
let previewLocale: Locale = locale;
if (qp === 'en' || qp === 'ka' || qp === 'ru') {
	previewLocale = qp;
}

const tp = ui[previewLocale];

type PreviewPage = {
	kind: 'page';
	block: PageLocaleBlock;
	pageHtml: string;
	seoTitle: string;
	seoDescription: string | undefined;
	canonicalPath: string;
};

type PreviewTour = {
	kind: 'tour';
	row: TourRow;
	bodyHtml: string;
	contactHtml: string;
	hasWtdContactAside: boolean;
	metaDescription: string;
	canonicalPath: string;
	pageUrl: string;
	coverUrl: string | undefined;
	heroGalleryImages: string[];
	jsonLd: Record<string, unknown>;
	locationLine: string | null;
	directionsHref: string | null;
	mapPageHref: string;
	listHref: string;
	listLabel: string;
};

let preview: PreviewPage | PreviewTour;

if (sub.kind === 'page') {
	const payload = sub.payload as PageSubmissionPayload;
	const synthetic = pagePayloadToSyntheticPagePost(sub.id, payload);
	let block = synthetic.i18n[previewLocale];
	if (!block?.title?.trim()) {
		let found: Locale | null = null;
		for (const L of LOCALE_ORDER) {
			const b = synthetic.i18n[L];
			if (b?.title?.trim()) {
				found = L;
				break;
			}
		}
		if (!found) {
			return new Response('This proposal has no page title in any language yet.', {
				status: 400,
				headers: { 'Content-Type': 'text/plain; charset=utf-8' },
			});
		}
		return Astro.redirect(`${previewBase}?locale=${found}`);
	}
	block = synthetic.i18n[previewLocale]!;

	const htmlRaw = marked.parse(block.body, { async: false });
	const pageHtml = typeof htmlRaw === 'string' ? htmlRaw : await htmlRaw;
	const seoTitle = block.seo_title?.trim() || block.title;
	const seoDescription = block.seo_description?.trim() || undefined;
	const canonicalPath = `/${previewLocale}/${synthetic.slug}`;
	preview = {
		kind: 'page',
		block,
		pageHtml,
		seoTitle,
		seoDescription,
		canonicalPath,
	};
} else if (sub.kind === 'what-to-do') {
	const payload = sub.payload as TourLikeSubmissionPayload;
	let synthetic: TourPost = tourLikePayloadToSyntheticTourPost(sub.id, payload);
	synthetic = {
		...synthetic,
		author_user_id: sub.author_user_id,
		author_email: sub.author_email,
	};

	let row = flattenTourPostToRow(synthetic, previewLocale);
	if (!row) {
		let found: Locale | null = null;
		for (const L of LOCALE_ORDER) {
			if (flattenTourPostToRow(synthetic, L)) {
				found = L;
				break;
			}
		}
		if (!found) {
			return new Response(
				'This proposal has no filled language block yet (need title, duration, excerpt in one language).',
				{
					status: 400,
					headers: { 'Content-Type': 'text/plain; charset=utf-8' },
				},
			);
		}
		return Astro.redirect(`${previewBase}?locale=${found}`);
	}
	row = flattenTourPostToRow(synthetic, previewLocale)!;

	const htmlRaw = marked.parse(row.body, { async: false });
	const bodyHtml = typeof htmlRaw === 'string' ? htmlRaw : await htmlRaw;

	const contactMd = row.contact_sidebar.trim();
	let contactHtml = '';
	if (contactMd) {
		const contactRaw = marked.parse(contactMd, { async: false });
		contactHtml = typeof contactRaw === 'string' ? contactRaw : await contactRaw;
	}
	const hasWtdContactAside =
		Boolean(contactHtml.trim()) || hasRenderableContactSocialLinks(row.social_links);

	const metaDescription = resolveTourMetaDescription(row.seo_description, row.excerpt, row.body);
	const slug = row.slug;
	const pathSeg = `what-to-do/${slug}`;
	const canonicalPath = `/${previewLocale}/${pathSeg}`;
	const site = Astro.site;
	const pageUrl = site ? new URL(canonicalPath, site).href : Astro.url.href;
	const siteOrigin = site?.origin ?? Astro.url.origin;
	const coverUrl = tourCoverImageUrl({ image: row.image, gallery: row.gallery });
	const imageAbs = absoluteSeoUrl(coverUrl, site);
	const heroGalleryImages: string[] = [];
	const seenUrls = new Set<string>();
	for (const g of row.gallery) {
		const s = typeof g === 'string' ? g.trim() : '';
		if (!s || seenUrls.has(s)) continue;
		seenUrls.add(s);
		heroGalleryImages.push(s);
	}
	const jsonLd = buildTourJsonLd({
		title: row.title,
		description: metaDescription,
		pageUrl,
		siteOrigin,
		imageUrl: imageAbs ?? undefined,
		locale: row.locale,
		priceText: row.price,
		updatedAt: row.updated_at,
	});

	const mapPageHref = getRelativeLocaleUrl(previewLocale, 'map');
	const locationLine =
		row.location == null
			? null
			: row.location.label?.trim()
				? row.location.label.trim()
				: `${row.location.lat.toFixed(4)}, ${row.location.lng.toFixed(4)}`;

	const directionsHref =
		row.google_directions_url?.trim() ||
		(row.location ? googleDirectionsUrlFromCoords(row.location.lat, row.location.lng) : null);

	const listHref = getRelativeLocaleUrl(previewLocale, 'what-to-do');
	const listLabel = tp.whatToDo;

	preview = {
		kind: 'tour',
		row,
		bodyHtml,
		contactHtml,
		hasWtdContactAside,
		metaDescription,
		canonicalPath,
		pageUrl,
		coverUrl,
		heroGalleryImages,
		jsonLd,
		locationLine,
		directionsHref,
		mapPageHref,
		listHref,
		listLabel,
	};
} else {
	return new Response(null, { status: 404 });
}
---

{
	preview.kind === 'page' ? (
		<Shell
			locale={previewLocale}
			subpath={`admin/submissions/preview/${sub.id}`}
			title={`Preview: ${preview.block.title}`}
			seoTitle={`Preview: ${preview.seoTitle}`}
			seoDescription={preview.seoDescription}
			canonicalPath={preview.canonicalPath}
			robotsNoindex={true}
		>
			<div
				class="notice notice-info"
				style="margin:0 0 1rem;padding:0.75rem 1rem;border-radius:8px;font-size:0.95rem"
				role="status"
			>
				<strong>Preview</strong> — this page is not published. Submitted by {sub.author_email}.
				<span style="display:block;margin-top:0.5rem">
					<a href={approvalsHref}>← Back to Approvals</a>
					{' · '}
					Locale:
					{LOCALE_ORDER.map((L, i) => (
						<>
							{i > 0 ? ' · ' : null}
							{L === previewLocale ? (
								<strong>{L.toUpperCase()}</strong>
							) : (
								<a href={`${previewBase}?locale=${L}`}>{L.toUpperCase()}</a>
							)}
						</>
					))}
				</span>
			</div>
			<article class="prose">
				<p class="muted" style="margin:0 0 1rem">
					<a href={getRelativeLocaleUrl(previewLocale, '/')}>{tp.home}</a>
					{' / '}
					<span>{preview.block.title}</span>
				</p>
				<h1>{preview.block.title}</h1>
				<div set:html={preview.pageHtml} />
			</article>
		</Shell>
	) : (
		<Shell
			locale={previewLocale}
			subpath={`admin/submissions/preview/${sub.id}`}
			title={`Preview: ${preview.row.title}`}
			seoTitle={`Preview: ${preview.row.title}`}
			seoDescription={preview.metaDescription}
			canonicalPath={preview.canonicalPath}
			seoImage={preview.coverUrl ?? null}
			ogType="article"
			jsonLd={preview.jsonLd}
			robotsNoindex={true}
		>
			<div
				class="notice notice-info"
				style="margin:0 0 1rem;padding:0.75rem 1rem;border-radius:8px;font-size:0.95rem"
				role="status"
			>
				<strong>Preview</strong> — not published. Submitted by {sub.author_email}.
				<span style="display:block;margin-top:0.5rem">
					<a href={approvalsHref}>← Back to Approvals</a>
					{' · '}
					Locale:
					{LOCALE_ORDER.map((L, i) => (
						<>
							{i > 0 ? ' · ' : null}
							{L === previewLocale ? (
								<strong>{L.toUpperCase()}</strong>
							) : (
								<a href={`${previewBase}?locale=${L}`}>{L.toUpperCase()}</a>
							)}
						</>
					))}
				</span>
			</div>

			<p class="muted" style="margin:0 0 1rem">
				<a href={preview.listHref}>{preview.listLabel}</a>
				<span aria-hidden="true"> / </span>
				<span>{preview.row.title}</span>
			</p>
			<TourDetailHeroGallery
				slug={preview.row.slug}
				locale={previewLocale}
				title={preview.row.title}
				duration={preview.row.duration}
				price={preview.row.price}
				excerpt={preview.row.excerpt}
				images={preview.heroGalleryImages}
				adminEditHref={null}
				shareUrl={preview.pageUrl}
			/>
			<div class="tour-detail-layout" data-tour-detail>
				<div class="tour-detail-main">
					<div class="prose" set:html={preview.bodyHtml} />
				</div>
				<aside
					class="tour-detail-aside"
					aria-label={`${tp.tourSidebarSectionTitle}${preview.hasWtdContactAside ? ` · ${tp.whatToDoContactAsideTitle}` : ''}`}
				>
					<div class="tour-detail-aside__stack">
						<div class="tour-detail-aside__card">
							<h2 class="tour-detail-aside__title" id="wtd-aside-summary">
								{tp.tourSidebarSectionTitle}
							</h2>
							<dl class="tour-detail-aside__dl" aria-labelledby="wtd-aside-summary">
								{preview.row.whatDoCategories.length > 0 ? (
									<div class="tour-detail-aside__row">
										<dt class="tour-detail-aside__dt">{tp.tourSidebarCategory}</dt>
										<dd class="tour-detail-aside__dd">
											{preview.row.whatDoCategories.map((id) => tp.whatToDoCategories[id]).join(', ')}
										</dd>
									</div>
								) : null}
								{preview.row.whatDoSeasons.length > 0 ? (
									<div class="tour-detail-aside__row">
										<dt class="tour-detail-aside__dt">{tp.tourSidebarSeason}</dt>
										<dd class="tour-detail-aside__dd">
											{preview.row.whatDoSeasons.map((id) => tp.whatToDoSeasons[id]).join(', ')}
										</dd>
									</div>
								) : null}
								{preview.row.physical_rating ? (
									<div class="tour-detail-aside__row">
										<dt class="tour-detail-aside__dt">{tp.tourSidebarPhysicalRating}</dt>
										<dd class="tour-detail-aside__dd">{tp.tourPhysicalRatings[preview.row.physical_rating]}</dd>
									</div>
								) : null}
								<div class="tour-detail-aside__row">
									<dt class="tour-detail-aside__dt">{tp.duration}</dt>
									<dd class="tour-detail-aside__dd">{preview.row.duration}</dd>
								</div>
								{preview.row.price ? (
									<div class="tour-detail-aside__row">
										<dt class="tour-detail-aside__dt">{tp.tourSidebarPriceLabel}</dt>
										<dd class="tour-detail-aside__dd">{preview.row.price}</dd>
									</div>
								) : null}
								{preview.row.driving_distance ? (
									<div class="tour-detail-aside__row">
										<dt class="tour-detail-aside__dt">{tp.tourSidebarDrivingDistance}</dt>
										<dd class="tour-detail-aside__dd">{preview.row.driving_distance}</dd>
									</div>
								) : null}
								{preview.locationLine ? (
									<div class="tour-detail-aside__row">
										<dt class="tour-detail-aside__dt">{tp.tourSidebarLocationLabel}</dt>
										<dd class="tour-detail-aside__dd">
											{preview.locationLine}
											<br />
											<a class="tour-detail-aside__map-link" href={preview.mapPageHref}>
												{tp.tourSidebarViewOnMap}
											</a>
										</dd>
									</div>
								) : null}
								{preview.directionsHref ? (
									<div class="tour-detail-aside__row">
										<dt class="tour-detail-aside__dt">{tp.tourSidebarDirections}</dt>
										<dd class="tour-detail-aside__dd">
											<a
												class="tour-detail-aside__map-link"
												href={preview.directionsHref}
												target="_blank"
												rel="noopener noreferrer"
											>
												{tp.tourSidebarGetDirections}
											</a>
										</dd>
									</div>
								) : null}
							</dl>
						</div>
						<WhatToDoContactAsideCard
							title={tp.whatToDoContactAsideTitle}
							contactHtml={preview.contactHtml}
							socialLinks={preview.row.social_links}
						/>
					</div>
				</aside>
			</div>
		</Shell>
	)
}

<style is:global>
	[data-tour-detail].tour-detail-layout {
		display: grid;
		gap: 1.75rem;
		align-items: start;
		margin-top: 0.5rem;
		width: 100%;
	}
	@media (max-width: 899px) {
		[data-tour-detail] .tour-detail-aside {
			order: 1;
		}
		[data-tour-detail] .tour-detail-main {
			order: 2;
		}
	}
	@media (min-width: 900px) {
		[data-tour-detail].tour-detail-layout {
			grid-template-columns: minmax(0, 1fr) min(280px, 34%);
			gap: 2rem;
		}
		[data-tour-detail] .tour-detail-main {
			order: 1;
		}
		[data-tour-detail] .tour-detail-aside {
			order: 2;
			position: sticky;
			top: 1rem;
			align-self: start;
		}
	}
	[data-tour-detail] .tour-detail-main {
		min-width: 0;
	}
	[data-tour-detail] .tour-detail-aside {
		min-width: 0;
		width: 100%;
	}
	[data-tour-detail] .tour-detail-aside__stack {
		display: flex;
		flex-direction: column;
		gap: 1rem;
	}
	[data-tour-detail] .tour-detail-aside__card {
		background: var(--surface);
		border: 1px solid var(--border);
		border-radius: 10px;
		padding: 1.1rem 1.2rem;
		box-shadow: 0 2px 10px rgba(26, 35, 50, 0.08);
	}
	[data-tour-detail] .tour-detail-aside__title {
		margin: 0 0 1rem;
		font-size: 1.05rem;
		font-weight: 700;
		color: var(--text);
		line-height: 1.25;
	}
	[data-tour-detail] .tour-detail-aside__dl {
		margin: 0;
		display: flex;
		flex-direction: column;
		gap: 1rem;
	}
	[data-tour-detail] .tour-detail-aside__row {
		display: grid;
		gap: 0.25rem;
	}
	[data-tour-detail] .tour-detail-aside__dt {
		margin: 0;
		font-size: 0.78rem;
		font-weight: 600;
		letter-spacing: 0.05em;
		text-transform: uppercase;
		color: var(--muted);
	}
	[data-tour-detail] .tour-detail-aside__dd {
		margin: 0;
		font-size: 1rem;
		font-weight: 600;
		color: var(--text);
		line-height: 1.45;
	}
	[data-tour-detail] .tour-detail-aside__map-link {
		display: inline-block;
		margin-top: 0.35rem;
		font-size: 0.92rem;
		font-weight: 600;
	}
	[data-tour-detail] .tour-detail-aside__contact-prose {
		font-size: 0.94rem;
		line-height: 1.55;
	}
	[data-tour-detail] .tour-detail-aside__contact-prose :where(p) {
		margin: 0.5rem 0;
	}
	[data-tour-detail] .tour-detail-aside__contact-prose :where(p:first-child) {
		margin-top: 0;
	}
	[data-tour-detail] .tour-detail-aside__contact-prose :where(p:last-child) {
		margin-bottom: 0;
	}
	[data-tour-detail] .tour-detail-aside__contact-prose :where(a) {
		word-break: break-word;
	}
</style>
