---
import AdminLayout from '../../../../components/admin/AdminLayout.astro';
import { getRelativeLocaleUrl } from 'astro:i18n';
import type { Locale } from '../../../../lib/strings';
import { getPaymentSettings } from '../../../../lib/payment-settings-db';

const loc = Astro.params.locale;
if (loc !== 'en' && loc !== 'ka' && loc !== 'ru') return new Response(null, { status: 404 });
const locale = loc as Locale;

if (!Astro.locals.user || Astro.locals.user.role !== 'admin') {
	const login = getRelativeLocaleUrl(locale, 'login');
	const next = getRelativeLocaleUrl(locale, 'admin/payment-settings');
	return Astro.redirect(`${login}?next=${encodeURIComponent(next)}`);
}

const settings = getPaymentSettings();
const maskedSecret = settings.paypal.client_secret ? '••••••••' : '';
---

<AdminLayout
	locale={locale}
	title="Payment Settings · Admin"
	headline="Payment Settings"
	subtitle="Configure PayPal, cash payments, and deposit options."
	activeNav="payment-settings"
	userEmail={Astro.locals.user.email}
>
	<div id="ps-notice"></div>

	<section class="admin-card">
		<h2 class="admin-card__h">PayPal</h2>
		<div class="admin-card__bd">
			<form id="paypal-form" class="admin-form">
				<div class="admin-form__row">
					<label class="admin-form__label">
						<input type="checkbox" id="pp-enabled" name="pp_enabled" checked={settings.paypal.enabled} />
						Enable PayPal payments
					</label>
				</div>

				<div class="admin-form__row">
					<label class="admin-form__label" for="pp-mode">Mode</label>
					<select id="pp-mode" name="pp_mode" class="admin-form__input">
						<option value="sandbox" selected={settings.paypal.mode === 'sandbox'}>Sandbox (testing)</option>
						<option value="live" selected={settings.paypal.mode === 'live'}>Live (production)</option>
					</select>
					<p class="admin-form__help">Use sandbox while testing. Switch to live when ready to accept real payments.</p>
				</div>

				<div class="admin-form__row">
					<label class="admin-form__label" for="pp-client-id">Client ID</label>
					<input
						type="text"
						id="pp-client-id"
						name="pp_client_id"
						class="admin-form__input"
						value={settings.paypal.client_id}
						placeholder="AaBbCc..."
						autocomplete="off"
					/>
					<p class="admin-form__help">From your PayPal Developer dashboard → My Apps &amp; Credentials.</p>
				</div>

				<div class="admin-form__row">
					<label class="admin-form__label" for="pp-secret">Client Secret</label>
					<input
						type="password"
						id="pp-secret"
						name="pp_secret"
						class="admin-form__input"
						value={maskedSecret}
						placeholder="Secret key"
						autocomplete="new-password"
					/>
					<p class="admin-form__help">Leave unchanged (shows ••••••••) to keep existing secret.</p>
				</div>

				<div class="admin-form__row">
					<label class="admin-form__label" for="pp-deposit">Deposit percentage (%)</label>
					<input
						type="number"
						id="pp-deposit"
						name="pp_deposit"
						class="admin-form__input"
						style="max-width:120px"
						min="1"
						max="99"
						value={settings.paypal.deposit_pct}
					/>
					<p class="admin-form__help">
						Percentage of the total price charged as deposit (e.g. 30 = 30%). The rest is paid by the
						customer on tour day.
					</p>
				</div>

				<div class="admin-form__row">
					<button type="submit" class="button button-primary">Save PayPal settings</button>
				</div>
			</form>
		</div>
	</section>

	<section class="admin-card">
		<h2 class="admin-card__h">Cash payments</h2>
		<div class="admin-card__bd">
			<form id="cash-form" class="admin-form">
				<div class="admin-form__row">
					<label class="admin-form__label">
						<input type="checkbox" id="cash-enabled" name="cash_enabled" checked={settings.cash.enabled} />
						Enable "Pay in cash" option at checkout
					</label>
				</div>

				<div class="admin-form__row">
					<label class="admin-form__label" for="cash-instructions">Instructions shown to customer</label>
					<textarea
						id="cash-instructions"
						name="cash_instructions"
						class="admin-form__input"
						rows="3"
					>{settings.cash.instructions}</textarea>
				</div>

				<div class="admin-form__row">
					<button type="submit" class="button button-primary">Save cash settings</button>
				</div>
			</form>
		</div>
	</section>

	<section class="admin-card">
		<h2 class="admin-card__h">How to set up PayPal</h2>
		<div class="admin-card__bd">
			<ol style="margin:0;padding-left:1.25rem;line-height:1.8">
				<li>Go to <a href="https://developer.paypal.com/developer/applications/" target="_blank" rel="noopener">developer.paypal.com</a> and log in.</li>
				<li>Under <strong>My Apps &amp; Credentials</strong>, create a new app (or use existing).</li>
				<li>Copy the <strong>Client ID</strong> and <strong>Secret</strong> for the environment you want (Sandbox or Live).</li>
				<li>Paste them above, select the matching mode, and save.</li>
				<li>Test with PayPal sandbox accounts before switching to live.</li>
			</ol>
		</div>
	</section>
</AdminLayout>

<script>
function showNotice(msg: string, ok: boolean) {
	const el = document.getElementById('ps-notice')!;
	el.innerHTML = `<div class="notice ${ok ? 'notice-success' : 'notice-error'}">${msg}</div>`;
	setTimeout(() => (el.innerHTML = ''), 4000);
}

async function savePayPal(e: SubmitEvent) {
	e.preventDefault();
	const enabled = (document.getElementById('pp-enabled') as HTMLInputElement).checked;
	const mode = (document.getElementById('pp-mode') as HTMLSelectElement).value;
	const clientId = (document.getElementById('pp-client-id') as HTMLInputElement).value.trim();
	const secret = (document.getElementById('pp-secret') as HTMLInputElement).value;
	const depositPct = parseInt((document.getElementById('pp-deposit') as HTMLInputElement).value, 10);

	const res = await fetch('/api/admin/payment-settings', {
		method: 'POST',
		headers: { 'Content-Type': 'application/json' },
		body: JSON.stringify({
			paypal: {
				enabled,
				mode,
				client_id: clientId,
				client_secret: secret,
				deposit_pct: isNaN(depositPct) ? 30 : depositPct,
			},
		}),
	});
	const data = await res.json();
	if (data.ok) showNotice('PayPal settings saved.', true);
	else showNotice(data.error ?? 'Error saving.', false);
}

async function saveCash(e: SubmitEvent) {
	e.preventDefault();
	const enabled = (document.getElementById('cash-enabled') as HTMLInputElement).checked;
	const instructions = (document.getElementById('cash-instructions') as HTMLTextAreaElement).value.trim();

	const res = await fetch('/api/admin/payment-settings', {
		method: 'POST',
		headers: { 'Content-Type': 'application/json' },
		body: JSON.stringify({ cash: { enabled, instructions } }),
	});
	const data = await res.json();
	if (data.ok) showNotice('Cash settings saved.', true);
	else showNotice(data.error ?? 'Error saving.', false);
}

document.getElementById('paypal-form')?.addEventListener('submit', savePayPal);
document.getElementById('cash-form')?.addEventListener('submit', saveCash);
</script>
