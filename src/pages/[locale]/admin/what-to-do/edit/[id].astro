---
import AdminLayout from '../../../../../components/admin/AdminLayout.astro';
import AdminStickySave from '../../../../../components/admin/AdminStickySave.astro';
import AdminWhatToDoSocialLinksCard from '../../../../../components/admin/AdminWhatToDoSocialLinksCard.astro';
import AdminTourLocalesFields from '../../../../../components/admin/AdminTourLocalesFields.astro';
import AdminSlugAutoFromEnTitle from '../../../../../components/admin/AdminSlugAutoFromEnTitle.astro';
import AdminTourPhotoUpload from '../../../../../components/admin/AdminTourPhotoUpload.astro';
import { getRelativeLocaleUrl } from 'astro:i18n';
import type { Locale } from '../../../../../lib/strings';
import {
	WHAT_TO_DO_CATEGORY_IDS,
	WHAT_TO_DO_CATEGORY_LABELS_EN,
} from '../../../../../lib/what-to-do-categories';
import {
	WHAT_TO_DO_SEASON_IDS,
	WHAT_TO_DO_SEASON_LABELS_EN,
} from '../../../../../lib/what-to-do-seasons';
import { PHYSICAL_RATING_IDS, PHYSICAL_RATING_LABELS_EN } from '../../../../../lib/tour-physical-rating';
import { getWhatToDoPostById, isValidTourId } from '../../../../../lib/tours-db';

const loc = Astro.params.locale;
const idParam = Astro.params.id;
if (loc !== 'en' && loc !== 'ka' && loc !== 'ru' || !idParam) {
	return new Response(null, { status: 404 });
}
const locale = loc as Locale;

if (!Astro.locals.user || Astro.locals.user.role !== 'admin') {
	const login = getRelativeLocaleUrl(locale, 'login');
	const next = getRelativeLocaleUrl(locale, `admin/what-to-do/edit/${idParam}`);
	return Astro.redirect(`${login}?next=${encodeURIComponent(next)}`);
}

if (!isValidTourId(idParam)) {
	return new Response(null, { status: 404 });
}

const post = getWhatToDoPostById(idParam);
if (!post) {
	return new Response(null, { status: 404 });
}

const displayTitle =
	post.i18n.en?.title?.trim() ||
	post.i18n.ka?.title?.trim() ||
	post.i18n.ru?.title?.trim() ||
	post.slug;

const adminHome = getRelativeLocaleUrl(locale, 'admin');
const userEmail = Astro.locals.user.email;
---

<AdminLayout
	locale={locale}
	title={`Edit “${displayTitle}” · Travel Guide Georgia`}
	headline="Edit — What to do"
	subtitle={`Post ID ${post.id} · slug: ${post.slug}${post.author_email ? ` · Author: ${post.author_email}` : ''}`}
	activeNav="wtd-edit"
	userEmail={userEmail}
>
	<form id="wtd-admin-form" method="post" action="/api/admin/what-to-do">
		<input type="hidden" name="intent" value="update" />
		<input type="hidden" name="id" value={post.id} />
		<input type="hidden" name="redirect" value={adminHome} />
		<input type="hidden" name="admin_locale" value={locale} />
		<input type="hidden" id="tour-admin-title" value={post.i18n.en?.title ?? ''} />

		<section class="admin-card">
			<h2 class="admin-card__h">Slug</h2>
			<div class="admin-card__bd">
				<div class="row">
					<label>
						<span>Slug (URL)</span>
						<input
							type="text"
							id="tour-admin-slug"
							name="slug"
							required
							value={post.slug}
							pattern="[a-z0-9]+(-[a-z0-9]+)*"
						/>
					</label>
				</div>
			</div>
		</section>

		<section class="admin-card">
			<h2 class="admin-card__h">Public sidebar</h2>
			<div class="admin-card__bd">
				<p class="muted" style="margin:0 0 1rem">
					The live page shows <strong>At a glance</strong> with categories and seasons (several of each allowed), physical rating, driving distance, duration and price from the active language, location when coordinates are set, and optional Google Maps directions (custom link or auto from coordinates).
				</p>
				<div class="row">
					<span class="muted" style="display:block;margin-bottom:0.35rem;font-weight:600">
						Categories
					</span>
					<p class="muted" style="margin:0 0 0.5rem;font-size:0.9rem">
						Check all that apply (optional).
					</p>
					<div class="admin-wtd-cat-grid">
						{
							WHAT_TO_DO_CATEGORY_IDS.map((id) => (
								<label class="admin-wtd-cat-item">
									<input
										type="checkbox"
										name="categories"
										value={id}
										checked={post.whatDoCategories.includes(id)}
									/>
									<span>{WHAT_TO_DO_CATEGORY_LABELS_EN[id]}</span>
								</label>
							))
						}
					</div>
				</div>
				<div class="row">
					<span class="muted" style="display:block;margin-bottom:0.35rem;font-weight:600">
						Seasons
					</span>
					<p class="muted" style="margin:0 0 0.5rem;font-size:0.9rem">
						Check all that apply (optional).
					</p>
					<div class="admin-wtd-cat-grid">
						{
							WHAT_TO_DO_SEASON_IDS.map((id) => (
								<label class="admin-wtd-cat-item">
									<input
										type="checkbox"
										name="seasons"
										value={id}
										checked={post.whatDoSeasons.includes(id)}
									/>
									<span>{WHAT_TO_DO_SEASON_LABELS_EN[id]}</span>
								</label>
							))
						}
					</div>
					<p class="muted" style="margin:0.35rem 0 0">Best time of year (optional).</p>
				</div>
				<div class="row">
					<label>
						<span>Physical rating</span>
						<select name="physical_rating">
							<option value="" selected={!post.physical_rating}>— None —</option>
							{
								PHYSICAL_RATING_IDS.map((id) => (
									<option value={id} selected={post.physical_rating === id}>
										{PHYSICAL_RATING_LABELS_EN[id]}
									</option>
								))
							}
						</select>
					</label>
				</div>
				<div class="row">
					<label>
						<span>Driving distance</span>
						<input
							type="text"
							name="driving_distance"
							autocomplete="off"
							placeholder="e.g. 120 km round trip"
							value={post.driving_distance ?? ''}
						/>
					</label>
					<p class="muted" style="margin:0.35rem 0 0">Free text; shown in the public sidebar.</p>
				</div>
			</div>
		</section>

		<section class="admin-card">
			<h2 class="admin-card__h">Featured image &amp; gallery</h2>
			<div class="admin-card__bd">
				<p class="muted" style="margin:0 0 1rem">Shared across all translations.</p>
				<fieldset class="photos" style="background:transparent;border-style:dashed">
					<AdminTourPhotoUpload formId="wtd-admin-form" uploadApiPath="/api/admin/upload-what-to-do-image" />
					<div class="row">
						<label>
							<span>Cover image URL (optional)</span>
							<input type="text" name="image" id="tour-cover-url" value={post.image ?? ''} />
						</label>
						<p class="muted" style="margin:0.35rem 0 0">Upload or paste a URL.</p>
					</div>
					<div class="row">
						<label>
							<span>Gallery URLs (optional)</span>
							<textarea class="gallery-urls" name="gallery_urls" id="tour-gallery-urls">
								{post.gallery.join('\n')}
							</textarea>
						</label>
					</div>
				</fieldset>
			</div>
		</section>

		<section class="admin-card">
			<h2 class="admin-card__h">Map location</h2>
			<div class="admin-card__bd">
				<p class="muted" style="margin:0 0 1rem">
					One pin per entry (WGS84). Shown on the public map. Leave latitude and longitude empty to hide from the map.
				</p>
				<div class="row">
					<label>
						<span>Latitude</span>
						<input
							type="text"
							name="location_lat"
							inputmode="decimal"
							autocomplete="off"
							placeholder="e.g. 41.7151"
							value={post.location?.lat ?? ''}
						/>
					</label>
					<label>
						<span>Longitude</span>
						<input
							type="text"
							name="location_lng"
							inputmode="decimal"
							autocomplete="off"
							placeholder="e.g. 44.8271"
							value={post.location?.lng ?? ''}
						/>
					</label>
				</div>
				<div class="row">
					<label>
						<span>Map label (optional)</span>
						<input
							type="text"
							name="location_label"
							autocomplete="off"
							placeholder="e.g. Tbilisi · Old Town"
							value={post.location?.label ?? ''}
						/>
					</label>
				</div>
				<div class="row">
					<label>
						<span>Google Maps directions link (optional)</span>
						<input
							type="url"
							name="google_directions_url"
							inputmode="url"
							autocomplete="off"
							placeholder="https://www.google.com/maps/dir/?api=1&destination=…"
							value={post.google_directions_url ?? ''}
						/>
					</label>
					<p class="muted" style="margin:0.35rem 0 0">
						Paste a directions or place URL from Google Maps (maps.google.com, google.com/maps, or goo.gl). If
						empty but latitude/longitude are set, the public page still offers “Get directions” using those
						coordinates.
					</p>
				</div>
			</div>
		</section>

		<section class="admin-card">
			<h2 class="admin-card__h">Translations</h2>
			<div class="admin-card__bd">
				<AdminTourLocalesFields post={post} showContactSidebar />
			</div>
		</section>

		<AdminWhatToDoSocialLinksCard socialLinks={post.social_links} />

	</form>
	<AdminStickySave
		locale={locale}
		formId="wtd-admin-form"
		submitLabel="Update"
		cancelHref={adminHome}
		viewMode="what-to-do"
	/>
	<AdminSlugAutoFromEnTitle />
</AdminLayout>

<style>
	.admin-wtd-cat-grid {
		display: flex;
		flex-direction: column;
		gap: 0.15rem;
	}
	.admin-wtd-cat-item {
		display: flex;
		gap: 0.45rem;
		align-items: flex-start;
		font-size: 0.9rem;
		cursor: pointer;
	}
	.admin-wtd-cat-item input[type='checkbox'] {
		width: auto;
		margin-top: 0.2em;
		flex-shrink: 0;
	}
	.admin-wtd-cat-item span {
		display: inline;
		margin: 0;
	}
</style>
