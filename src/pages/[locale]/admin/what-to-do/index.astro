---
import AdminLayout from '../../../../components/admin/AdminLayout.astro';
import { getRelativeLocaleUrl } from 'astro:i18n';
import {
	ADMIN_LIST_PAGE_SIZE,
	buildAdminQueryLink,
	filterTourRowsForAdmin,
	listRangeLabel,
	paginateSlice,
	parseAdminListPage,
} from '../../../../lib/admin-list-helpers';
import { listAllWhatToDoAdmin } from '../../../../lib/tours-db';
import { contributorAuthorEmailForPublishedPost } from '../../../../lib/submissions-db';
import type { Locale } from '../../../../lib/strings';

export const prerender = false;

const loc = Astro.params.locale;
if (loc !== 'en' && loc !== 'ka' && loc !== 'ru') {
	return new Response(null, { status: 404 });
}
const locale = loc as Locale;

if (!Astro.locals.user || Astro.locals.user.role !== 'admin') {
	const login = getRelativeLocaleUrl(locale, 'login');
	const next = getRelativeLocaleUrl(locale, 'admin/what-to-do');
	return Astro.redirect(`${login}?next=${encodeURIComponent(next)}`);
}

const wtdRows = await listAllWhatToDoAdmin();
const formError = Astro.url.searchParams.get('error');
const userEmail = Astro.locals.user.email;
const sp = Astro.url.searchParams;
const q = (sp.get('q') ?? '').trim();
const categoryFilter = (sp.get('category') ?? '').trim();
const wtdRowsFiltered = filterTourRowsForAdmin(wtdRows, q, 'what-to-do', categoryFilter);
const wtdPag = paginateSlice(
	wtdRowsFiltered,
	parseAdminListPage(sp, 'page'),
	ADMIN_LIST_PAGE_SIZE,
);

const selfUrl = `${Astro.url.pathname}${Astro.url.search}`;
const pathOnly = Astro.url.pathname;
const searchOnly = Astro.url.search;

const newWtdUrl = getRelativeLocaleUrl(locale, 'admin/what-to-do/new');
const dashboardUrl = getRelativeLocaleUrl(locale, 'admin');

function queryLink(updates: Record<string, string | null | undefined>): string {
	return buildAdminQueryLink(pathOnly, searchOnly, updates);
}

function displayWtdAuthor(row: (typeof wtdRows)[number]): string {
	return (
		row.author_email?.trim() || contributorAuthorEmailForPublishedPost('what-to-do', row.id) || ''
	);
}

const WTD_CATEGORY_FILTERS = [
	{ value: '', label: 'All' },
	{ value: 'hiking', label: 'Hiking' },
	{ value: 'history-culture', label: 'History & Culture' },
	{ value: 'landmark', label: 'Landmark' },
	{ value: 'museum', label: 'Museum' },
	{ value: 'park', label: 'Park' },
	{ value: 'lake', label: 'Lake' },
	{ value: 'river', label: 'River' },
	{ value: 'mountain-peaks', label: 'Mountain Peaks' },
	{ value: 'hot-spring', label: 'Hot Spring' },
	{ value: 'state-nature-reserve', label: 'Nature Reserve' },
	{ value: 'street', label: 'Street' },
] as const;
---

<AdminLayout
	locale={locale}
	title="What to do · Travel Guide Georgia"
	headline="What to do"
	subtitle="Public list at /{locale}/what-to-do/ · data/what-to-do.json"
	activeNav="wtd-all"
	userEmail={userEmail}
>
	{
		formError ? (
			<div class="notice notice-error" role="alert">
				{formError}
			</div>
		) : null
	}

	<section class="admin-card">
		<h2 class="admin-card__h">All entries</h2>
		<div class="admin-card__bd">
			<p class="muted" style="margin:0 0 1rem">
				Activities and ideas — same fields as tours, separate public list.
			</p>
			<p style="margin:0 0 1rem">
				<a class="button button-primary" href={newWtdUrl}>Add new</a>
				<a class="button" href={dashboardUrl} style="margin-left:0.35rem">
					Dashboard
				</a>
			</p>

			<form id="bulk-wtd-form" method="post" action="/api/admin/what-to-do" class="admin-bulk-form">
				<input type="hidden" name="intent" value="bulk_delete" />
				<input type="hidden" name="redirect" value={selfUrl} />
			</form>

			<div class="admin-filter-bar">
				<span class="admin-filter-bar__label">Category:</span>
				{
					WTD_CATEGORY_FILTERS.map(({ value, label }) => (
						<a
							class:list={['admin-filter-btn', categoryFilter === value && 'is-active']}
							href={queryLink({ category: value || null, page: null, q: null })}
						>
							{label}{' '}
							<span class="admin-filter-btn__count">
								{value
									? wtdRows.filter((r) => r.whatDoCategories.includes(value)).length
									: wtdRows.length}
							</span>
						</a>
					))
				}
			</div>

			<div class="admin-toolbar">
				<span class="muted" style="font-size:0.88rem;margin:0">
					{listRangeLabel(wtdPag.page, ADMIN_LIST_PAGE_SIZE, wtdPag.total)}
					{q ? ` · search "${q}"` : ''}{categoryFilter ? ` · cat: ${categoryFilter}` : ''} · {ADMIN_LIST_PAGE_SIZE} per page · page {wtdPag.page} / {wtdPag.totalPages}
				</span>
				<div class="admin-toolbar__bulk">
					<form method="get" action={pathOnly} class="admin-toolbar__search">
						{categoryFilter ? <input type="hidden" name="category" value={categoryFilter} /> : null}
						<input type="hidden" name="page" value="1" />
						<label class="visually-hidden" for="wtd-list-q">Search what to do</label>
						<input
							id="wtd-list-q"
							type="search"
							name="q"
							value={q}
							placeholder="Search slug, titles, author…"
							autocomplete="off"
							class="admin-toolbar__search-input"
						/>
						<button type="submit" class="button button-sm">Search</button>
						{
							q ? (
								<a class="button button-sm btn--ghost" href={queryLink({ q: null, page: null })}>
									Clear
								</a>
							) : null
						}
					</form>
					<label>
						<input type="checkbox" data-bulk-select-all="wtd" />
						Select all on page
					</label>
					<button type="submit" form="bulk-wtd-form" class="button button-danger button-sm">
						Delete selected
					</button>
				</div>
			</div>

			<div class="admin-table-wrap">
				<table class="admin-table">
					<thead>
						<tr>
							<th class="admin-table__check" scope="col">
								<span class="visually-hidden">Select</span>
							</th>
							<th>Slug</th>
							<th>Author</th>
							<th>English</th>
							<th>Georgian</th>
							<th>Russian</th>
							<th>Actions</th>
						</tr>
					</thead>
					<tbody>
						{
							wtdPag.slice.map((row) => (
								<tr>
									<td class="admin-table__check">
										<input
											type="checkbox"
											name="ids"
											value={row.id}
											form="bulk-wtd-form"
											data-bulk-row="wtd"
											aria-label={`Select what-to-do ${row.slug}`}
										/>
									</td>
									<td>
										<code>{row.slug}</code>
									</td>
									<td class="muted" style="font-size:0.88rem;max-width:12rem">
										{displayWtdAuthor(row) || '—'}
									</td>
									<td>{row.titles.en || '—'}</td>
									<td>{row.titles.ka || '—'}</td>
									<td>{row.titles.ru || '—'}</td>
									<td>
										<div class="admin-actions">
											<a href={getRelativeLocaleUrl(locale, `admin/what-to-do/edit/${row.id}`)}>Edit</a>
											<form
												method="post"
												action="/api/admin/what-to-do"
												onsubmit="return confirm('Delete this \"What to do\" entry and its reviews? This cannot be undone.');"
											>
												<input type="hidden" name="intent" value="delete" />
												<input type="hidden" name="id" value={row.id} />
												<input type="hidden" name="redirect" value={selfUrl} />
												<button type="submit" class="button button-danger button-sm">Delete</button>
											</form>
										</div>
										<div class="view-links muted" style="margin-top:0.35rem">
											{row.locales.map((code) => (
												<a href={getRelativeLocaleUrl(code, `what-to-do/${row.slug}`)}>View ({code})</a>
											))}
											{row.locales.length === 0 ? <span>No locales</span> : null}
										</div>
									</td>
								</tr>
							))
						}
					</tbody>
				</table>
			</div>

			<nav class="admin-pagination" aria-label="What to do pages">
				<span class="muted">
					{wtdPag.page > 1 ? (
						<a href={queryLink({ page: String(wtdPag.page - 1) })}>← Previous</a>
					) : (
						<span style="opacity:0.55">← Previous</span>
					)}
					{' · '}
					{wtdPag.page < wtdPag.totalPages ? (
						<a href={queryLink({ page: String(wtdPag.page + 1) })}>Next →</a>
					) : (
						<span style="opacity:0.55">Next →</span>
					)}
				</span>
				<span class="muted">
					Page {wtdPag.page} / {wtdPag.totalPages}
				</span>
			</nav>
		</div>
	</section>

	<script is:inline>
		document.addEventListener('DOMContentLoaded', function () {
			document.querySelectorAll('[data-bulk-select-all]').forEach(function (master) {
				var scope = master.getAttribute('data-bulk-select-all');
				if (!scope) return;
				master.addEventListener('change', function () {
					document.querySelectorAll('[data-bulk-row="' + scope + '"]').forEach(function (cb) {
						cb.checked = master.checked;
					});
				});
			});
			var form = document.getElementById('bulk-wtd-form');
			if (form) {
				form.addEventListener('submit', function (e) {
					var checked = [];
					for (var i = 0; i < form.elements.length; i++) {
						var el = form.elements[i];
						if (el.name === 'ids' && el.type === 'checkbox' && el.checked) checked.push(el);
					}
					if (checked.length === 0) {
						e.preventDefault();
						alert('Select at least one post.');
						return;
					}
					if (
						!confirm(
							'Delete ' +
								checked.length +
								' "What to do" entr' +
								(checked.length === 1 ? 'y' : 'ies') +
								' and their reviews? This cannot be undone.',
						)
					) {
						e.preventDefault();
					}
				});
			}
		});
	</script>
</AdminLayout>
