---
import AdminLayout from '../../../../components/admin/AdminLayout.astro';
import AdminStickySave from '../../../../components/admin/AdminStickySave.astro';
import AdminGuideLocalesFields from '../../../../components/admin/AdminGuideLocalesFields.astro';
import AdminTourPhotoUpload from '../../../../components/admin/AdminTourPhotoUpload.astro';
import AdminWhatToDoSocialLinksCard from '../../../../components/admin/AdminWhatToDoSocialLinksCard.astro';
import { getRelativeLocaleUrl } from 'astro:i18n';
import { GUIDE_SPECIALTY_IDS, GUIDE_SPECIALTY_LABELS_EN } from '../../../../lib/guide-specialties';
import type { Locale } from '../../../../lib/strings';

const loc = Astro.params.locale;
if (loc !== 'en' && loc !== 'ka' && loc !== 'ru') {
	return new Response(null, { status: 404 });
}
const locale = loc as Locale;

if (!Astro.locals.user || Astro.locals.user.role !== 'admin') {
	const login = getRelativeLocaleUrl(locale, 'login');
	const next = getRelativeLocaleUrl(locale, 'admin/guides/new');
	return Astro.redirect(`${login}?next=${encodeURIComponent(next)}`);
}

const guidesListUrl = getRelativeLocaleUrl(locale, 'admin/guides');
const userEmail = Astro.locals.user.email;
---

<AdminLayout
	locale={locale}
	title="Add guide · Travel Guide Georgia"
	headline="Add new tour guide"
	subtitle="One row per guide: shared contact, photos, and global fields; separate bio for each language."
	activeNav="guides-new"
	userEmail={userEmail}
>
	<form id="guide-admin-form" method="post" action="/api/admin/guides">
		<input type="hidden" name="intent" value="create" />
		<input type="hidden" name="redirect" value={guidesListUrl} />
		<input type="hidden" name="admin_locale" value={locale} />

		<section class="admin-card">
			<h2 class="admin-card__h">Slug</h2>
			<div class="admin-card__bd">
				<div class="row">
					<label>
						<span>Slug (URL)</span>
						<input
							type="text"
							id="guide-admin-slug"
							name="slug"
							required
							placeholder="e.g. giorgi-beridze"
							pattern="[a-z0-9]+(-[a-z0-9]+)*"
						/>
					</label>
					<p class="muted" style="margin:0.35rem 0 0">Lowercase Latin letters, numbers, and hyphens only.</p>
				</div>
			</div>
		</section>

		<section class="admin-card">
			<h2 class="admin-card__h">Guide details (shared)</h2>
			<div class="admin-card__bd">
				<div class="row">
					<label>
						<span>Base location</span>
						<input type="text" name="base_location" autocomplete="off" placeholder="e.g. Tbilisi" />
					</label>
				</div>
				<div class="row">
					<label>
						<span>Languages spoken</span>
						<input
							type="text"
							name="languages_spoken"
							autocomplete="off"
							placeholder="e.g. English, Georgian, Russian, German"
						/>
					</label>
					<p class="muted" style="margin:0.35rem 0 0">Comma-separated list of languages.</p>
				</div>
				<div class="row">
					<label>
						<span>Years of experience (optional)</span>
						<input type="number" name="years_experience" min="0" max="99" autocomplete="off" placeholder="e.g. 8" />
					</label>
				</div>
				<div class="row">
					<label>
						<span>Starting price (optional)</span>
						<input type="text" name="price_from" autocomplete="off" placeholder="e.g. $80/day" />
					</label>
					<p class="muted" style="margin:0.35rem 0 0">Free text shown on the public profile.</p>
				</div>
				<div class="row">
					<fieldset style="border:none;padding:0;margin:0">
						<legend style="font-size:0.875rem;font-weight:500;margin-bottom:0.5rem">Specialties</legend>
						<div style="display:flex;flex-wrap:wrap;gap:0.5rem 1rem">
							{GUIDE_SPECIALTY_IDS.map((id) => (
								<label style="display:flex;align-items:center;gap:0.35rem;font-size:0.9rem">
									<input type="checkbox" name="specialties" value={id} />
									{GUIDE_SPECIALTY_LABELS_EN[id]}
								</label>
							))}
						</div>
					</fieldset>
				</div>
				<div class="row" style="margin-top:0.75rem">
					<label style="display:flex;align-items:center;gap:0.5rem">
						<input type="checkbox" name="verified" value="1" />
						<span>Verified guide</span>
					</label>
					<p class="muted" style="margin:0.35rem 0 0">Shows a verified badge on the public profile.</p>
				</div>
			</div>
		</section>

		<section class="admin-card">
			<h2 class="admin-card__h">Profile photo &amp; gallery</h2>
			<div class="admin-card__bd">
				<p class="muted" style="margin:0 0 1rem">Shared across all translations.</p>
				<fieldset class="photos" style="background:transparent;border-style:dashed">
					<AdminTourPhotoUpload
						uploadApiPath="/api/admin/upload-guide-image"
						formId="guide-admin-form"
						slugInputId="guide-admin-slug"
						widgetPrefix="guide"
					/>
					<div class="row">
						<label>
							<span>Profile photo URL (optional)</span>
							<input type="text" name="profile_photo" id="guide-cover-url" placeholder="/uploads/guides/… or https://…" />
						</label>
						<p class="muted" style="margin:0.35rem 0 0">
							Set automatically when you upload, or paste a URL.
						</p>
					</div>
					<div class="row">
						<label>
							<span>Gallery URLs (optional)</span>
							<textarea
								class="gallery-urls"
								name="gallery_urls"
								id="guide-gallery-urls"
								placeholder="One URL per line."
							></textarea>
						</label>
					</div>
				</fieldset>
			</div>
		</section>

		<section class="admin-card">
			<h2 class="admin-card__h">Translations</h2>
			<div class="admin-card__bd">
				<p class="muted" style="margin:0 0 1rem">
					At least one language needs a name and tagline. Leave a language empty to hide it on the site.
				</p>
				<AdminGuideLocalesFields />
			</div>
		</section>

		<AdminWhatToDoSocialLinksCard />

	</form>

	<AdminStickySave
		locale={locale}
		formId="guide-admin-form"
		submitLabel="Publish"
		cancelHref={guidesListUrl}
		viewMode="guides"
	/>

	<script is:inline>
		(function () {
			function slugify(s) {
				s = String(s).trim().toLowerCase().replace(/&/g, 'and').replace(/[^a-z0-9]+/g, '-').replace(/^-+|-+$/g, '');
				return s.length > 120 ? s.slice(0, 120) : s;
			}
			function bind() {
				var slug = document.getElementById('guide-admin-slug');
				if (!slug) return;
				var form = slug.closest('form');
				if (!form) return;
				var name = form.querySelector('input[name="en_name"]');
				if (!name) return;
				var auto = !slug.value.trim() || slug.value.trim() === slugify(name.value);
				name.addEventListener('input', function () { if (auto) slug.value = slugify(name.value); });
				slug.addEventListener('input', function () { auto = false; });
			}
			if (document.readyState === 'loading') document.addEventListener('DOMContentLoaded', bind);
			else bind();
		})();
	</script>
</AdminLayout>
