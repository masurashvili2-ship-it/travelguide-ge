---
import AdminLayout from '../../../../components/admin/AdminLayout.astro';
import AdminStickySave from '../../../../components/admin/AdminStickySave.astro';
import AdminTourLocalesFields from '../../../../components/admin/AdminTourLocalesFields.astro';
import AdminSlugAutoFromEnTitle from '../../../../components/admin/AdminSlugAutoFromEnTitle.astro';
import AdminTourPhotoUpload from '../../../../components/admin/AdminTourPhotoUpload.astro';
import { getRelativeLocaleUrl } from 'astro:i18n';
import { TOUR_CATEGORY_IDS, TOUR_CATEGORY_LABELS_EN } from '../../../../lib/tour-categories';
import { PHYSICAL_RATING_IDS, PHYSICAL_RATING_LABELS_EN } from '../../../../lib/tour-physical-rating';
import type { Locale } from '../../../../lib/strings';

const loc = Astro.params.locale;
if (loc !== 'en' && loc !== 'ka' && loc !== 'ru') {
	return new Response(null, { status: 404 });
}
const locale = loc as Locale;

if (!Astro.locals.user || Astro.locals.user.role !== 'admin') {
	const login = getRelativeLocaleUrl(locale, 'login');
	const next = getRelativeLocaleUrl(locale, 'admin/tours/new');
	return Astro.redirect(`${login}?next=${encodeURIComponent(next)}`);
}

const toursListUrl = getRelativeLocaleUrl(locale, 'admin/tours');
const userEmail = Astro.locals.user.email;
---

<AdminLayout
	locale={locale}
	title="Add tour · Travel Guide Georgia"
	headline="Add new tour"
	subtitle="One database row per tour: shared slug, cover, and gallery; separate fields for each language."
	activeNav="tours-new"
	userEmail={userEmail}
>
	<form id="tour-admin-form" method="post" action="/api/admin/tours">
		<input type="hidden" name="intent" value="create" />
		<input type="hidden" name="redirect" value={toursListUrl} />
		<input type="hidden" name="admin_locale" value={locale} />
		<section class="admin-card">
			<h2 class="admin-card__h">Slug</h2>
			<div class="admin-card__bd">
				<div class="row">
					<label>
						<span>Slug (URL)</span>
						<input
							type="text"
							id="tour-admin-slug"
							name="slug"
							required
							placeholder="e.g. batumi-food-walk"
							pattern="[a-z0-9]+(-[a-z0-9]+)*"
						/>
					</label>
					<p class="muted" style="margin:0.35rem 0 0">Lowercase Latin letters, numbers, and hyphens only.</p>
				</div>
			</div>
		</section>

		<section class="admin-card">
			<h2 class="admin-card__h">Public tour sidebar</h2>
			<div class="admin-card__bd">
				<p class="muted" style="margin:0 0 1rem">
					The live tour page shows an <strong>At a glance</strong> column with <strong>category</strong>, <strong>physical rating</strong>, <strong>driving distance</strong>, <strong>duration</strong> and <strong>price</strong> from each language under Translations, and <strong>location</strong> plus a map link when coordinates are set in Map location.
				</p>
				<div class="row">
					<label>
						<span>Category</span>
						<select name="category">
							<option value="" selected>— None —</option>
							{
								TOUR_CATEGORY_IDS.map((id) => (
									<option value={id}>{TOUR_CATEGORY_LABELS_EN[id]}</option>
								))
							}
						</select>
					</label>
				</div>
				<div class="row">
					<label>
						<span>Physical rating</span>
						<select name="physical_rating">
							<option value="" selected>— None —</option>
							{
								PHYSICAL_RATING_IDS.map((id) => (
									<option value={id}>{PHYSICAL_RATING_LABELS_EN[id]}</option>
								))
							}
						</select>
					</label>
				</div>
				<div class="row">
					<label>
						<span>Driving distance</span>
						<input
							type="text"
							name="driving_distance"
							autocomplete="off"
							placeholder="e.g. 120 km round trip"
						/>
					</label>
					<p class="muted" style="margin:0.35rem 0 0">Free text; shown in the public sidebar.</p>
				</div>
			</div>
		</section>

		<section class="admin-card">
			<h2 class="admin-card__h">Featured image &amp; gallery</h2>
			<div class="admin-card__bd">
				<p class="muted" style="margin:0 0 1rem">Shared across all translations of this tour.</p>
				<fieldset class="photos" style="background:transparent;border-style:dashed">
					<AdminTourPhotoUpload />
					<div class="row">
						<label>
							<span>Cover image URL (optional)</span>
							<input type="text" name="image" id="tour-cover-url" placeholder="/uploads/tours/… or https://…" />
						</label>
						<p class="muted" style="margin:0.35rem 0 0">
							Set automatically when you upload, or paste a URL. If empty, the first gallery URL is used.
						</p>
					</div>
					<div class="row">
						<label>
							<span>Gallery URLs (optional)</span>
							<textarea
								class="gallery-urls"
								name="gallery_urls"
								id="tour-gallery-urls"
								placeholder="One URL per line. Upload can fill this for you."
							></textarea>
						</label>
						<p class="muted" style="margin:0.35rem 0 0">Up to 30 images on the public tour page.</p>
					</div>
				</fieldset>
			</div>
		</section>

		<section class="admin-card">
			<h2 class="admin-card__h">Map location</h2>
			<div class="admin-card__bd">
				<p class="muted" style="margin:0 0 1rem">
					One pin per tour (WGS84). Optional — leave empty if this tour should not appear on the map.
				</p>
				<div class="row">
					<label>
						<span>Latitude</span>
						<input type="text" name="location_lat" inputmode="decimal" autocomplete="off" placeholder="e.g. 41.7151" />
					</label>
					<label>
						<span>Longitude</span>
						<input type="text" name="location_lng" inputmode="decimal" autocomplete="off" placeholder="e.g. 44.8271" />
					</label>
				</div>
				<div class="row">
					<label>
						<span>Map label (optional)</span>
						<input type="text" name="location_label" autocomplete="off" placeholder="e.g. Kazbegi" />
					</label>
				</div>
			</div>
		</section>

		<section class="admin-card">
			<h2 class="admin-card__h">Translations</h2>
			<div class="admin-card__bd">
				<p class="muted" style="margin:0 0 1rem">
					At least one language needs title, duration, and excerpt. Leave a language empty to hide it on the site.
				</p>
				<AdminTourLocalesFields />
			</div>
		</section>

	</form>
	<AdminStickySave
		locale={locale}
		formId="tour-admin-form"
		submitLabel="Publish"
		cancelHref={toursListUrl}
		viewMode="tours"
	/>
	<AdminSlugAutoFromEnTitle />
</AdminLayout>
