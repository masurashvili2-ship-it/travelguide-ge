---
import AdminLayout from '../../../../components/admin/AdminLayout.astro';
import { getRelativeLocaleUrl } from 'astro:i18n';
import {
	ADMIN_LIST_PAGE_SIZE,
	buildAdminQueryLink,
	filterTourRowsForAdmin,
	listRangeLabel,
	paginateSlice,
	parseAdminListPage,
} from '../../../../lib/admin-list-helpers';
import { listAllToursAdmin } from '../../../../lib/tours-db';
import { contributorAuthorEmailForPublishedPost } from '../../../../lib/submissions-db';
import type { Locale } from '../../../../lib/strings';

export const prerender = false;

const loc = Astro.params.locale;
if (loc !== 'en' && loc !== 'ka' && loc !== 'ru') {
	return new Response(null, { status: 404 });
}
const locale = loc as Locale;

if (!Astro.locals.user || Astro.locals.user.role !== 'admin') {
	const login = getRelativeLocaleUrl(locale, 'login');
	const next = getRelativeLocaleUrl(locale, 'admin/tours');
	return Astro.redirect(`${login}?next=${encodeURIComponent(next)}`);
}

const tourRows = await listAllToursAdmin();
const formError = Astro.url.searchParams.get('error');
const userEmail = Astro.locals.user.email;
const sp = Astro.url.searchParams;
const q = (sp.get('q') ?? '').trim();
const categoryFilter = (sp.get('category') ?? '').trim();
const tourRowsFiltered = filterTourRowsForAdmin(tourRows, q, 'tours', categoryFilter);
const toursPag = paginateSlice(
	tourRowsFiltered,
	parseAdminListPage(sp, 'page'),
	ADMIN_LIST_PAGE_SIZE,
);

const selfUrl = `${Astro.url.pathname}${Astro.url.search}`;
const pathOnly = Astro.url.pathname;
const searchOnly = Astro.url.search;

const newTourUrl = getRelativeLocaleUrl(locale, 'admin/tours/new');
const dashboardUrl = getRelativeLocaleUrl(locale, 'admin');

function queryLink(updates: Record<string, string | null | undefined>): string {
	return buildAdminQueryLink(pathOnly, searchOnly, updates);
}

function displayTourAuthor(row: (typeof tourRows)[number]): string {
	return (
		row.author_email?.trim() || contributorAuthorEmailForPublishedPost('tours', row.id) || ''
	);
}

const CATEGORY_FILTERS = [
	{ value: '', label: 'All' },
	{ value: 'adventure-nature', label: 'Adventure & Nature' },
	{ value: 'cultural-historical', label: 'Cultural & Historical' },
	{ value: 'wine-food', label: 'Wine & Food' },
	{ value: 'religious-pilgrimage', label: 'Religious & Pilgrimage' },
] as const;
---

<AdminLayout
	locale={locale}
	title="Tours · Travel Guide Georgia"
	headline="Tours"
	subtitle="Public list at /{locale}/tours/ · data/tours.json"
	activeNav="tours-all"
	userEmail={userEmail}
>
	{
		formError ? (
			<div class="notice notice-error" role="alert">
				{formError}
			</div>
		) : null
	}

	<section class="admin-card">
		<h2 class="admin-card__h">All tours</h2>
		<div class="admin-card__bd">
			<p style="margin:0 0 1rem">
				<a class="button button-primary" href={newTourUrl}>Add new tour</a>
				<a class="button" href={dashboardUrl} style="margin-left:0.35rem">
					Dashboard
				</a>
			</p>

			<form id="bulk-tours-form" method="post" action="/api/admin/tours" class="admin-bulk-form">
				<input type="hidden" name="intent" value="bulk_delete" />
				<input type="hidden" name="redirect" value={selfUrl} />
			</form>

			<div class="admin-filter-bar">
				<span class="admin-filter-bar__label">Category:</span>
				{
					CATEGORY_FILTERS.map(({ value, label }) => (
						<a
							class:list={['admin-filter-btn', categoryFilter === value && 'is-active']}
							href={queryLink({ category: value || null, page: null, q: null })}
						>
							{label}{' '}
							<span class="admin-filter-btn__count">
								{value
									? tourRows.filter((r) => r.category === value).length
									: tourRows.length}
							</span>
						</a>
					))
				}
			</div>

			<div class="admin-toolbar">
				<span class="muted" style="font-size:0.88rem;margin:0">
					{listRangeLabel(toursPag.page, ADMIN_LIST_PAGE_SIZE, toursPag.total)}
					{q ? ` · search "${q}"` : ''}{categoryFilter ? ` · cat: ${categoryFilter}` : ''} · {ADMIN_LIST_PAGE_SIZE} per page · page {toursPag.page} / {toursPag.totalPages}
				</span>
				<div class="admin-toolbar__bulk">
					<form method="get" action={pathOnly} class="admin-toolbar__search">
						{categoryFilter ? <input type="hidden" name="category" value={categoryFilter} /> : null}
						<input type="hidden" name="page" value="1" />
						<label class="visually-hidden" for="tours-list-q">Search tours</label>
						<input
							id="tours-list-q"
							type="search"
							name="q"
							value={q}
							placeholder="Search slug, titles, author…"
							autocomplete="off"
							class="admin-toolbar__search-input"
						/>
						<button type="submit" class="button button-sm">Search</button>
						{
							q ? (
								<a class="button button-sm btn--ghost" href={queryLink({ q: null, page: null })}>
									Clear
								</a>
							) : null
						}
					</form>
					<label>
						<input type="checkbox" data-bulk-select-all="tours" />
						Select all on page
					</label>
					<button type="submit" form="bulk-tours-form" class="button button-danger button-sm">
						Delete selected
					</button>
				</div>
			</div>

			<div class="admin-table-wrap">
				<table class="admin-table">
					<thead>
						<tr>
							<th class="admin-table__check" scope="col">
								<span class="visually-hidden">Select</span>
							</th>
							<th>Slug</th>
							<th>Author</th>
							<th>English</th>
							<th>Georgian</th>
							<th>Russian</th>
							<th>Actions</th>
						</tr>
					</thead>
					<tbody>
						{
							toursPag.slice.map((row) => (
								<tr>
									<td class="admin-table__check">
										<input
											type="checkbox"
											name="ids"
											value={row.id}
											form="bulk-tours-form"
											data-bulk-row="tours"
											aria-label={`Select tour ${row.slug}`}
										/>
									</td>
									<td>
										<code>{row.slug}</code>
									</td>
									<td class="muted" style="font-size:0.88rem;max-width:12rem">
										{displayTourAuthor(row) || '—'}
									</td>
									<td>{row.titles.en || '—'}</td>
									<td>{row.titles.ka || '—'}</td>
									<td>{row.titles.ru || '—'}</td>
									<td>
										<div class="admin-actions">
											<a href={getRelativeLocaleUrl(locale, `admin/tours/edit/${row.id}`)}>Edit</a>
											<form
												method="post"
												action="/api/admin/tours"
												onsubmit="return confirm('Delete this tour and its reviews? This cannot be undone.');"
											>
												<input type="hidden" name="intent" value="delete" />
												<input type="hidden" name="id" value={row.id} />
												<input type="hidden" name="redirect" value={selfUrl} />
												<button type="submit" class="button button-danger button-sm">Delete</button>
											</form>
										</div>
										<div class="view-links muted" style="margin-top:0.35rem">
											{row.locales.map((code) => (
												<a href={getRelativeLocaleUrl(code, `tours/${row.slug}`)}>View ({code})</a>
											))}
											{row.locales.length === 0 ? <span>No locales</span> : null}
										</div>
									</td>
								</tr>
							))
						}
					</tbody>
				</table>
			</div>

			<nav class="admin-pagination" aria-label="Tours pages">
				<span class="muted">
					{toursPag.page > 1 ? (
						<a href={queryLink({ page: String(toursPag.page - 1) })}>← Previous</a>
					) : (
						<span style="opacity:0.55">← Previous</span>
					)}
					{' · '}
					{toursPag.page < toursPag.totalPages ? (
						<a href={queryLink({ page: String(toursPag.page + 1) })}>Next →</a>
					) : (
						<span style="opacity:0.55">Next →</span>
					)}
				</span>
				<span class="muted">
					Page {toursPag.page} / {toursPag.totalPages}
				</span>
			</nav>
		</div>
	</section>

	<script is:inline>
		document.addEventListener('DOMContentLoaded', function () {
			document.querySelectorAll('[data-bulk-select-all]').forEach(function (master) {
				var scope = master.getAttribute('data-bulk-select-all');
				if (!scope) return;
				master.addEventListener('change', function () {
					document.querySelectorAll('[data-bulk-row="' + scope + '"]').forEach(function (cb) {
						cb.checked = master.checked;
					});
				});
			});
			var form = document.getElementById('bulk-tours-form');
			if (form) {
				form.addEventListener('submit', function (e) {
					var checked = [];
					for (var i = 0; i < form.elements.length; i++) {
						var el = form.elements[i];
						if (el.name === 'ids' && el.type === 'checkbox' && el.checked) checked.push(el);
					}
					if (checked.length === 0) {
						e.preventDefault();
						alert('Select at least one post.');
						return;
					}
					if (
						!confirm(
							'Delete ' +
								checked.length +
								' tour' +
								(checked.length === 1 ? '' : 's') +
								' and their reviews? This cannot be undone.',
						)
					) {
						e.preventDefault();
					}
				});
			}
		});
	</script>
</AdminLayout>
