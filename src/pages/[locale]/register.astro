---
import Shell from '../../components/Shell.astro';
import { getRelativeLocaleUrl } from 'astro:i18n';
import type { Locale } from '../../lib/strings';
import { ui } from '../../lib/strings';

const loc = Astro.params.locale;
if (loc !== 'en' && loc !== 'ka' && loc !== 'ru') {
	return new Response(null, { status: 404 });
}
const locale = loc as Locale;
const t = ui[locale];
const errParam = Astro.url.searchParams.get('error');
const registerErrors: Record<string, string> = {
	invalid_email: t.registerErrorInvalidEmail,
	email_taken: t.registerErrorEmailTaken,
	password_short: t.registerErrorPasswordShort,
	password_mismatch: t.registerErrorPasswordMismatch,
	terms_required: t.registerErrorTermsRequired,
	generic: t.registerErrorGeneric,
};
const errMessage = errParam ? registerErrors[errParam] ?? t.registerErrorGeneric : null;
const next = Astro.url.searchParams.get('next') ?? getRelativeLocaleUrl(locale, '/');
const policyUrl = getRelativeLocaleUrl(locale, 'policy');
const googleOAuthEnabled = typeof process !== 'undefined' && !!process.env.GOOGLE_CLIENT_ID?.trim();
const googleStartUrl = `/api/auth/google?next=${encodeURIComponent(next)}`;
---

<Shell
	locale={locale}
	subpath="register"
	title={t.register}
	canonicalPath={`/${locale}/register`}
	robotsNoindex
>
	<h1 style="margin:0 0 1rem">{t.register}</h1>
	<p class="muted" style="margin:0 0 1rem">
		Create an account to leave reviews and contribute. The first account on a fresh install becomes{' '}
		<strong>admin</strong> (demo). Use a strong password; set <code>SESSION_SECRET</code> in production.
	</p>
	{errMessage ? <div class="alert" role="alert">{errMessage}</div> : null}

	{
		googleOAuthEnabled ? (
			<>
				<p style="margin:0 0 0.75rem">
					<a class="auth-google" href={googleStartUrl}>
						<svg width="18" height="18" viewBox="0 0 48 48" aria-hidden="true">
							<path
								fill="#FFC107"
								d="M43.611 20.083H42V20H24v8h11.303c-1.649 4.657-6.08 8-11.303 8-6.627 0-12-5.373-12-12s5.373-12 12-12c3.059 0 5.842 1.154 7.961 3.039l5.657-5.657C34.046 6.053 29.268 4 24 4 12.955 4 4 12.955 4 24s8.955 20 20 20 20-8.955 20-20c0-1.341-.138-2.65-.389-3.917z"
							/>
							<path
								fill="#FF3D00"
								d="m6.306 14.691 6.571 4.819C14.655 15.108 18.961 12 24 12c3.059 0 5.842 1.154 7.961 3.039l5.657-5.657C34.046 6.053 29.268 4 24 4 16.318 4 9.656 8.337 6.306 14.691z"
							/>
							<path
								fill="#4CAF50"
								d="M24 44c5.166 0 9.86-1.977 13.409-5.192l-6.19-5.238A11.91 11.91 0 0 1 24 36c-5.202 0-9.619-3.317-11.283-7.946l-6.522 5.025C9.505 39.556 16.227 44 24 44z"
							/>
							<path
								fill="#1976D2"
								d="M43.611 20.083H42V20H24v8h11.303a12.04 12.04 0 0 1-4.087 5.571l.003-.002 6.19 5.238C36.971 39.205 44 34 44 24c0-1.341-.138-2.65-.389-3.917z"
							/>
						</svg>
						<span>{t.continueWithGoogle}</span>
					</a>
				</p>
				<p class="auth-divider muted">{t.authOrContinueWith}</p>
			</>
		) : null
	}

	<form class="auth" method="post" action="/api/auth/register" data-auth-form>
		<input type="hidden" name="next" value={next} />
		<label>
			<span>{t.displayName}</span>
			<input type="text" name="display_name" autocomplete="name" maxlength="120" />
		</label>
		<label>
			<span>{t.email}</span>
			<input type="email" name="email" required autocomplete="email" />
		</label>
		<label>
			<span>{t.password}</span>
			<input type="password" name="password" required autocomplete="new-password" minlength="8" />
		</label>
		<label>
			<span>{t.passwordConfirm}</span>
			<input type="password" name="password_confirm" required autocomplete="new-password" minlength="8" />
		</label>
		<label class="auth-policy">
			<input type="checkbox" name="accept_policy" value="on" required />
			<span>
				{t.registerPolicyAgree}{' '}
				<a href={policyUrl}>{t.policyPageTitle}</a>
				{t.registerPolicyEnd}
			</span>
		</label>
		<button class="btn" type="submit">{t.submitRegister}</button>
	</form>
	<p class="muted" style="margin-top:1.5rem">
		{t.haveAccount}
		<a href={getRelativeLocaleUrl(locale, 'login')}>{t.login}</a>
	</p>
	<style>
		.auth-google {
			display: inline-flex;
			align-items: center;
			justify-content: center;
			gap: 0.5rem;
			width: 100%;
			padding: 0.58rem 1rem;
			border-radius: 999px;
			border: 1px solid var(--border);
			background: var(--surface);
			color: var(--text);
			font-weight: 600;
			font-size: 0.92rem;
			text-decoration: none !important;
			box-shadow: var(--shadow-sm);
			transition:
				background 0.15s ease,
				border-color 0.15s ease;
		}
		.auth-google:hover {
			background: color-mix(in srgb, var(--accent) 6%, var(--surface));
			border-color: color-mix(in srgb, var(--accent) 28%, var(--border));
		}
		.auth-divider {
			text-align: center;
			margin: 0 0 1rem;
			font-size: 0.88rem;
		}
		.auth-policy {
			display: flex;
			align-items: flex-start;
			gap: 0.5rem;
			cursor: pointer;
		}
		.auth-policy input {
			width: auto;
			margin-top: 0.35rem;
			flex-shrink: 0;
		}
		.auth-policy span {
			font-size: 0.88rem;
			color: var(--muted);
			line-height: 1.45;
		}
		.auth-policy a {
			font-weight: 600;
		}
	</style>
	<script is:inline>
		(function () {
			var f = document.querySelector('form[data-auth-form]');
			if (!f) return;
			f.addEventListener('submit', function () {
				var btn = f.querySelector('button[type="submit"]');
				if (!btn || btn.disabled) return;
				btn.disabled = true;
				btn.setAttribute('aria-busy', 'true');
			});
		})();
	</script>
</Shell>
