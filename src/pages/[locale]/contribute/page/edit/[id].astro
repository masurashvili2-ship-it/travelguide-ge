---
import Shell from '../../../../../components/Shell.astro';
import ContributeSubmitBar from '../../../../../components/ContributeSubmitBar.astro';
import AdminPageLocalesFields from '../../../../../components/admin/AdminPageLocalesFields.astro';
import { getRelativeLocaleUrl } from 'astro:i18n';
import { pagePostToContributionPayload } from '../../../../../lib/contribute-live-payload';
import { pagePayloadToSyntheticPagePost } from '../../../../../lib/contribute-synthetic-post';
import { getPagePostById } from '../../../../../lib/pages-db';
import type { Locale } from '../../../../../lib/strings';
import { getSubmissionById, type PageSubmissionPayload } from '../../../../../lib/submissions-db';
import '../../../../../styles/contribute.css';

const loc = Astro.params.locale;
const idParam = Astro.params.id;
if (loc !== 'en' && loc !== 'ka' && loc !== 'ru' || !idParam) {
	return new Response(null, { status: 404 });
}
const locale = loc as Locale;

if (!Astro.locals.user) {
	const login = getRelativeLocaleUrl(locale, 'login');
	const next = getRelativeLocaleUrl(locale, `contribute/page/edit/${idParam}`);
	return Astro.redirect(`${login}?next=${encodeURIComponent(next)}`);
}

const back = getRelativeLocaleUrl(locale, 'contribute');
const sub = getSubmissionById(idParam);
if (!sub || sub.kind !== 'page' || sub.author_user_id !== Astro.locals.user.id) {
	return Astro.redirect(back);
}
let p: PageSubmissionPayload;
if (sub.status === 'approved' && sub.published_id) {
	const live = getPagePostById(sub.published_id);
	p = live ? pagePostToContributionPayload(live) : (sub.payload as PageSubmissionPayload);
} else {
	p = sub.payload as PageSubmissionPayload;
}
const synthetic = pagePayloadToSyntheticPagePost(sub.id, p);
---

<Shell
	locale={locale}
	subpath={`contribute/page/edit/${idParam}`}
	title="Edit page proposal"
	seoTitle="Edit page proposal"
	robotsNoindex={true}
>
	<div class="contribute-page">
		<p class="muted" style="margin-top:0">
			<a href={back}>← Back to Contribute</a>
		</p>
		<h1>Edit page proposal</h1>
		<p class="muted">
			Status: <strong>{sub.status}</strong>.
			{sub.status === 'approved' ? (
				<>
					{' '}
					The live page stays as-is until an admin approves your changes. Saving sends a new version for review.
				</>
			) : (
				<>
					{' '}
					Saving returns it to <strong>pending review</strong>.
				</>
			)}
		</p>

		<form id="contribute-page-form" method="post" action={`/api/contribute/submissions/${sub.id}`}>
			<section class="contribute-card">
				<h2 class="contribute-card__h">Settings</h2>
				<div class="contribute-card__bd">
					<div class="row">
						<label>
							<span>Slug</span>
							<input
								type="text"
								name="slug"
								required
								value={p.slug}
								pattern="[a-z0-9]+(-[a-z0-9]+)*"
							/>
						</label>
					</div>
					<div class="row">
						<label>
							<span>List order (optional)</span>
							<input type="number" name="sort_order" value={p.sort_order} step="1" />
						</label>
					</div>
				</div>
			</section>

			<section class="contribute-card">
				<h2 class="contribute-card__h">Content</h2>
				<div class="contribute-card__bd">
					<AdminPageLocalesFields post={synthetic} />
				</div>
			</section>
		</form>

		<ContributeSubmitBar formId="contribute-page-form" cancelHref={back} submitLabel="Save changes" />
	</div>
</Shell>
