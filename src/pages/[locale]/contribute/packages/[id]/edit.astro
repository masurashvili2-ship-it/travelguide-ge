			'<button type="button" class="btn btn-ghost btn-sm btn-danger-soft btn-remove-rule" aria-label="Remove rule">✕</button>' +
			'</div>' +
			'<div class="rule-extra" id="extra-' + id + '"></div>';
		rulesEl.appendChild(div);

		var kindEl = div.querySelector('.rule-kind');
		var extraEl = document.getElementById('extra-' + id);
		kindEl.value = existing?.kind || 'group';
		div.querySelector('.rule-discount').value = existing?.discount_pct || '';
		div.querySelector('.rule-label').value = existing?.label || '';

		function renderExtra() {
			if (kindEl.value === 'group') {
				extraEl.innerHTML = '<label>Min people: <input type="number" class="rule-min-pax" min="1" style="width:70px" /></label><label style="margin-left:0.5rem">Max people: <input type="number" class="rule-max-pax" min="1" placeholder="∞" style="width:70px" /></label>';
				if (existing?.min_pax != null) extraEl.querySelector('.rule-min-pax').value = existing.min_pax;
				if (existing?.max_pax != null) extraEl.querySelector('.rule-max-pax').value = existing.max_pax;
			} else if (kindEl.value === 'early_bird') {
				extraEl.innerHTML = '<label>Book at least <input type="number" class="rule-days-before" min="1" style="width:70px" /> days in advance</label>';
				if (existing?.days_before != null) extraEl.querySelector('.rule-days-before').value = existing.days_before;
			} else if (kindEl.value === 'seasonal') {
				extraEl.innerHTML = '<label>From: <input type="date" class="rule-date-from" /></label><label style="margin-left:0.5rem">To: <input type="date" class="rule-date-to" /></label>';
				if (existing?.date_from) extraEl.querySelector('.rule-date-from').value = existing.date_from;
				if (existing?.date_to) extraEl.querySelector('.rule-date-to').value = existing.date_to;
