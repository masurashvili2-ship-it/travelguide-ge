	function normalizeStop(s) {
		var k = s && s.kind;
		if (k !== 'start' && k !== 'stop' && k !== 'optional' && k !== 'end') k = 'stop';
		return {
			id: (s && s.id) || genId(),
			kind: k,
			title: (s && s.title) || '',
			body: (s && s.body) || '',
			timing_note: s && s.timing_note ? String(s.timing_note) : null,
		};
	}
	function normalizeDaysFromPkg(hours, existing) {
		var need = dayCountFromHours(hours);
		var days = [];
		var i;
		if (existing && existing.length) {
			for (i = 0; i < need; i++) {
				var d = existing[i];
				if (d && d.stops && d.stops.length) {
					days.push({
						id: d.id || genId(),
						day_index: i + 1,
						title: d.title != null && String(d.title).trim() ? String(d.title).trim() : null,
						stops: d.stops.map(normalizeStop),
					});
				} else days.push(emptyDay(i));
			}
		} else for (i = 0; i < need; i++) days.push(emptyDay(i));
		return days;
	}
	function resizeDays(need, prev) {
		var next = [];
		for (var i = 0; i < need; i++) next.push(prev[i] ? prev[i] : emptyDay(i));
		return next;
	}
	function currentDurationHours() {
		var el = document.querySelector('[name="duration_preset"]');
