	/** Same rules as server `validatePackageForReview` (for clear UX before save). */
	function reviewValidationErrors(data) {
		var errs = [];
		if (!(data.cover_photo && String(data.cover_photo).trim()))
			errs.push('Add a cover photo (upload above or paste an image URL).');
		if (!data.gallery || !data.gallery.length)
			errs.push('Add at least one gallery image (upload or paste one URL per line).');
		var en = data.i18n && data.i18n.en;
		if (!en || !String(en.title || '').trim()) errs.push('English title is required.');
		if (data.tour_style === 'private') {
			var hasTier = (data.private_tiers || []).some(function (t) {
				return t.price > 0;
			});
			if (!hasTier) errs.push('Private tours need at least one group-size tier with a price set.');
		} else {
			if (!data.base_price || data.base_price <= 0)
				errs.push('Set a base price per person greater than 0 for group tours.');
		}
		var hours = data.duration_hours || 8;
		var daysNeeded = Math.max(1, Math.ceil(Math.max(1, hours) / 24));
		var it = (en && en.itinerary_days) || [];
		if (it.length < daysNeeded) {
			errs.push(
				'Complete the English itinerary: ' + daysNeeded + ' day block(s) required for this tour length.',
			);
		}
		for (var d = 0; d < daysNeeded; d++) {
			var day = it[d];
			var label = 'Day ' + (d + 1);
			if (!day || !day.stops || !day.stops.length) {
				errs.push(label + ': add itinerary segments (start, stops, end).');
				continue;
			}
			var stops = day.stops;
			if (stops[0].kind !== 'start')
				errs.push(label + ': the first segment must be “Starting” (first row).');
			if (stops[stops.length - 1].kind !== 'end')
				errs.push(label + ': the last segment must be “Ending” (last row).');
			var middle = stops.slice(1, -1);
			if (middle.length < 1) errs.push(label + ': add at least one main stop between start and end.');
			for (var i = 0; i < stops.length; i++) {
				var s = stops[i];
				if (!String(s.title || '').trim())
					errs.push(label + ', segment ' + (i + 1) + ': add a title.');
				if (!String(s.body || '').trim())
					errs.push(label + ', segment ' + (i + 1) + ': add a description.');
				if (i > 0 && i < stops.length - 1 && s.kind !== 'stop' && s.kind !== 'optional') {
					errs.push(label + ', segment ' + (i + 1) + ': middle segments must be Stop or Optional stop.');
				}
			}
		}
		return errs;
	}

	function showPkgFormMessage(statusEl, submitBtn, errs, isError) {
		if (!statusEl) {
			window.alert(errs.join('\n'));
			if (submitBtn) {
				submitBtn.disabled = false;
				submitBtn.textContent = submitBtn.getAttribute('data-label-submit') || 'Submit for Review';
			}
			return;
		}
		if (errs.length === 1) {
			statusEl.textContent = errs[0];
		} else {
			statusEl.innerHTML =
				'<strong>Please fix the following:</strong><ul class="pkg-form-error-list">' +
				errs
					.map(function (e) {
						return '<li>' + String(e).replace(/&/g, '&amp;').replace(/</g, '&lt;') + '</li>';
					})
					.join('') +
				'</ul>';
		}
		statusEl.className = 'notice ' + (isError ? 'notice-error' : 'notice-info');
		statusEl.style.display = 'block';
		statusEl.setAttribute('role', 'alert');
		try {
			statusEl.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
		} catch (e) {}
		if (submitBtn) {
			submitBtn.disabled = false;
			submitBtn.textContent = submitBtn.getAttribute('data-label-submit') || 'Submit for Review';
		}
	}

	function hoursToPreset(h) {
		for (var key in DURATION_MAP) {
			if (DURATION_MAP[key].hours === h) return key;
		}
		// Fallback: nearest day
		if (h <= 4) return 'half_day';
		if (h <= 8) return 'full_day';
		var days = Math.round(h / 24);
		var k = days + 'd';
		return DURATION_MAP[k] ? k : 'full_day';
	}

