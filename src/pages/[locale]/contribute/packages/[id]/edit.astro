@media (max-width: 600px) { .tour-style-grid { grid-template-columns: 1fr; } }
.tour-style-option { cursor: pointer; }
.tour-style-option input[type="radio"] { display: none; }
.tour-style-card { border: 2px solid #e2e8f0; border-radius: 12px; padding: 1.1rem 1.2rem; background: #f8fafc; transition: border-color 0.15s, background 0.15s; }
.tour-style-card:hover { border-color: #a5b4fc; background: #f5f3ff; }
.tour-style-option input:checked + .tour-style-card { border-color: #4f46e5; background: #eff6ff; }
.tour-style-icon { font-size: 1.5rem; display: block; margin-bottom: 0.3rem; }
.tour-style-card strong { font-size: 1rem; display: block; margin-bottom: 0.25rem; }
.tour-style-card p { font-size: 0.82rem; color: #64748b; margin: 0; line-height: 1.45; }
.tier-table-wrap { overflow-x: auto; }
.tier-table { width: 100%; border-collapse: collapse; font-size: 0.9rem; }
.tier-table th { text-align: left; padding: 0.5rem 0.75rem; background: #f1f5f9; font-size: 0.78rem; color: #64748b; font-weight: 700; text-transform: uppercase; letter-spacing: 0.04em; border-bottom: 1px solid #e2e8f0; }
.tier-table td { padding: 0.6rem 0.75rem; border-bottom: 1px solid #f1f5f9; vertical-align: middle; }
.tier-table tr:last-child td { border-bottom: none; }
.tier-range { color: #64748b; font-size: 0.85rem; }
.tier-hint { font-size: 0.8rem; }
.tier-price-input { width: 120px; padding: 0.4rem 0.6rem; border: 1px solid #cbd5e1; border-radius: 7px; font-size: 0.9rem; font-family: inherit; }
.tier-price-input:focus { outline: none; border-color: #4f46e5; box-shadow: 0 0 0 3px rgba(79,70,229,.1); }
.checkbox-row-label { display: flex; align-items: center; gap: 0.5rem; cursor: pointer; font-size: 0.925rem; font-weight: 500; }
.checkbox-row-label input[type="checkbox"] { width: 16px; height: 16px; cursor: pointer; }
</style>
