	function openLinkPanel(q) {
		var p = document.getElementById('pkg-link-panel');
		if (!p) return;
		p.style.display = 'block';
		p.innerHTML = '<p class="muted">Loading…</p>';
		var url =
			'/api/contribute/package-link-suggestions?q=' +
			encodeURIComponent(q) +
			'&locale=' +
			encodeURIComponent(contributeLocale);
		fetch(url, { credentials: 'same-origin' })
			.then(function (r) {
				return r.json();
			})
			.then(function (data) {
				var s = data.suggestions || [];
				if (!s.length) {
					p.innerHTML = '<p class="muted">No matches. Select words in the text and try again.</p>';
					return;
				}
				p.innerHTML = '<p class="pkg-link-panel__title">Insert link</p><ul class="pkg-link-panel__list"></ul>';
				var ul = p.querySelector('ul');
				s.forEach(function (item) {
					var li = document.createElement('li');
					var btn = document.createElement('button');
					btn.type = 'button';
					btn.className = 'pkg-link-item';
					btn.textContent = item.title + ' · ' + item.kind;
					btn.addEventListener('click', function () {
						if (!linkTargetTa) return;
						var md = '[' + item.title.replace(/\]/g, '') + '](/' + contributeLocale + '/' + item.path + ')';
						var v = linkTargetTa.value;
						var st = linkTargetTa.selectionStart || 0;
						var en = linkTargetTa.selectionEnd || 0;
						linkTargetTa.value = v.slice(0, st) + md + v.slice(en);
						p.style.display = 'none';
						linkTargetTa.focus();
					});
					li.appendChild(btn);
					ul.appendChild(li);
				});
			})
			.catch(function () {
				p.innerHTML = '<p class="muted">Could not load suggestions.</p>';
			});
	}
	function renderItineraryUi() {
		var need = dayCountFromHours(currentDurationHours());
