---
import Shell from '../../../../../components/Shell.astro';
import { getRelativeLocaleUrl } from 'astro:i18n';
import type { Locale } from '../../../../../lib/strings';
import { getPackageById } from '../../../../../lib/guide-packages-db';
import { getGuides } from '../../../../../lib/guides-db';
import '../../../../../styles/contribute.css';
import AdminTourPhotoUpload from '../../../../../components/admin/AdminTourPhotoUpload.astro';

export const prerender = false;

const loc = Astro.params.locale;
if (loc !== 'en' && loc !== 'ka' && loc !== 'ru') return new Response(null, { status: 404 });
const locale = loc as Locale;

if (!Astro.locals.user) {
	return Astro.redirect(`${getRelativeLocaleUrl(locale, 'login')}?next=${encodeURIComponent(Astro.url.pathname)}`);
}
const user = Astro.locals.user;

const pkg = getPackageById(Astro.params.id ?? '');
if (!pkg) return new Response(null, { status: 404 });

// Verify ownership (or admin)
const allGuides = getGuides();
const myGuide = allGuides.find((g) => g.author_user_id === user.id) ?? null;
if (user.role !== 'admin' && pkg.guide_id !== myGuide?.id) {
	return new Response(null, { status: 403 });
}

const backUrl = getRelativeLocaleUrl(locale, 'contribute/packages');
const calendarUrl = getRelativeLocaleUrl(locale, `contribute/packages/${pkg.id}/calendar`);
const bookingsUrl = getRelativeLocaleUrl(locale, `contribute/packages/${pkg.id}/bookings`);
const pkgJson = JSON.stringify(pkg).replace(/</g, '\\u003c');
const isAdmin = user.role === 'admin';
---

<Shell
	locale={locale}
	subpath="contribute"
	title="Edit Package"
	seoTitle="Edit Package"
	robotsNoindex={true}
>
	<div class="contribute-page">
		<p class="muted" style="margin-top:0"><a href={backUrl}>← Back to Packages</a></p>
		<div style="display:flex;align-items:center;gap:1rem;flex-wrap:wrap;margin-bottom:1rem">
			<h1 style="margin:0">Edit Package</h1>
			<div style="display:flex;gap:0.5rem;flex-wrap:wrap;align-items:center">
				<a href={calendarUrl} class="btn btn-ghost btn-sm">Manage Calendar</a>
				<a href={bookingsUrl} class="btn btn-ghost btn-sm">View Bookings</a>
			</div>
		</div>

		<div id="pkg-status" class="notice" style="display:none"></div>

		<form id="pkg-form" novalidate>
		<!-- ── Tour Type (choose first) ─────────────────────────── -->
		<section class="contribute-card">
			<h2 class="contribute-card__h">Tour Type</h2>
			<div class="contribute-card__bd">
				<p class="muted" style="font-size:0.88rem;margin:0 0 1rem;line-height:1.5">
					Choose whether this package is a <strong>group</strong> tour (per-person pricing) or a <strong>private</strong> tour (fixed price by group size). You can change this later.
				</p>
				<div class="tour-style-grid">
					<label class="tour-style-option">
						<input type="radio" name="tour_style" value="group" id="style-group" />
						<div class="tour-style-card">
							<span class="tour-style-icon">👥</span>
							<strong>Group Tour</strong>
							<p>Shared departures. Per-person pricing.</p>
						</div>
					</label>
					<label class="tour-style-option">
						<input type="radio" name="tour_style" value="private" id="style-private" />
						<div class="tour-style-card">
							<span class="tour-style-icon">🔒</span>
							<strong>Private Guided Tour</strong>
							<p>Exclusive, just for one group. Fixed total price by group size.</p>
						</div>
					</label>
				</div>
				<div id="private-tiers-section" style="display:none;margin-top:1.5rem">
					<h3 style="margin:0 0 0.4rem;font-size:0.95rem;font-weight:700">Pricing by Group Size</h3>
					<p class="muted" style="font-size:0.85rem;margin:0 0 1rem">Set a fixed total price per tier. Leave blank to hide that tier from booking.</p>
					<div class="tier-table-wrap">
						<table class="tier-table">
							<thead>
								<tr><th>Tier</th><th>Group Size</th><th>Total Price (per group)</th><th>Vehicle</th><th>Transport notes</th></tr>
							</thead>
							<tbody id="tier-tbody">
								<tr data-tier-id="t1" data-min="1" data-max="3" data-label="Solo & Couple">
									<td><strong>Solo &amp; Couple</strong></td><td class="tier-range">1–3 people</td>
									<td><input type="number" class="tier-price-input" min="0" step="0.01" placeholder="—" /></td>
									<td>
										<select class="tier-vehicle-select" aria-label="Vehicle for this tier">
											<option value="">— Not set —</option>
											<option value="sedan">🚗 Sedan (2–3 pax)</option>
											<option value="suv">🚙 SUV / Crossover (3–5 pax)</option>
											<option value="minivan">🚐 Minivan (5–8 pax)</option>
											<option value="minibus">🚌 Minibus (8–20 pax)</option>
											<option value="bus">🚌 Coach Bus (20+ pax)</option>
											<option value="boat">⛵ Boat</option>
											<option value="other">Other</option>
										</select>
									</td>
									<td>
										<input type="text" class="tier-transport-notes-input" placeholder="e.g. Mercedes V-class" aria-label="Transport notes for this tier" />
									</td>
								</tr>
								<tr data-tier-id="t2" data-min="4" data-max="6" data-label="Small Group">
									<td><strong>Small Group</strong></td><td class="tier-range">4–6 people</td>
									<td><input type="number" class="tier-price-input" min="0" step="0.01" placeholder="—" /></td>
									<td>
										<select class="tier-vehicle-select" aria-label="Vehicle for this tier">
											<option value="">— Not set —</option>
											<option value="sedan">🚗 Sedan (2–3 pax)</option>
											<option value="suv">🚙 SUV / Crossover (3–5 pax)</option>
											<option value="minivan">🚐 Minivan (5–8 pax)</option>
											<option value="minibus">🚌 Minibus (8–20 pax)</option>
											<option value="bus">🚌 Coach Bus (20+ pax)</option>
											<option value="boat">⛵ Boat</option>
											<option value="other">Other</option>
										</select>
									</td>
									<td>
										<input type="text" class="tier-transport-notes-input" placeholder="e.g. Mercedes V-class" aria-label="Transport notes for this tier" />
									</td>
								</tr>
								<tr data-tier-id="t3" data-min="7" data-max="11" data-label="Medium Group">
									<td><strong>Medium Group</strong></td><td class="tier-range">7–11 people</td>
									<td><input type="number" class="tier-price-input" min="0" step="0.01" placeholder="—" /></td>
									<td>
										<select class="tier-vehicle-select" aria-label="Vehicle for this tier">
											<option value="">— Not set —</option>
											<option value="sedan">🚗 Sedan (2–3 pax)</option>
											<option value="suv">🚙 SUV / Crossover (3–5 pax)</option>
											<option value="minivan">🚐 Minivan (5–8 pax)</option>
											<option value="minibus">🚌 Minibus (8–20 pax)</option>
											<option value="bus">🚌 Coach Bus (20+ pax)</option>
											<option value="boat">⛵ Boat</option>
											<option value="other">Other</option>
										</select>
									</td>
									<td>
										<input type="text" class="tier-transport-notes-input" placeholder="e.g. Mercedes V-class" aria-label="Transport notes for this tier" />
									</td>
								</tr>
								<tr data-tier-id="t4" data-min="12" data-max="16" data-label="Large Group">
									<td><strong>Large Group</strong></td><td class="tier-range">12–16 people</td>
									<td><input type="number" class="tier-price-input" min="0" step="0.01" placeholder="—" /></td>
									<td>
										<select class="tier-vehicle-select" aria-label="Vehicle for this tier">
											<option value="">— Not set —</option>
											<option value="sedan">🚗 Sedan (2–3 pax)</option>
											<option value="suv">🚙 SUV / Crossover (3–5 pax)</option>
											<option value="minivan">🚐 Minivan (5–8 pax)</option>
											<option value="minibus">🚌 Minibus (8–20 pax)</option>
											<option value="bus">🚌 Coach Bus (20+ pax)</option>
											<option value="boat">⛵ Boat</option>
											<option value="other">Other</option>
										</select>
									</td>
									<td>
										<input type="text" class="tier-transport-notes-input" placeholder="e.g. Mercedes V-class" aria-label="Transport notes for this tier" />
									</td>
								</tr>
								<tr data-tier-id="t5" data-min="17" data-max="25" data-label="XL Group">
									<td><strong>XL Group</strong></td><td class="tier-range">17–25 people</td>
									<td><input type="number" class="tier-price-input" min="0" step="0.01" placeholder="—" /></td>
									<td>
										<select class="tier-vehicle-select" aria-label="Vehicle for this tier">
											<option value="">— Not set —</option>
											<option value="sedan">🚗 Sedan (2–3 pax)</option>
											<option value="suv">🚙 SUV / Crossover (3–5 pax)</option>
											<option value="minivan">🚐 Minivan (5–8 pax)</option>
											<option value="minibus">🚌 Minibus (8–20 pax)</option>
											<option value="bus">🚌 Coach Bus (20+ pax)</option>
											<option value="boat">⛵ Boat</option>
											<option value="other">Other</option>
										</select>
									</td>
									<td>
										<input type="text" class="tier-transport-notes-input" placeholder="e.g. Mercedes V-class" aria-label="Transport notes for this tier" />
									</td>
								</tr>
								<tr data-tier-id="t6" data-min="26" data-max="30" data-label="XXL Group">
									<td><strong>XXL Group</strong></td><td class="tier-range">26–30 people</td>
									<td><input type="number" class="tier-price-input" min="0" step="0.01" placeholder="—" /></td>
									<td>
										<select class="tier-vehicle-select" aria-label="Vehicle for this tier">
											<option value="">— Not set —</option>
											<option value="sedan">🚗 Sedan (2–3 pax)</option>
											<option value="suv">🚙 SUV / Crossover (3–5 pax)</option>
											<option value="minivan">🚐 Minivan (5–8 pax)</option>
											<option value="minibus">🚌 Minibus (8–20 pax)</option>
											<option value="bus">🚌 Coach Bus (20+ pax)</option>
											<option value="boat">⛵ Boat</option>
											<option value="other">Other</option>
										</select>
									</td>
									<td>
										<input type="text" class="tier-transport-notes-input" placeholder="e.g. Mercedes V-class" aria-label="Transport notes for this tier" />
									</td>
								</tr>
							</tbody>
						</table>
					</div>
				</div>
			</div>
		</section>

			<section class="contribute-card">
				<h2 class="contribute-card__h">Basic Info</h2>
				<div class="contribute-card__bd">
					<div class="row">
						<label>
							<span>Slug <em>*</em></span>
							<input type="text" id="pkg-slug" name="slug" required pattern="[a-z0-9]+(-[a-z0-9]+)*" />
						</label>
					</div>
					{isAdmin && (
						<div class="row">
							<label>
								<span>Status (admin only)</span>
								<select name="status" id="pkg-status-select">
									<option value="draft">Draft</option>
									<option value="pending_review">Pending Review</option>
									<option value="published">Published</option>
								</select>
							</label>
						</div>
					)}
					<div class="row">
						<label>
							<span>Duration <em>*</em></span>
							<select name="duration_preset" id="pkg-duration-preset" required>
								<option value="half_day">Half day (4h)</option>
								<option value="full_day">Full day (8h)</option>
								<option value="2d">2 days</option>
								<option value="3d">3 days</option>
								<option value="4d">4 days</option>
								<option value="5d">5 days</option>
								<option value="6d">6 days</option>
								<option value="7d">7 days</option>
								<option value="8d">8 days</option>
								<option value="9d">9 days</option>
								<option value="10d">10 days</option>
								<option value="11d">11 days</option>
								<option value="12d">12 days</option>
								<option value="13d">13 days</option>
								<option value="14d">14 days</option>
							</select>
						</label>
					</div>
					<div class="row" id="group-capacity-row" style="display:grid;grid-template-columns:1fr 1fr;gap:1rem">
						<label>
							<span>Min people</span>
							<input type="number" name="min_people" min="1" max="100" />
						</label>
						<label>
							<span>Max people</span>
							<input type="number" name="max_people" min="1" max="100" />
						</label>
					</div>
					<div class="row">
						<label>
							<span>Currency</span>
							<select name="currency">
								<option value="USD">USD $</option>
								<option value="EUR">EUR €</option>
								<option value="GEL">GEL ₾</option>
							</select>
						</label>
					</div>
					<div class="row">
						<label>
							<span>Base price per person</span>
							<input type="number" name="base_price" min="0" step="0.01" />
						</label>
					</div>
					<div class="row">
						<label>
							<span>Languages (comma-separated)</span>
							<input type="text" name="languages" placeholder="en, ka" />
						</label>
					</div>
					<div class="row">
						<AdminTourPhotoUpload
							formId="pkg-form"
							uploadApiPath="/api/contribute/upload-package-image"
							slugInputId="pkg-slug"
							widgetPrefix="pkg"
						/>
					</div>
					<div class="row">
						<label>
							<span>Cover photo URL</span>
							<input type="url" name="cover_photo" id="pkg-cover-url" placeholder="https://… or upload above" />
						</label>
					</div>
					<div class="row">
						<label>
							<span>Gallery (one image URL per line)</span>
							<textarea name="gallery_urls" id="pkg-gallery-urls" rows="4" placeholder="/uploads/packages/…"></textarea>
						</label>
					</div>
				</div>
			</section>

			<section class="contribute-card">
				<h2 class="contribute-card__h">Tour Details (English)</h2>
				<div class="contribute-card__bd">
					<div class="row"><label><span>Title <em>*</em></span><input type="text" name="en_title" required /></label></div>
					<div class="row"><label><span>Description</span><textarea name="en_description" rows="5"></textarea></label></div>
					<div class="row"><label><span>Long article (optional, Markdown)</span><textarea name="en_body" rows="8" placeholder="Extended story below the itinerary…"></textarea></label></div>
					<div class="row"><label><span>What's included</span><textarea name="en_includes_text" rows="4"></textarea></label></div>
					<div class="row"><label><span>What's excluded</span><textarea name="en_excludes_text" rows="3"></textarea></label></div>
					<div class="row"><label><span>Meeting point</span><input type="text" name="en_meeting_point_text" /></label></div>
				</div>
			</section>

			<section class="contribute-card">
				<h2 class="contribute-card__h">Tour Details (Georgian)</h2>
				<div class="contribute-card__bd">
					<div class="row"><label><span>Title</span><input type="text" name="ka_title" /></label></div>
					<div class="row"><label><span>Description</span><textarea name="ka_description" rows="4"></textarea></label></div>
				</div>
			</section>

			<section class="contribute-card">
				<h2 class="contribute-card__h">Tour Details (Russian)</h2>
				<div class="contribute-card__bd">
					<div class="row"><label><span>Title</span><input type="text" name="ru_title" /></label></div>
					<div class="row"><label><span>Description</span><textarea name="ru_description" rows="4"></textarea></label></div>
				</div>
			</section>

			<section class="contribute-card">
				<h2 class="contribute-card__h">Itinerary (English)</h2>
				<div class="contribute-card__bd">
					<p class="muted" style="font-size:0.9rem;line-height:1.5">
						One block per calendar day (based on duration). Use <strong>Add segment</strong> to choose Starting, Stop, Optional stop, or Ending — then fill title, optional time (24-hour, 15-minute steps), and description. For submit, the day must begin with Starting, end with Ending, and include at least one main stop. <strong>Markdown</strong> and <em>Link suggestions</em> work in descriptions.
					</p>
					<div id="pkg-itinerary-day-tabs" class="pkg-itin-tabs" role="tablist" aria-label="Itinerary day"></div>
					<div id="pkg-itinerary-root" class="pkg-itin-editor-root"></div>
					<div id="pkg-link-panel" class="pkg-link-panel" style="display:none" role="region" aria-label="Suggested links"></div>
				</div>
			</section>

		<!-- ── Transportation & Logistics ───────────────────── -->
		<section class="contribute-card">
			<h2 class="contribute-card__h">Transportation & Logistics</h2>
			<div class="contribute-card__bd">
				<div class="row">
					<label class="checkbox-row-label">
						<input type="checkbox" name="transport_included" id="transport-included" />
						<span>Transportation is included in the tour price</span>
					</label>
				</div>
				<div class="row" style="margin-top:0.75rem">
					<label class="checkbox-row-label">
						<input type="checkbox" name="pickup_offered" id="pickup-offered" />
						<span>Hotel / airport pickup & drop-off available</span>
					</label>
				</div>
				<div id="pickup-details" style="display:none;margin-top:0.5rem">
					<div class="row">
						<label><span>Pickup notes</span>
							<input type="text" name="pickup_notes" placeholder="e.g. Free pickup within Tbilisi city centre" />
						</label>
					</div>
				</div>
			</div>
		</section>

		<!-- ── Additional Info ───────────────────────────────── -->
		<section class="contribute-card">
			<h2 class="contribute-card__h">Additional Information</h2>
			<div class="contribute-card__bd">
				<div class="row" style="display:grid;grid-template-columns:1fr 1fr;gap:1rem">
					<label><span>Difficulty level</span>
						<select name="difficulty">
							<option value="">Not specified</option>
							<option value="easy">🟢 Easy — suitable for all</option>
							<option value="moderate">🟡 Moderate — some walking required</option>
							<option value="challenging">🔴 Challenging — good fitness needed</option>
						</select>
					</label>
					<label><span>Minimum age (blank = no restriction)</span>
						<input type="number" name="min_age" min="0" max="99" placeholder="e.g. 6" />
					</label>
				</div>
				<div class="row">
					<label><span>Cancellation & refund policy</span>
						<textarea name="cancellation_policy" rows="2" placeholder="e.g. Full refund 48h before. 50% within 24h."></textarea>
					</label>
				</div>
			</div>
		</section>

		<section class="contribute-card">
			<h2 class="contribute-card__h">Pricing Rules & Discounts</h2>
			<div class="contribute-card__bd">
				<p class="muted">The best applicable discount is applied automatically at checkout.</p>
				<div id="rules-list"></div>
				<button type="button" id="add-rule-btn" class="btn btn-ghost btn-sm" style="margin-top:0.5rem">+ Add discount rule</button>
			</div>
		</section>

		<div class="pkg-form-actions" style="margin-top:1.5rem;display:flex;gap:0.75rem;align-items:center;flex-wrap:wrap">
			<button type="submit" class="btn" id="pkg-submit-btn" data-action="review" data-label-submit="Submit for Review">Submit for Review</button>
			<button type="button" class="btn btn-ghost btn-sm" id="pkg-draft-btn">Save as Draft</button>
			<a href={backUrl} class="btn btn-ghost btn-sm">Cancel</a>
			<button type="button" class="btn btn-ghost btn-sm btn-danger-soft" id="pkg-delete-btn" style="margin-left:auto">Delete Package</button>
		</div>
		{!isAdmin && <p class="muted" style="font-size:0.85rem;margin-top:0.5rem">Changes will be reviewed by admin before going live.</p>}
		</form>
	</div>
</Shell>

<script is:inline define:vars={{ pkgJson, backUrl, isAdmin, contributeLocale: locale }}>
(function () {
	var pkg = JSON.parse(pkgJson);
	var rulesEl = document.getElementById('rules-list');
	var ruleCount = 0;

	var DURATION_MAP = {
		'half_day': { hours: 4, label: 'Half day' },
		'full_day': { hours: 8, label: 'Full day' },
		'2d':  { hours: 48,  label: '2 days' },
		'3d':  { hours: 72,  label: '3 days' },
		'4d':  { hours: 96,  label: '4 days' },
		'5d':  { hours: 120, label: '5 days' },
		'6d':  { hours: 144, label: '6 days' },
		'7d':  { hours: 168, label: '7 days' },
		'8d':  { hours: 192, label: '8 days' },
		'9d':  { hours: 216, label: '9 days' },
		'10d': { hours: 240, label: '10 days' },
		'11d': { hours: 264, label: '11 days' },
		'12d': { hours: 288, label: '12 days' },
		'13d': { hours: 312, label: '13 days' },
		'14d': { hours: 336, label: '14 days' },
	};

	var itinDays = [];
	var activeItinDay = 0;
	var linkTargetTa = null;

	function genId() {
		return crypto.randomUUID ? crypto.randomUUID() : 's' + Math.random().toString(36).slice(2);
	}
	function dayCountFromHours(h) {
		h = Math.max(1, Number(h) || 8);
		return Math.max(1, Math.ceil(h / 24));
	}
	function emptyDay(idx) {
		return { id: genId(), day_index: idx + 1, title: null, stops: [] };
	}
	var TIME_QUARTER_HOURS = [];
	(function initTimeSlots() {
		for (var h = 0; h < 24; h++) {
			for (var m = 0; m < 60; m += 15) {
				TIME_QUARTER_HOURS.push(
					(h < 10 ? '0' : '') + h + ':' + (m < 10 ? '0' : '') + m,
				);
			}
		}
	})();
	function fillTimingSelect(selectEl, currentVal) {
		var v = currentVal ? String(currentVal).trim() : '';
		selectEl.innerHTML = '';
		var opt0 = document.createElement('option');
		opt0.value = '';
		opt0.textContent = '— Time (optional) —';
		selectEl.appendChild(opt0);
		var found = !v;
		for (var i = 0; i < TIME_QUARTER_HOURS.length; i++) {
			var t = TIME_QUARTER_HOURS[i];
			var o = document.createElement('option');
			o.value = t;
			o.textContent = t;
			selectEl.appendChild(o);
			if (v === t) found = true;
		}
		if (v && !found) {
			var oc = document.createElement('option');
			oc.value = v;
			oc.textContent = v + ' (saved)';
			selectEl.appendChild(oc);
