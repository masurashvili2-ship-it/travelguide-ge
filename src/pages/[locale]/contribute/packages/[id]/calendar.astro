.cal-nav-btn { background: transparent; border: 1px solid #e2e8f0; border-radius: 7px; font-size: 1.3rem; cursor: pointer; padding: 0.1rem 0.65rem; color: #475569; line-height: 1.6; }
.cal-nav-btn:hover { background: #f1f5f9; }

.cal-grid { display: grid; grid-template-columns: repeat(7, 1fr); }
.cal-day-header { padding: 0.35rem 0.2rem; text-align: center; font-size: 0.7rem; font-weight: 700; color: #94a3b8; background: #f8fafc; border-bottom: 1px solid #e2e8f0; letter-spacing: 0.04em; text-transform: uppercase; }
.cal-cell {
	min-height: 58px; padding: 0.25rem; border: 1px solid #f1f5f9;
	cursor: pointer; position: relative;
	display: flex; flex-direction: column; align-items: center; gap: 2px;
	transition: background 0.12s;
	user-select: none;
}
.cal-cell:hover:not(.cal-cell--empty):not(.cal-cell--past) { background: #f0f9ff; }
.cal-cell--empty  { cursor: default; background: #fafafa; }
.cal-cell--past   { opacity: 0.38; cursor: default; }

/* Today ring */
.cal-cell--today .cal-day-num {
	background: #4f46e5; color: #fff;
	border-radius: 50%; width: 22px; height: 22px;
	display: flex; align-items: center; justify-content: center;
}
/* Single selection */
.cal-cell--selected { background: #eff6ff !important; outline: 2px solid #4f46e5; outline-offset: -2px; }
/* Multi selection */
.cal-cell--multi { background: #f0fdf4 !important; outline: 2px solid #16a34a; outline-offset: -2px; }
/* Range selection */
.cal-cell--range           { background: #e0e7ff !important; }
.cal-cell--range-start     { background: #c7d2fe !important; border-radius: 8px 0 0 8px; outline: 2px solid #4f46e5; outline-offset: -2px; }
.cal-cell--range-end       { background: #c7d2fe !important; border-radius: 0 8px 8px 0; outline: 2px solid #4f46e5; outline-offset: -2px; }
/* Start = end (single day range) */
.cal-cell--range-start.cal-cell--range-end { border-radius: 8px; }

.cal-day-num { font-size: 0.82rem; font-weight: 500; line-height: 1; }

/* Status dots */
.cal-dot {
	width: 8px; height: 8px; border-radius: 50%;
	display: inline-block; flex-shrink: 0;
	box-shadow: 0 0 0 1.5px #fff; /* white ring so dot pops on any background */
}
.cal-dot--open    { background: #16a34a; }
.cal-dot--booked  { background: #f59e0b; }
.cal-dot--full    { background: #dc2626; }
.cal-dot--blocked { background: #94a3b8; }
/* Make dots brighter on highlighted cells */
.cal-cell--range .cal-dot,
.cal-cell--range-start .cal-dot,
.cal-cell--range-end .cal-dot,
.cal-cell--multi .cal-dot {
	box-shadow: 0 0 0 2px rgba(255,255,255,0.9);
	width: 9px; height: 9px;
}

.cal-time  { font-size: 0.6rem; color: #64748b; line-height: 1; }
.cal-price { font-size: 0.6rem; color: #4f46e5; font-weight: 700; line-height: 1; }

.cal-legend { display: flex; gap: 0.85rem; padding: 0.5rem 0.85rem; border-top: 1px solid #e2e8f0; flex-wrap: wrap; }
.cal-legend-item { display: flex; align-items: center; gap: 4px; font-size: 0.78rem; color: #64748b; }

/* ── Sidebar / panels ───────────────────────────────────────── */
.cal-sidebar { display: flex; flex-direction: column; gap: 0.75rem; position: sticky; top: 1rem; }
.cal-panel {
	background: #fff; border: 1px solid #e2e8f0; border-radius: 14px; padding: 1rem;
}
.cal-panel--hint { border-style: dashed; background: transparent; }
.cal-panel__h { margin: 0 0 0.85rem; font-size: 1rem; font-weight: 700; }

.field-row { margin-bottom: 0.75rem; }
.field-row label { display: flex; flex-direction: column; gap: 0.3rem; font-size: 0.875rem; font-weight: 600; color: #374151; }
.field-row input, .field-row select { padding: 0.45rem 0.6rem; border: 1px solid #cbd5e1; border-radius: 7px; font-size: 0.9rem; font-family: inherit; width: 100%; box-sizing: border-box; }
.field-row input:focus, .field-row select:focus { outline: none; border-color: #4f46e5; box-shadow: 0 0 0 3px rgba(79,70,229,.1); }
.field-hint { font-size: 0.78rem; color: #94a3b8; margin: 0.2rem 0 0; }
.muted-inline { font-weight: 400; color: #94a3b8; }
.booked-info { font-size: 0.8rem; color: #64748b; margin-top: 0.5rem; }

.btn-danger { color: #dc2626 !important; border-color: #fecaca !important; }
.btn-danger:hover { background: #fff1f2 !important; }

/* Bulk summary */
.bulk-summary { font-size: 0.82rem; font-weight: 600; color: #4f46e5; background: #eff6ff; border-radius: 6px; padding: 0.4rem 0.6rem; margin-bottom: 0.75rem; }

/* Field sections */
.field-section { margin-bottom: 0.75rem; }
.field-section__label { font-size: 0.75rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.06em; color: #94a3b8; margin: 0 0 0.4rem; }

/* Day-of-week buttons */
.dow-btns { display: flex; flex-wrap: wrap; gap: 0.35rem; margin-bottom: 0.5rem; }
.dow-preset { background: #f1f5f9; border: 1px solid #e2e8f0; border-radius: 6px; padding: 0.25rem 0.6rem; font-size: 0.78rem; font-weight: 600; cursor: pointer; color: #475569; }
.dow-preset.is-active { background: #4f46e5; color: #fff; border-color: #4f46e5; }
.dow-custom-row { display: flex; flex-wrap: wrap; gap: 0.4rem; margin-top: 0.35rem; }
.dow-check { display: flex; align-items: center; gap: 0.2rem; font-size: 0.8rem; background: #f8fafc; border: 1px solid #e2e8f0; border-radius: 5px; padding: 0.2rem 0.5rem; cursor: pointer; }

/* Pricing tabs */
.pricing-tabs { display: flex; gap: 0; border: 1px solid #e2e8f0; border-radius: 7px; overflow: hidden; margin-bottom: 0.5rem; }
.pricing-tab { flex: 1; background: #fff; border: none; border-right: 1px solid #e2e8f0; padding: 0.35rem 0.5rem; font-size: 0.78rem; font-weight: 600; cursor: pointer; color: #64748b; }
.pricing-tab:last-child { border-right: none; }
.pricing-tab.is-active  { background: #4f46e5; color: #fff; }
.pricing-content { font-size: 0.875rem; }
.pricing-content label { display: flex; flex-direction: column; gap: 0.3rem; font-size: 0.875rem; font-weight: 600; color: #374151; }
.pricing-content input { padding: 0.4rem 0.6rem; border: 1px solid #cbd5e1; border-radius: 7px; font-size: 0.9rem; font-family: inherit; }

/* Toast */
.cal-toast {
	position: fixed; bottom: 1.5rem; left: 50%; transform: translateX(-50%);
	background: #1e293b; color: #fff; border-radius: 8px;
	padding: 0.6rem 1.25rem; font-size: 0.9rem; font-weight: 500;
	z-index: 9999; box-shadow: 0 4px 16px rgba(0,0,0,.25);
	pointer-events: none;
}
.cal-toast--error { background: #dc2626; }
.cal-toast--success { background: #16a34a; }
</style>
