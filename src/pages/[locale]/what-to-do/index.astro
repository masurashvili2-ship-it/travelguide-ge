---
import Shell from '../../../components/Shell.astro';
import TourHeroGallery from '../../../components/TourHeroGallery.astro';
import { getRelativeLocaleUrl } from 'astro:i18n';
import { listWhatToDoForLocale, type TourListItem } from '../../../lib/tours-db';
import { WHAT_TO_DO_CATEGORY_IDS, type WhatToDoCategoryId } from '../../../lib/what-to-do-categories';
import { WHAT_TO_DO_SEASON_IDS, type WhatToDoSeasonId } from '../../../lib/what-to-do-seasons';
import { PHYSICAL_RATING_IDS, type TourPhysicalRatingId } from '../../../lib/tour-physical-rating';
import type { Locale } from '../../../lib/strings';
import { ui } from '../../../lib/strings';
import { isWhatToDoCategoryId } from '../../../lib/what-to-do-categories';
import { isWhatToDoSeasonId } from '../../../lib/what-to-do-seasons';
import { isTourPhysicalRatingId } from '../../../lib/tour-physical-rating';

const loc = Astro.params.locale;
if (loc !== 'en' && loc !== 'ka' && loc !== 'ru') {
	return new Response(null, { status: 404 });
}
const locale = loc as Locale;
const t = ui[locale];

function collectValidParam(name: string, isValid: (s: string) => boolean): string[] {
	const seen = new Set<string>();
	const out: string[] = [];
	for (const v of Astro.url.searchParams.getAll(name)) {
		const trimmed = v.trim();
		if (!trimmed || seen.has(trimmed) || !isValid(trimmed)) continue;
		seen.add(trimmed);
		out.push(trimmed);
	}
	return out;
}

const filterCategories = collectValidParam('category', isWhatToDoCategoryId);
const filterSeasons = collectValidParam('season', isWhatToDoSeasonId);
const filterRatings = collectValidParam('physical_rating', isTourPhysicalRatingId);

const hasActiveFilters =
	filterCategories.length > 0 || filterSeasons.length > 0 || filterRatings.length > 0;

function matchesFilters(entry: TourListItem): boolean {
	const d = entry.data;
	if (filterCategories.length > 0) {
		const tags = d.whatDoCategories ?? [];
		const fc = filterCategories as WhatToDoCategoryId[];
		if (!fc.some((id) => tags.includes(id))) return false;
	}
	if (filterSeasons.length > 0) {
		const seasons = d.whatDoSeasons ?? [];
		if (!filterSeasons.some((id) => seasons.includes(id))) return false;
	}
	if (filterRatings.length > 0) {
		const p = d.physical_rating;
		if (!p || !filterRatings.includes(p)) return false;
	}
	return true;
}

const allSorted = listWhatToDoForLocale(locale);
const filtered = hasActiveFilters ? allSorted.filter(matchesFilters) : allSorted;

const whatToDoPath = getRelativeLocaleUrl(locale, 'what-to-do');
const clearFiltersHref = whatToDoPath;

const showingLine =
	allSorted.length > 0
		? t.whatToDoFiltersShowing.replace('{n}', String(filtered.length)).replace('{total}', String(allSorted.length))
		: '';

function filterDropdownSummary(selectedIds: string[], labelFor: (id: string) => string): string {
	if (selectedIds.length === 0) return t.whatToDoFiltersAny;
	if (selectedIds.length === 1) return labelFor(selectedIds[0]!);
	return t.whatToDoFiltersNSelected.replace('{n}', String(selectedIds.length));
}

const categorySummary = filterDropdownSummary(filterCategories, (id) => t.whatToDoCategories[id as WhatToDoCategoryId]);
const seasonSummary = filterDropdownSummary(filterSeasons, (id) => t.whatToDoSeasons[id as WhatToDoSeasonId]);
const ratingSummary = filterDropdownSummary(filterRatings, (id) => t.tourPhysicalRatings[id as TourPhysicalRatingId]);
---

<Shell
	locale={locale}
	subpath="what-to-do"
	title={t.whatToDo}
	seoDescription={t.whatToDoMetaDescription}
	canonicalPath={`/${locale}/what-to-do`}
>
	<div class="wtd-layout">
		<aside class="wtd-filters" aria-label={t.whatToDoFiltersTitle}>
			<form class="wtd-filters__form" method="get" action={whatToDoPath}>
				<h2 class="wtd-filters__heading">{t.whatToDoFiltersTitle}</h2>
				{
					allSorted.length > 0 ? (
						<p class="wtd-filters__count muted" style="margin:0 0 1rem;font-size:0.9rem">
							{showingLine}
						</p>
					) : null
				}

				<div class="wtd-filters__dropdowns">
					<details
						class:list={['wtd-filter-dd', filterCategories.length > 0 && 'wtd-filter-dd--active']}
						name="wtd-filter-acc"
					>
						<summary class="wtd-filter-dd__trigger">
							<span class="wtd-filter-dd__text">
								<span class="wtd-filter-dd__label">{t.tourSidebarCategory}</span>
								<span class="wtd-filter-dd__value">{categorySummary}</span>
							</span>
							<span class="wtd-filter-dd__chevron" aria-hidden="true" />
						</summary>
						<div class="wtd-filter-dd__panel" role="group" aria-label={t.tourSidebarCategory}>
							{
								WHAT_TO_DO_CATEGORY_IDS.map((id) => (
									<label class="wtd-filter-dd__option">
										<input
											type="checkbox"
											name="category"
											value={id}
											checked={filterCategories.includes(id)}
										/>
										<span class="wtd-filter-dd__option-text">{t.whatToDoCategories[id]}</span>
									</label>
								))
							}
						</div>
					</details>

					<details
						class:list={['wtd-filter-dd', filterSeasons.length > 0 && 'wtd-filter-dd--active']}
						name="wtd-filter-acc"
					>
						<summary class="wtd-filter-dd__trigger">
							<span class="wtd-filter-dd__text">
								<span class="wtd-filter-dd__label">{t.tourSidebarSeason}</span>
								<span class="wtd-filter-dd__value">{seasonSummary}</span>
							</span>
							<span class="wtd-filter-dd__chevron" aria-hidden="true" />
						</summary>
						<div class="wtd-filter-dd__panel" role="group" aria-label={t.tourSidebarSeason}>
							{
								WHAT_TO_DO_SEASON_IDS.map((id) => (
									<label class="wtd-filter-dd__option">
										<input type="checkbox" name="season" value={id} checked={filterSeasons.includes(id)} />
										<span class="wtd-filter-dd__option-text">{t.whatToDoSeasons[id]}</span>
									</label>
								))
							}
						</div>
					</details>

					<details
						class:list={['wtd-filter-dd', filterRatings.length > 0 && 'wtd-filter-dd--active']}
						name="wtd-filter-acc"
					>
						<summary class="wtd-filter-dd__trigger">
							<span class="wtd-filter-dd__text">
								<span class="wtd-filter-dd__label">{t.tourSidebarPhysicalRating}</span>
								<span class="wtd-filter-dd__value">{ratingSummary}</span>
							</span>
							<span class="wtd-filter-dd__chevron" aria-hidden="true" />
						</summary>
						<div class="wtd-filter-dd__panel" role="group" aria-label={t.tourSidebarPhysicalRating}>
							{
								PHYSICAL_RATING_IDS.map((id) => (
									<label class="wtd-filter-dd__option">
										<input
											type="checkbox"
											name="physical_rating"
											value={id}
											checked={filterRatings.includes(id)}
										/>
										<span class="wtd-filter-dd__option-text">{t.tourPhysicalRatings[id]}</span>
									</label>
								))
							}
						</div>
					</details>
				</div>

				<div class="wtd-filters__actions">
					<button type="submit" class="btn">
						{t.whatToDoFiltersApply}
					</button>
					{
						hasActiveFilters ? (
							<a class="btn btn-ghost" href={clearFiltersHref}>
								{t.whatToDoFiltersClear}
							</a>
						) : null
					}
				</div>
			</form>
		</aside>

		<div class="wtd-main">
			{
				filtered.length > 0 ? (
					<TourHeroGallery
						tours={filtered}
						locale={locale}
						viewLabel={t.viewWhatToDo}
						durationLabel={t.duration}
						title={t.whatToDo}
						subtitle={t.whatToDoMetaDescription}
						layout="bento"
						detailSegment="what-to-do"
					/>
				) : (
					<header class="wtd-main__head">
						<h1 class="wtd-main__title">{t.whatToDo}</h1>
						<p class="muted wtd-main__sub">{t.whatToDoMetaDescription}</p>
					</header>
				)
			}

			{
				filtered.length === 0 && allSorted.length > 0 ? (
					<p class="alert" role="status">
						{t.whatToDoFiltersEmpty}
					</p>
				) : null
			}

			{
				filtered.length > 0 ? (
					<div class="card-grid wtd-main__grid">
						{filtered.map((entry) => (
							<article class="card">
								<h2>{entry.data.title}</h2>
								<p class="muted">{entry.data.excerpt}</p>
								<p class="muted">
									{t.duration}: {entry.data.duration}
									{entry.data.price ? ` · ${entry.data.price}` : ''}
									{entry.data.whatDoSeasons?.length
										? ` · ${t.tourSidebarSeason}: ${entry.data.whatDoSeasons.map((id) => t.whatToDoSeasons[id]).join(', ')}`
										: ''}
								</p>
								<a class="btn" href={getRelativeLocaleUrl(locale, `what-to-do/${entry.data.slug}`)}>
									{t.viewWhatToDo}
								</a>
							</article>
						))}
					</div>
				) : null
			}
		</div>
	</div>
</Shell>

<style>
	.wtd-layout {
		display: grid;
		gap: 1.25rem;
		align-items: start;
		margin-top: 0.75rem;
	}
	@media (min-width: 880px) {
		.wtd-layout {
			grid-template-columns: min(300px, 32vw) minmax(0, 1fr);
			gap: 2rem;
		}
	}
	.wtd-filters {
		position: relative;
		padding: 1rem 1rem 1.05rem;
		background: var(--surface);
		border: 1px solid var(--border);
		border-radius: 12px;
		box-shadow: 0 2px 10px rgba(26, 35, 50, 0.06);
		min-width: 0;
	}
	@media (min-width: 880px) {
		.wtd-filters {
			position: sticky;
			top: max(0.75rem, env(safe-area-inset-top, 0px));
			padding: 1.1rem 1.15rem 1.15rem;
		}
	}
	.wtd-filters__heading {
		margin: 0 0 0.35rem;
		font-size: 1.05rem;
		font-weight: 700;
	}
	.wtd-filters__dropdowns {
		display: flex;
		flex-direction: column;
		gap: 0.65rem;
		margin: 0 0 1rem;
		min-width: 0;
	}
	.wtd-filter-dd {
		min-width: 0;
		border-radius: 10px;
	}
	.wtd-filter-dd__trigger {
		display: flex;
		align-items: center;
		justify-content: space-between;
		gap: 0.65rem;
		min-height: 3rem;
		padding: 0.55rem 0.85rem;
		margin: 0;
		list-style: none;
		cursor: pointer;
		border: 1px solid var(--border);
		border-radius: 10px;
		background: color-mix(in srgb, var(--surface) 92%, var(--text) 8%);
		box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.04);
		transition:
			border-color 0.15s ease,
			box-shadow 0.15s ease;
	}
	.wtd-filter-dd__trigger::-webkit-details-marker {
		display: none;
	}
	.wtd-filter-dd__trigger:hover {
		border-color: color-mix(in srgb, var(--border) 70%, var(--accent) 30%);
	}
	.wtd-filter-dd[open] .wtd-filter-dd__trigger {
		border-color: color-mix(in srgb, var(--accent) 45%, var(--border));
		box-shadow:
			0 0 0 1px color-mix(in srgb, var(--accent) 25%, transparent),
			inset 0 1px 0 rgba(255, 255, 255, 0.04);
	}
	.wtd-filter-dd--active .wtd-filter-dd__trigger {
		border-color: color-mix(in srgb, var(--accent) 35%, var(--border));
	}
	.wtd-filter-dd__text {
		display: flex;
		flex-direction: column;
		align-items: flex-start;
		gap: 0.12rem;
		min-width: 0;
		text-align: left;
		flex: 1 1 auto;
	}
	.wtd-filter-dd__label {
		font-size: 0.68rem;
		font-weight: 700;
		text-transform: uppercase;
		letter-spacing: 0.08em;
		color: var(--muted);
		line-height: 1.2;
	}
	.wtd-filter-dd__value {
		font-size: 0.94rem;
		font-weight: 600;
		color: var(--text);
		line-height: 1.35;
		overflow: hidden;
		text-overflow: ellipsis;
		white-space: nowrap;
		max-width: 100%;
	}
	.wtd-filter-dd__chevron {
		flex: 0 0 auto;
		width: 0.55rem;
		height: 0.55rem;
		margin-inline-end: 0.15rem;
		border-inline-end: 2px solid var(--muted);
		border-block-end: 2px solid var(--muted);
		transform: rotate(45deg);
		translate: 0 -0.12rem;
		transition: transform 0.2s ease;
		opacity: 0.85;
	}
	.wtd-filter-dd[open] .wtd-filter-dd__chevron {
		transform: rotate(225deg);
		translate: 0 0.08rem;
	}
	.wtd-filter-dd__panel {
		margin-top: 0.4rem;
		padding: 0.35rem 0;
		max-height: min(50vh, 280px);
		overflow-y: auto;
		-webkit-overflow-scrolling: touch;
		overscroll-behavior: contain;
		border: 1px solid var(--border);
		border-radius: 10px;
		background: var(--surface);
		box-shadow: 0 6px 24px rgba(26, 35, 50, 0.08);
	}
	.wtd-filter-dd__option {
		display: flex;
		flex-direction: row;
		align-items: center;
		gap: 0.65rem;
		margin: 0;
		padding: 0.65rem 0.85rem;
		min-height: 2.75rem;
		font-size: 0.94rem;
		line-height: 1.35;
		cursor: pointer;
		box-sizing: border-box;
	}
	.wtd-filter-dd__option:hover,
	.wtd-filter-dd__option:focus-within {
		background: color-mix(in srgb, var(--accent) 8%, transparent);
	}
	.wtd-filter-dd__option input[type='checkbox'] {
		width: 1.1rem;
		height: 1.1rem;
		min-width: 1.1rem;
		flex: 0 0 auto;
		margin: 0;
		padding: 0;
		border: none;
		background: transparent;
		box-shadow: none;
		accent-color: var(--accent);
		align-self: center;
	}
	.wtd-filter-dd__option-text {
		display: inline;
		margin: 0;
		padding: 0;
		font-weight: 500;
		color: var(--text);
		flex: 1 1 auto;
		min-width: 0;
	}
	.wtd-filters__actions {
		display: flex;
		flex-direction: column;
		gap: 0.5rem;
		margin-top: 0.15rem;
	}
	@media (min-width: 400px) {
		.wtd-filters__actions {
			flex-direction: row;
			flex-wrap: wrap;
			align-items: center;
		}
		.wtd-filters__actions .btn {
			flex: 1 1 auto;
			min-width: 0;
		}
	}
	.wtd-main {
		min-width: 0;
	}
	.wtd-main__head {
		margin-bottom: 1rem;
	}
	.wtd-main__title {
		margin: 0 0 0.35rem;
		font-size: clamp(1.5rem, 4vw, 2rem);
		font-weight: 800;
		letter-spacing: -0.02em;
	}
	.wtd-main__sub {
		margin: 0;
		max-width: 60ch;
		line-height: 1.5;
	}
	.wtd-main__grid {
		margin-top: 0.5rem;
	}
	.wtd-main .alert {
		margin: 0 0 1rem;
		padding: 0.85rem 1rem;
		border-radius: 8px;
		border: 1px solid var(--border);
		background: color-mix(in srgb, var(--accent) 9%, var(--surface));
		color: var(--text);
	}
</style>

<style is:global>
	/* Shell globals: keep filter checkboxes and option labels readable */
	.wtd-filters .wtd-filter-dd__option input[type='checkbox'] {
		width: 1.1rem !important;
		max-width: none !important;
		min-width: 1.1rem !important;
		padding: 0 !important;
		border: none !important;
		background: transparent !important;
		box-shadow: none !important;
		flex: 0 0 auto !important;
	}
	.wtd-filters .wtd-filter-dd__option .wtd-filter-dd__option-text {
		display: inline !important;
		margin: 0 !important;
		font-size: inherit !important;
		color: var(--text) !important;
	}
</style>
